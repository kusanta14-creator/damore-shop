                          .shorts-top-badge {
                            position: absolute;
                            left: 16px;
                            top: 16px;
                            z-index: 6;
                            color: white;
                            font-size: 15px;
                            font-weight: 800;
                            text-shadow: 0 2px 8px rgba(0, 0, 0, 0.24);
                            pointer-events: none;
                          }

                          .shorts-center-icon {
                            position: absolute;
                            left: 50%;
                            top: 50%;
                            transform: translate(-50%, -50%) scale(0.9);
                            width: 72px;
                            height: 72px;
                            border-radius: 50%;
                            background: rgba(0, 0, 0, 0.45);
                            color: #fff;
                            font-size: 28px;
                            font-weight: 800;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            z-index: 9;
                            opacity: 0;
                            pointer-events: none;
                            transition: opacity 0.2s ease, transform 0.2s ease;
                            backdrop-filter: blur(6px);
                          }

                          .shorts-center-icon.show {
                            opacity: 1;
                            transform: translate(-50%, -50%) scale(1);
                          }

                          .shorts-sound-controls {
                            position: absolute;
                            right: 12px;
                            bottom: 90px;
                            display: flex;
                            align-items: center;
                            gap: 8px;
                            padding: 8px 12px;
                            border-radius: 999px;
                            background: rgba(0, 0, 0, 0.6);
                            backdrop-filter: blur(8px);
                            z-index: 10;
                          }

                          .sound-btn {
                            width: 38px;
                            height: 38px;
                            border: 0;
                            border-radius: 50%;
                            background: rgba(255, 255, 255, 0.95);
                            color: #111;
                            font-size: 16px;
                            cursor: pointer;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            flex-shrink: 0;
                          }

                          .volume-range {
                            width: 0;
                            opacity: 0;
                            overflow: hidden;
                            cursor: pointer;
                            transition: width 0.25s ease, opacity 0.25s ease;
                            accent-color: #fff;
                          }

                          .shorts-sound-controls:hover .volume-range {
                            width: 90px;
                            opacity: 1;
                          }

                          .shorts-product-box {
                            position: absolute;
                            left: 14px;
                            right: 14px;
                            bottom: 14px;
                            z-index: 4;
                            display: flex;
                            align-items: center;
                            gap: 10px;
                            padding: 10px;
                            background: rgba(255, 255, 255, 0.95);
                            border-radius: 14px;
                            color: #111;
                            text-decoration: none;
                          }

                          .shorts-product-thumb {
                            width: 56px;
                            height: 56px;
                            border-radius: 10px;
                            overflow: hidden;
                            flex-shrink: 0;
                            background: #eee;
                          }

                          .shorts-product-thumb img {
                            width: 100%;
                            height: 100%;
                            object-fit: cover;
                          }

                          .shorts-product-info {
                            min-width: 0;
                          }

                          .shorts-product-title {
                            font-size: 13px;
                            line-height: 1.35;
                            font-weight: 700;
                            color: #222;
                            display: -webkit-box;
                            line-clamp: 2;
                            -webkit-line-clamp: 2;
                            -webkit-box-orient: vertical;
                            overflow: hidden;
                            margin-bottom: 4px;
                          }

                          .shorts-product-price {
                            font-size: 14px;
                            font-weight: 800;
                            color: #111;
                          }

                          @media (hover: none) {
                            .volume-range {
                              width: 70px;
                              opacity: 1;
                            }
                          }

                          @media (max-width: 1100px) {
                            .shorts-grid {
                              grid-template-columns: repeat(3, minmax(0, 1fr));
                            }
                          }

                          @media (max-width: 860px) {
                            .shorts-grid {
                              grid-template-columns: repeat(2, minmax(0, 1fr));
                            }
                          }

                          @media (max-width: 560px) {
                            .shorts-grid {
                              grid-template-columns: 1fr;
                            }
                          }
                        </style>

                        <div class="container">
                          <div class="shorts-head">
                            <div class="shorts-head-left">
                              <small>Video Content</small>
                              <h2>DAMORE VIDEO</h2>
                            </div>
                            <a href="/about" class="shorts-more">더보기</a>
                          </div>

                          <div class="shorts-grid">
                            <% renderedShortsItems.slice(0, 4).forEach((item, index)=> { %>
                              <div class="shorts-card">
                                <div class="shorts-top-badge">
                                  <%= item.brandLabel || 'DAMORE SHORTS' %>
                                </div>

                                <div class="shorts-video-wrap">
                                  <% if (item.video) { %>
                                    <video class="shorts-video js-shorts-video" src="<%= item.video %>" autoplay muted
                                      loop playsinline preload="metadata" data-index="<%= index %>">
                                    </video>

                                    <div class="shorts-center-icon js-center-icon" data-target="<%= index %>">▶</div>

                                    <div class="shorts-sound-controls">
                                      <button type="button" class="sound-btn js-sound-btn" data-target="<%= index %>"
                                        aria-label="음소거 해제">
                                        🔇
                                      </button>

                                      <input type="range" class="volume-range js-volume-range"
                                        data-target="<%= index %>" min="0" max="1" step="0.05" value="0.5"
                                        aria-label="볼륨 조절">
                                    </div>
                                    <% } else { %>
                                      <div class="shorts-video"
                                        style="display:flex;align-items:center;justify-content:center;color:#fff;">
                                        영상 없음
                                      </div>
                                      <% } %>
                                </div>

                                <a href="<%= item.link || '/about' %>" class="shorts-product-box">
                                  <div class="shorts-product-thumb">
                                    <% if (item.productThumb) { %>
                                      <img src="<%= item.productThumb %>"
                                        alt="<%= item.productTitle || `숏폼 상품 ${index + 1}` %>">
                                      <% } %>
                                  </div>
                                  <div class="shorts-product-info">
                                    <div class="shorts-product-title">
                                      <%= item.productTitle || `숏폼 연결 상품 ${index + 1}` %>
                                    </div>
                                    <div class="shorts-product-price">
                                      <%= item.productPrice || '' %>
                                    </div>
                                  </div>
                                </a>
                              </div>
                              <% }) %>
                          </div>
                        </div>

                        <script>
                          (function () {
                            const videos = document.querySelectorAll('.js-shorts-video');
                            const soundButtons = document.querySelectorAll('.js-sound-btn');
                            const volumeRanges = document.querySelectorAll('.js-volume-range');

                            function updateButton(video, button) {
                              if (!video || !button) return;
                              button.textContent = video.muted || video.volume === 0 ? '🔇' : '🔊';
                              button.setAttribute(
                                'aria-label',
                                video.muted || video.volume === 0 ? '음소거 해제' : '음소거'
                              );
                            }

                            function showCenterIcon(index, iconText, keepVisible) {
                              const icon = document.querySelector('.js-center-icon[data-target="' + index + '"]');
                              if (!icon) return;

                              icon.textContent = iconText;
                              icon.classList.add('show');

                              if (!keepVisible) {
                                clearTimeout(icon._hideTimer);
                                icon._hideTimer = setTimeout(function () {
                                  icon.classList.remove('show');
                                }, 700);
                              }
                            }

                            function pauseOtherVideos(currentIndex) {
                              videos.forEach((video) => {
                                if (video.dataset.index !== currentIndex) {
                                  video.pause();
                                  showCenterIcon(video.dataset.index, '▶', true);
                                }
                              });
                            }

                            function muteOtherVideos(currentIndex) {
                              videos.forEach((video) => {
                                if (video.dataset.index !== currentIndex) {
                                  video.muted = true;
                                }
                              });

                              soundButtons.forEach((button) => {
                                const target = button.dataset.target;
                                const targetVideo = document.querySelector('.js-shorts-video[data-index="' + target + '"]');
                                updateButton(targetVideo, button);
                              });
                            }

                            videos.forEach((video) => {
                              video.muted = true;
                              video.volume = 0.5;

                              video.addEventListener('loadeddata', function () {
                                if (video.paused) {
                                  showCenterIcon(video.dataset.index, '▶', true);
                                }
                              });

                              video.addEventListener('play', function () {
                                showCenterIcon(video.dataset.index, '⏸', false);
                              });

                              video.addEventListener('pause', function () {
                                showCenterIcon(video.dataset.index, '▶', true);
                              });

                              video.addEventListener('click', function () {
                                if (video.paused) {
                                  pauseOtherVideos(video.dataset.index);
                                  video.play();
                                } else {
                                  video.pause();
                                }
                              });
                            });

                            soundButtons.forEach((button) => {
                              button.addEventListener('click', function (e) {
                                e.stopPropagation();

                                const target = this.dataset.target;
                                const video = document.querySelector('.js-shorts-video[data-index="' + target + '"]');
                                const range = document.querySelector('.js-volume-range[data-target="' + target + '"]');

                                if (!video) return;

                                if (video.muted || video.volume === 0) {
                                  muteOtherVideos(target);
                                  video.muted = false;

                                  if (range && Number(range.value) === 0) {
                                    range.value = 0.5;
                                  }

                                  video.volume = range ? Number(range.value) : 0.5;
                                } else {
                                  video.muted = true;
                                }

                                updateButton(video, this);
                              });
                            });

                            volumeRanges.forEach((range) => {
                              range.addEventListener('click', function (e) {
                                e.stopPropagation();
                              });

                              range.addEventListener('input', function () {
                                const target = this.dataset.target;
                                const video = document.querySelector('.js-shorts-video[data-index="' + target + '"]');
                                const button = document.querySelector('.js-sound-btn[data-target="' + target + '"]');

                                if (!video) return;

                                const volume = Number(this.value);
                                video.volume = volume;

                                if (volume <= 0) {
                                  video.muted = true;
                                } else {
                                  muteOtherVideos(target);
                                  video.muted = false;
                                }

                                updateButton(video, button);
                              });
                            });

                            soundButtons.forEach((button) => {
                              const target = button.dataset.target;
                              const video = document.querySelector('.js-shorts-video[data-index="' + target + '"]');
                              updateButton(video, button);
                            });

                            videos.forEach((video) => {
                              if (video.paused) {
                                showCenterIcon(video.dataset.index, '▶', true);
                              }
                            });
                          })();
                        </script>
                      </section>
                      <% } %>

                        <% if (category && bestProducts && bestProducts.length> 0 && currentPage === 1) { %>
                          <section class="best-section">
                            <div class="container">
                              <div class="section-head">
                                <div class="section-head-left">
                                  <small>Best Item</small>
                                  <h2>
                                    <%= category %> best item
                                  </h2>
                                  <p>관리자에서 직접 지정한 베스트 상품입니다.</p>
                                </div>
                              </div>
                              <div class="best-grid">
                                <% bestProducts.forEach((product)=> { %>
                                  <% const hasDiscount=Number(product.oldPrice || 0)> Number(product.price || 0);
                                    const discountPercent = hasDiscount
                                    ? Math.round((1 - (Number(product.price || 0) / Number(product.oldPrice || 0))) *
                                    100)
                                    : 0;
                                    const hasReview = Number(product.reviewCount || 0) > 0;
                                    %>
                                    <a href="/products/<%= product._id %>" class="best-card">
                                      <div class="best-image">
                                        <% if (product.image) { %>
                                          <img src="<%= product.image %>" alt="<%= product.name %>" />
                                          <% } else { %>
                                            <div class="product-no-image">이미지 없음</div>
                                            <% } %>
                                              <% if (product.status==='soldout' ) { %>
                                                <div class="soldout-badge">품절</div>
                                                <% } %>
                                      </div>
                                      <div class="best-info">
                                        <div class="best-name">
                                          <%= product.name %>
                                        </div>
                                        <div class="best-desc">
                                          <%= product.desc ? product.desc.substring(0, 42) : '상품 설명이 없습니다.' %>
                                            <%= product.desc && product.desc.length> 42 ? '...' : '' %>
                                        </div>
                                        <div class="price-row">
                                          <% if (hasDiscount) { %>
                                            <span class="showcase-discount-text">
                                              <%= discountPercent %>%
                                            </span>
                                            <% } %>
                                              <span class="best-price">
                                                <%= Number(product.price || 0).toLocaleString() %>원
                                              </span>
                                              <% if (Number(product.oldPrice || 0)> 0) { %>
                                                <span class="old-price">
                                                  <%= Number(product.oldPrice || 0).toLocaleString() %>원
                                                </span>
                                                <% } %>
                                        </div>
                                        <% if (hasReview) { %>
                                          <div class="showcase-review">
                                            리뷰 <strong>
                                              <%= Number(product.reviewCount || 0).toLocaleString() %>
                                            </strong>
                                          </div>
                                          <% } %>
                                            <div class="product-category">
                                              <%= product.category || 'DAMORE' %>
                                            </div>
                                            <% if (product.tag) { %>
                                              <div class="best-tag">
                                                <%= product.tag %>
                                              </div>
                                              <% } %>
                                      </div>
                                    </a>
                                    <% }) %>
                              </div>
                            </div>
                          </section>
                          <% } %>
        </main>

        <%- include('partials/footer', { currentUser, siteContent: safeSiteContent, categories }) %>

          <script>
            (function () {
              const track = document.getElementById('heroTrack');
              const dotsWrap = document.getElementById('heroDots');
              const prevBtn = document.getElementById('heroPrev');
              const nextBtn = document.getElementById('heroNext');
              if (!track || !dotsWrap) return;

              const slides = Array.from(track.querySelectorAll('.hero-slide'));
              const dots = Array.from(dotsWrap.querySelectorAll('.hero-dot'));
              const slideCount = slides.length;
              let current = 0;
              let autoTimer = null;

              if (!slideCount) return;

              track.style.width = `${slideCount * 100}%`;
              slides.forEach((slide) => {
                slide.style.width = `${100 / slideCount}%`;
                slide.style.minWidth = `${100 / slideCount}%`;
                slide.style.flex = `0 0 ${100 / slideCount}%`;
              });

              function renderSlider(index) {
                current = index;
                track.style.transform = `translateX(-${(100 / slideCount) * current}%)`;
                dots.forEach((dot, i) => {
                  dot.classList.toggle('active', i === current);
                });
              }

              function nextSlide() {
                if (slideCount <= 1) return;
                renderSlider((current + 1) % slideCount);
              }

              function prevSlide() {
                if (slideCount <= 1) return;
                renderSlider((current - 1 + slideCount) % slideCount);
              }

              function stopAuto() {
                if (autoTimer) {
                  clearInterval(autoTimer);
                  autoTimer = null;
                }
              }

              function startAuto() {
                stopAuto();
                if (slideCount <= 1) return;
                autoTimer = setInterval(nextSlide, 4000);
              }

              if (prevBtn) {
                prevBtn.addEventListener('click', function (e) {
                  e.preventDefault();
                  prevSlide();
                  startAuto();
                });
              }

              if (nextBtn) {
                nextBtn.addEventListener('click', function (e) {
                  e.preventDefault();
                  nextSlide();
                  startAuto();
                });
              }

              dots.forEach((dot, index) => {
                dot.addEventListener('click', function (e) {
                  e.preventDefault();
                  renderSlider(index);
                  startAuto();
                });
              });

              track.addEventListener('mouseenter', stopAuto);
              track.addEventListener('mouseleave', startAuto);

              renderSlider(0);
              startAuto();
            })();

            (function () {
              const items = document.querySelectorAll('[data-pos]');
              items.forEach((el) => {
                const top = el.dataset.top || '';
                const left = el.dataset.left || '';
                const right = el.dataset.right || '';
                const bottom = el.dataset.bottom || '';
                if (top) el.style.top = top;
                if (left) el.style.left = left;
                if (right) el.style.right = right;
                if (bottom) el.style.bottom = bottom;
              });
            })();

            (function () {
              const tabButtons = document.querySelectorAll('[data-home-tab-btn]');
              const tabPanels = document.querySelectorAll('[data-home-tab-panel]');
              if (!tabButtons.length) return;

              tabButtons.forEach((button) => {
                button.addEventListener('click', function () {
                  const sectionId = button.dataset.section;
                  const tabIndex = button.dataset.tab;

                  tabButtons.forEach((btn) => {
                    if (btn.dataset.section === sectionId) {
                      btn.classList.toggle('active', btn.dataset.tab === tabIndex);
                    }
                  });

                  tabPanels.forEach((panel) => {
                    if (panel.dataset.section === sectionId) {
                      panel.classList.toggle('active', panel.dataset.tab === tabIndex);
                    }
                  });
                });
              });
            })();

            (function () {
              const sliders = document.querySelectorAll('[data-section-slider]');
              sliders.forEach((slider) => {
                const track = slider.querySelector('[data-slider-track]');
                const dots = Array.from(slider.querySelectorAll('[data-slider-dot]'));
                const total = Number(slider.dataset.total || 0);

                if (!track || total <= 1) return;

                let current = 0;
                let timer = null;

                function render(index) {
                  current = index;
                  track.style.transform = `translateX(-${current * 100}%)`;
                  dots.forEach((dot, i) => {
                    dot.classList.toggle('active', i === current);
                  });
                }

                function next() {
                  render((current + 1) % total);
                }

                function stop() {
                  if (timer) {
                    clearInterval(timer);
                    timer = null;
                  }
                }

                function start() {
                  stop();
                  timer = setInterval(next, 3500);
                }

                dots.forEach((dot, index) => {
                  dot.addEventListener('click', function () {
                    render(index);
                    start();
                  });
                });

                slider.addEventListener('mouseenter', stop);
                slider.addEventListener('mouseleave', start);

                render(0);
                start();
              });
            })();
          </script>
</body>

</html>
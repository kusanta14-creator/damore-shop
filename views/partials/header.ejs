<header>
  <div class="container">
    <div class="header-inner">
      <a href="/" class="brand">
        <span class="brand-logo">DAMORE</span>
        <span class="brand-sub">the more, the mood</span>
      </a>

      <nav class="nav">
        <a href="/" class="<%= (typeof currentPath !== 'undefined' && currentPath === '/') ? 'active' : '' %>">all</a>

        <% if (categories && categories.length > 0) { %>
          <% categories.forEach(item => { %>
            <div class="nav-item">
              <a href="/category/<%= item.name %>" class="nav-link <%= category === item.name ? 'active' : '' %>">
                <%= item.name %>
              </a>

              <% if (item.subCategories && item.subCategories.length > 0) { %>
                <div class="dropdown-menu">
                  <% item.subCategories.forEach(subItem => { %>
                    <a href="/category/<%= item.name %>?sub=<%= encodeURIComponent(subItem) %>">
                      <%= subItem %>
                    </a>
                  <% }) %>
                </div>
              <% } %>
            </div>
          <% }) %>
        <% } %>

        <a href="/about" class="<%= (typeof currentPath !== 'undefined' && currentPath === '/about') ? 'active' : '' %>">about</a>
      </nav>

      <div class="header-actions">
        <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
          <a href="/admin/dashboard">관리자 수정</a>
          <a href="/logout">로그아웃</a>
        <% } else if (currentUser) { %>
          <span class="user-name"><%= currentUser.name %>님</span>
          <a href="/my-orders">내 주문내역</a>
          <a href="/logout">로그아웃</a>
        <% } else { %>
          <a href="/order/lookup">주문조회</a>
          <a href="/auth">로그인 / 회원가입</a>
        <% } %>

        <a href="/cart">장바구니 <%= typeof cartCount !== 'undefined' ? cartCount : 0 %></a>
      </div>
    </div>
  </div>
</header>
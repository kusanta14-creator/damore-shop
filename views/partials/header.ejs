<%
  const safeCategories = Array.isArray(typeof categories !== 'undefined' ? categories : []) ? categories : [];
  const safeCategory = typeof category !== 'undefined' ? category : '';
  const safeCurrentPath = typeof currentPath !== 'undefined' ? currentPath : '';
  const safeIsAdmin = typeof isAdmin !== 'undefined' ? isAdmin : false;
  const safeCurrentUser = typeof currentUser !== 'undefined' ? currentUser : null;
  const safeCartCount = typeof cartCount !== 'undefined' ? cartCount : 0;
  const isCommunityActive = safeCurrentPath.startsWith('/community');
%>

<header>
  <div class="container">
    <div class="header-inner">
      <a href="/" class="brand">
        <span class="brand-logo">DAMORE</span>
        <span class="brand-sub">the more, the mood</span>
      </a>

      <nav class="nav">
        <a href="/" class="<%= safeCurrentPath === '/' ? 'active' : '' %>">all</a>

        <% if (safeCategories.length > 0) { %>
          <% safeCategories.forEach(item => { %>
            <div class="nav-item">
              <a href="/category/<%= item.name %>" class="nav-link <%= safeCategory === item.name ? 'active' : '' %>">
                <%= item.name %>
              </a>

              <% if (item.subCategories && item.subCategories.length > 0) { %>
                <div class="dropdown-menu">
                  <% item.subCategories.forEach(subItem => { %>
                    <a href="/category/<%= item.name %>?sub=<%= encodeURIComponent(subItem) %>">
                      <%= subItem %>
                    </a>
                  <% }) %>
                </div>
              <% } %>
            </div>
          <% }) %>
        <% } %>

        <a href="/about" class="<%= safeCurrentPath === '/about' ? 'active' : '' %>">about</a>

        <div class="nav-item">
          <a href="/community/notice" class="nav-link <%= isCommunityActive ? 'active' : '' %>">
            커뮤니티
          </a>

          <div class="dropdown-menu">
            <a href="/community/notice">공지사항</a>
            <a href="/community/review">리뷰</a>
            <a href="/community/event">이벤트</a>
            <a href="/community/customer">고객센터</a>
          </div>
        </div>
      </nav>

      <div class="header-actions">
        <% if (safeIsAdmin) { %>
          <a href="/admin/dashboard">관리자 수정</a>
          <a href="/logout">로그아웃</a>
        <% } else if (safeCurrentUser) { %>
          <span class="user-name"><%= safeCurrentUser.name %>님</span>
          <a href="/my-orders">내 주문내역</a>
          <a href="/logout">로그아웃</a>
        <% } else { %>
          <a href="/order/lookup">주문조회</a>
          <a href="/auth">로그인 / 회원가입</a>
        <% } %>

        <a href="/cart">장바구니 <%= safeCartCount %></a>
      </div>
    </div>
  </div>
</header>
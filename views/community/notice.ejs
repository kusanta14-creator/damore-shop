<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageTitle %> | DAMORE</title>
  <link rel="stylesheet" href="/css/common.css" />
  <style>
    body {
      margin: 0;
      background: #f6f4ef;
      color: #111;
      font-family: Arial, sans-serif;
    }

    .page {
      max-width: 1100px;
      margin: 0 auto;
      padding: 48px 20px 80px;
    }

    .community-head {
      margin-bottom: 28px;
      text-align: center;
    }

    .community-head h1 {
      margin: 0 0 10px;
      font-size: 34px;
      font-weight: 800;
    }

    .community-head p {
      margin: 0;
      color: #777;
      font-size: 14px;
    }

    .community-tabs {
      display: flex;
      justify-content: center;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 24px;
    }

    .community-tabs a {
      padding: 10px 16px;
      border: 1px solid #ddd2c4;
      border-radius: 999px;
      background: #fff;
      color: #444;
      text-decoration: none;
      font-size: 14px;
      font-weight: 700;
    }

    .community-tabs a.active {
      background: #111;
      color: #fff;
      border-color: #111;
    }

    .notice-topbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 18px;
    }

    .admin-actions {
      display: flex;
      justify-content: flex-end;
      gap: 10px;
      flex-wrap: wrap;
    }

    .admin-write-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 44px;
      padding: 0 18px;
      border-radius: 999px;
      background: #111;
      color: #fff;
      text-decoration: none;
      font-size: 14px;
      font-weight: 800;
    }

    .search-form {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      width: 100%;
      max-width: 460px;
    }

    .search-form input[type="text"] {
      flex: 1;
      min-width: 220px;
      height: 44px;
      padding: 0 14px;
      border: 1px solid #ddd2c4;
      border-radius: 999px;
      background: #fff;
      font-size: 14px;
      outline: none;
    }

    .search-form button,
    .search-form a {
      height: 44px;
      padding: 0 16px;
      border-radius: 999px;
      border: 0;
      background: #111;
      color: #fff;
      text-decoration: none;
      font-size: 14px;
      font-weight: 800;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
    }

    .search-form a {
      background: #666;
    }

    .notice-summary {
      margin-bottom: 14px;
      color: #666;
      font-size: 14px;
    }

    .board-card {
      background: #fff;
      border: 1px solid #e8e0d4;
      border-radius: 18px;
      overflow: hidden;
    }

    .board-row {
      display: grid;
      grid-template-columns: 100px 1fr 160px;
      gap: 16px;
      align-items: center;
      padding: 18px 22px;
      border-bottom: 1px solid #f0ebe3;
      color: inherit;
      text-decoration: none;
      transition: background 0.15s ease;
    }

    .board-row:hover {
      background: #fcfaf7;
    }

    .board-row:last-child {
      border-bottom: 0;
    }

    .board-row.head {
      background: #fbf9f5;
      font-weight: 800;
      color: #555;
    }

    .board-row.head:hover {
      background: #fbf9f5;
    }

    .board-title {
      font-weight: 700;
      line-height: 1.5;
      word-break: keep-all;
    }

    .board-date {
      color: #777;
      text-align: right;
      font-size: 14px;
    }

    .pin-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 6px 10px;
      border-radius: 999px;
      background: #111;
      color: #fff;
      font-size: 12px;
      font-weight: 700;
      width: fit-content;
    }

    .empty-box {
      padding: 70px 20px;
      text-align: center;
      color: #666;
      font-size: 15px;
      line-height: 1.8;
      background: #fff;
      border: 1px solid #e8e0d4;
      border-radius: 18px;
    }

    .pagination {
      margin-top: 22px;
      display: flex;
      justify-content: center;
      gap: 8px;
      flex-wrap: wrap;
    }

    .pagination a,
    .pagination span {
      min-width: 42px;
      height: 42px;
      padding: 0 12px;
      border-radius: 999px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      font-size: 14px;
      font-weight: 800;
      border: 1px solid #ddd2c4;
      background: #fff;
      color: #444;
    }

    .pagination .active {
      background: #111;
      color: #fff;
      border-color: #111;
    }

    .pagination .disabled {
      opacity: 0.45;
      pointer-events: none;
    }

    @media (max-width: 768px) {
      .page {
        padding: 36px 14px 64px;
      }

      .notice-topbar {
        align-items: stretch;
      }

      .search-form {
        max-width: none;
      }

      .search-form input[type="text"] {
        min-width: 0;
      }

      .board-row {
        grid-template-columns: 1fr;
        gap: 8px;
      }

      .board-date {
        text-align: left;
      }

      .board-row.head {
        display: none;
      }

      .admin-actions,
      .search-form {
        width: 100%;
      }

      .admin-write-btn,
      .search-form button,
      .search-form a {
        width: 100%;
      }
    }
  </style>
</head>
<body>
  <%- include('../partials/header') %>

  <div class="page">
    <div class="community-head">
      <h1>공지사항</h1>
      <p>다모어의 공지사항을 확인해보세요.</p>
    </div>

    <div class="community-tabs">
      <a href="/community/notice" class="active">공지사항</a>
      <a href="/community/review">리뷰</a>
      <a href="/community/event">이벤트</a>
      <a href="/community/customer">고객센터</a>
    </div>

    <div class="notice-topbar">
      <form action="/community/notice" method="GET" class="search-form">
        <input
          type="text"
          name="keyword"
          placeholder="공지 제목 검색"
          value="<%= keyword || '' %>"
        />
        <button type="submit">검색</button>
        <% if (keyword) { %>
          <a href="/community/notice">초기화</a>
        <% } %>
      </form>

      <% if (isAdmin) { %>
        <div class="admin-actions">
          <a href="/admin/notices/new" class="admin-write-btn">공지 작성하기</a>
        </div>
      <% } %>
    </div>

    <div class="notice-summary">
      총 <strong><%= totalCount || 0 %></strong>개의 공지
      <% if (keyword) { %>
        · 검색어: "<strong><%= keyword %></strong>"
      <% } %>
    </div>

    <% if (notices && notices.length > 0) { %>
      <div class="board-card">
        <div class="board-row head">
          <div>구분</div>
          <div>제목</div>
          <div class="board-date">등록일</div>
        </div>

        <% notices.forEach((notice) => { %>
          <a href="/community/notice/<%= notice._id %>" class="board-row">
            <div>
              <% if (notice.isPinned) { %>
                <span class="pin-badge">공지</span>
              <% } else { %>
                일반
              <% } %>
            </div>
            <div class="board-title"><%= notice.title %></div>
            <div class="board-date">
              <%= notice.date || new Date(notice.createdAt).toLocaleDateString('ko-KR') %>
            </div>
          </a>
        <% }) %>
      </div>

      <% if (totalPages > 1) { %>
        <div class="pagination">
          <% if (hasPrevPage) { %>
            <a href="/community/notice?page=<%= currentPage - 1 %><%= keyword ? '&keyword=' + encodeURIComponent(keyword) : '' %>">이전</a>
          <% } else { %>
            <span class="disabled">이전</span>
          <% } %>

          <% for (let i = startPage; i <= endPage; i++) { %>
            <% if (i === currentPage) { %>
              <span class="active"><%= i %></span>
            <% } else { %>
              <a href="/community/notice?page=<%= i %><%= keyword ? '&keyword=' + encodeURIComponent(keyword) : '' %>"><%= i %></a>
            <% } %>
          <% } %>

          <% if (hasNextPage) { %>
            <a href="/community/notice?page=<%= currentPage + 1 %><%= keyword ? '&keyword=' + encodeURIComponent(keyword) : '' %>">다음</a>
          <% } else { %>
            <span class="disabled">다음</span>
          <% } %>
        </div>
      <% } %>
    <% } else { %>
      <div class="empty-box">
        <% if (keyword) { %>
          검색 결과가 없습니다.
        <% } else { %>
          등록된 공지사항이 없습니다.
        <% } %>
      </div>
    <% } %>
  </div>

  <%- include('../partials/footer') %>
</body>
</html>
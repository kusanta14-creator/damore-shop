<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageTitle %> | DAMORE</title>
  <link rel="stylesheet" href="/css/common.css" />
  <style>
    body {
      margin: 0;
      background: #f6f4ef;
      color: #111;
      font-family: Arial, sans-serif;
    }

    .page {
      max-width: 1100px;
      margin: 0 auto;
      padding: 48px 20px 80px;
    }

    .community-head {
      margin-bottom: 28px;
      text-align: center;
    }

    .community-head h1 {
      margin: 0 0 10px;
      font-size: 34px;
      font-weight: 800;
    }

    .community-head p {
      margin: 0;
      color: #777;
      font-size: 14px;
    }

    .community-tabs {
      display: flex;
      justify-content: center;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 34px;
    }

    .community-tabs a {
      padding: 10px 16px;
      border: 1px solid #ddd2c4;
      border-radius: 999px;
      background: #fff;
      color: #444;
      text-decoration: none;
      font-size: 14px;
      font-weight: 700;
    }

    .community-tabs a.active {
      background: #111;
      color: #fff;
      border-color: #111;
    }

    .board-card {
      background: #fff;
      border: 1px solid #e8e0d4;
      border-radius: 18px;
      overflow: hidden;
    }

    .board-row {
      display: grid;
      grid-template-columns: 100px 1fr 160px;
      gap: 16px;
      align-items: center;
      padding: 18px 22px;
      border-bottom: 1px solid #f0ebe3;
      color: inherit;
      text-decoration: none;
    }

    .board-row:last-child {
      border-bottom: 0;
    }

    .board-row.head {
      background: #fbf9f5;
      font-weight: 800;
      color: #555;
    }

    .board-title {
      font-weight: 700;
    }

    .board-date {
      color: #777;
      text-align: right;
      font-size: 14px;
    }

    .pin-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 6px 10px;
      border-radius: 999px;
      background: #111;
      color: #fff;
      font-size: 12px;
      font-weight: 700;
      width: fit-content;
    }

    .empty-box {
      padding: 70px 20px;
      text-align: center;
      color: #666;
      font-size: 15px;
      line-height: 1.8;
      background: #fff;
      border: 1px solid #e8e0d4;
      border-radius: 18px;
    }

    @media (max-width: 768px) {
      .board-row {
        grid-template-columns: 1fr;
        gap: 8px;
      }

      .board-date {
        text-align: left;
      }

      .board-row.head {
        display: none;
      }
    }
  </style>
</head>
<body>
  <%- include('../partials/header') %>

  <div class="page">
    <div class="community-head">
      <h1>공지사항</h1>
      <p>다모어의 공지사항을 확인해보세요.</p>
    </div>

    <div class="community-tabs">
      <a href="/community/notice" class="active">공지사항</a>
      <a href="/community/review">리뷰</a>
      <a href="/community/event">이벤트</a>
      <a href="/community/customer">고객센터</a>
    </div>

    <% if (notices && notices.length > 0) { %>
      <div class="board-card">
        <div class="board-row head">
          <div>구분</div>
          <div>제목</div>
          <div class="board-date">등록일</div>
        </div>

        <% notices.forEach((notice) => { %>
          <a href="/community/notice/<%= notice._id %>" class="board-row">
            <div>
              <% if (notice.isPinned) { %>
                <span class="pin-badge">공지</span>
              <% } else { %>
                일반
              <% } %>
            </div>
            <div class="board-title"><%= notice.title %></div>
            <div class="board-date"><%= new Date(notice.createdAt).toLocaleDateString('ko-KR') %></div>
          </a>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-box">등록된 공지사항이 없습니다.</div>
    <% } %>
  </div>

  <%- include('../partials/footer') %>
</body>
</html>
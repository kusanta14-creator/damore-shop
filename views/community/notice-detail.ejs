<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageTitle %> | DAMORE</title>
  <link rel="stylesheet" href="/css/common.css" />
  <style>
    body {
      margin: 0;
      background: #f6f4ef;
      color: #111;
      font-family: Arial, sans-serif;
    }

    .page {
      max-width: 900px;
      margin: 0 auto;
      padding: 48px 20px 80px;
    }

    .detail-card {
      background: #fff;
      border: 1px solid #e8e0d4;
      border-radius: 18px;
      overflow: hidden;
    }

    .detail-head {
      padding: 26px 28px;
      border-bottom: 1px solid #f0ebe3;
    }

    .detail-title {
      margin: 0 0 10px;
      font-size: 28px;
      font-weight: 800;
      line-height: 1.4;
    }

    .detail-meta {
      color: #777;
      font-size: 14px;
    }

    .detail-content {
      padding: 28px;
      color: #333;
      font-size: 15px;
      line-height: 1.9;
      white-space: pre-line;
      word-break: keep-all;
    }

    .bottom-actions {
      margin-top: 20px;
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .bottom-actions a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 12px 16px;
      border-radius: 10px;
      background: #111;
      color: #fff;
      text-decoration: none;
      font-size: 14px;
      font-weight: 700;
    }

    .bottom-actions a.sub {
      background: #666;
    }
  </style>
</head>
<body>
  <%- include('../partials/header') %>

  <div class="page">
    <div class="detail-card">
      <div class="detail-head">
        <h1 class="detail-title"><%= notice.title %></h1>
        <div class="detail-meta"><%= new Date(notice.createdAt).toLocaleDateString('ko-KR') %></div>
      </div>

      <div class="detail-content"><%= notice.content %></div>
    </div>

    <div class="bottom-actions">
      <a href="/community/notice" class="sub">목록으로</a>
    </div>
  </div>

  <%- include('../partials/footer') %>
</body>
</html>
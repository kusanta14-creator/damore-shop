  <script>

  (function () {
    const forms = document.querySelectorAll('.live-preview-form');

    function qs(root, sel) {
      return root.querySelector(sel);
    }

    function qsa(root, sel) {
      return Array.from(root.querySelectorAll(sel));
    }

    function setStylePos(el, pos) {
      if (!el) return;
      el.style.top = pos.top || '';
      el.style.left = pos.left || '';
      el.style.right = pos.right || '';
      el.style.bottom = pos.bottom || '';
    }

    function setInputValue(form, name, value) {
      const input = qs(form, '[name="' + name + '"]');
      if (input) input.value = value;
    }

    function getInputValue(form, name, fallback) {
      const input = qs(form, '[name="' + name + '"]');
      return input ? input.value : fallback;
    }

    function updateText(container, name, value) {
      qsa(container, '[data-preview-target="' + name + '"]').forEach((el) => {
        el.textContent = value;
      });
    }

    function updateImage(container, name, src) {
      qsa(container, '[data-preview-target-image="' + name + '"]').forEach((el) => {
        if (src) el.src = src;
      });

      qsa(container, '[data-preview-image="' + name + '"]').forEach((el) => {
        if (src) el.src = src;
      });
    }

    function updateToggle(container, wrapName, checked) {
      qsa(container, '[data-preview-target-wrap="' + wrapName + '"]').forEach((el) => {
        el.style.display = checked ? '' : 'none';
      });
    }

    function refreshCommonPositions(container, form) {
      const title = qs(container, '[data-pos-target="title"]');
      const benefit = qs(container, '[data-pos-target="benefit"]');
      const button = qs(container, '[data-pos-target="button"]');
      const point = qs(container, '[data-pos-target="point"]');
      const label = qs(container, '[data-drag-type="label"]');

      setStylePos(title, {
        top: getInputValue(form, 'titleTop', '58%'),
        left: getInputValue(form, 'titleLeft', '34px'),
        right: '',
        bottom: ''
      });

      setStylePos(benefit, {
        top: '',
        left: getInputValue(form, 'benefitLeft', '34px'),
        right: '',
        bottom: getInputValue(form, 'benefitBottom', '86px')
      });

      setStylePos(button, {
        top: '',
        left: getInputValue(form, 'buttonLeft', '34px'),
        right: '',
        bottom: getInputValue(form, 'buttonBottom', '34px')
      });

      setStylePos(point, {
        top: '',
        left: '',
        right: getInputValue(form, 'pointRight', '34px'),
        bottom: getInputValue(form, 'pointBottom', '34px')
      });

      if (label) {
        if (!label.style.top) label.style.top = '22px';
        if (!label.style.left) label.style.left = '22px';
      }
    }

    function refreshBadgePositions(container, form) {
      ['1', '2', '3'].forEach((n) => {
        const badge = qs(container, '[data-badge="badge' + n + '"]');
        if (!badge) return;

        setStylePos(badge, {
          top: getInputValue(form, 'badge' + n + 'Top', ''),
          left: getInputValue(form, 'badge' + n + 'Left', ''),
          right: getInputValue(form, 'badge' + n + 'Right', ''),
          bottom: getInputValue(form, 'badge' + n + 'Bottom', '')
        });
      });
    }

    function bindDrag(container, form) {
      qsa(container, '.drag-item').forEach((item) => {
        item.addEventListener('pointerdown', function (e) {
          e.preventDefault();

          const type = item.getAttribute('data-drag-type');
          const panel = item.closest('.hero-preview-panel');
          if (!panel) return;

          const panelRect = panel.getBoundingClientRect();
          const itemRect = item.getBoundingClientRect();

          const startOffsetX = e.clientX - itemRect.left;
          const startOffsetY = e.clientY - itemRect.top;

          item.classList.add('dragging');

          function onMove(ev) {
            const currentRect = item.getBoundingClientRect();

            let left = ev.clientX - panelRect.left - startOffsetX;
            let top = ev.clientY - panelRect.top - startOffsetY;

            const maxLeft = Math.max(panelRect.width - currentRect.width, 0);
            const maxTop = Math.max(panelRect.height - currentRect.height, 0);

            left = Math.max(0, Math.min(left, maxLeft));
            top = Math.max(0, Math.min(top, maxTop));

            if (type === 'label') {
              item.style.left = Math.round(left) + 'px';
              item.style.top = Math.round(top) + 'px';
              return;
            }

            if (type === 'title') {
              const newLeft = Math.round(left) + 'px';
              const newTop = Math.round(top) + 'px';
              setInputValue(form, 'titleLeft', newLeft);
              setInputValue(form, 'titleTop', newTop);
              setStylePos(item, {
                left: newLeft,
                top: newTop,
                right: '',
                bottom: ''
              });
              return;
            }

            if (type === 'benefit') {
              const newLeft = Math.round(left) + 'px';
              const newBottom = Math.round(panelRect.height - top - currentRect.height) + 'px';
              setInputValue(form, 'benefitLeft', newLeft);
              setInputValue(form, 'benefitBottom', newBottom);
              setStylePos(item, {
                left: newLeft,
                bottom: newBottom,
                top: '',
                right: ''
              });
              return;
            }

            if (type === 'button') {
              const newLeft = Math.round(left) + 'px';
              const newBottom = Math.round(panelRect.height - top - currentRect.height) + 'px';
              setInputValue(form, 'buttonLeft', newLeft);
              setInputValue(form, 'buttonBottom', newBottom);
              setStylePos(item, {
                left: newLeft,
                bottom: newBottom,
                top: '',
                right: ''
              });
              return;
            }

            if (type === 'point') {
              const newRight = Math.round(panelRect.width - left - currentRect.width) + 'px';
              const newBottom = Math.round(panelRect.height - top - currentRect.height) + 'px';
              setInputValue(form, 'pointRight', newRight);
              setInputValue(form, 'pointBottom', newBottom);
              setStylePos(item, {
                right: newRight,
                bottom: newBottom,
                top: '',
                left: ''
              });
              return;
            }

            if (type === 'badge1' || type === 'badge2' || type === 'badge3') {
              const n = type.replace('badge', '');
              const newTop = Math.round(top) + 'px';
              const newLeft = Math.round(left) + 'px';

              setInputValue(form, 'badge' + n + 'Top', newTop);
              setInputValue(form, 'badge' + n + 'Left', newLeft);
              setInputValue(form, 'badge' + n + 'Right', '');
              setInputValue(form, 'badge' + n + 'Bottom', '');

              setStylePos(item, {
                top: newTop,
                left: newLeft,
                right: '',
                bottom: ''
              });
            }
          }

          function onUp() {
            item.classList.remove('dragging');
            window.removeEventListener('pointermove', onMove);
            window.removeEventListener('pointerup', onUp);
          }

          window.addEventListener('pointermove', onMove);
          window.addEventListener('pointerup', onUp);
        });
      });
    }

    forms.forEach((form) => {
      const container = form.closest('.editor-layout');
      if (!container) return;

      const togglePairs = [
        { checkbox: 'showMainLabel', wrap: 'mainLabel' },
        { checkbox: 'showButton', wrap: 'buttonText' },
        { checkbox: 'showBadge1', wrap: 'badge1' },
        { checkbox: 'showBadge2', wrap: 'badge2' },
        { checkbox: 'showBadge3', wrap: 'badge3' },
        { checkbox: 'showBenefit1', wrap: 'benefit1Text' },
        { checkbox: 'showBenefit2', wrap: 'benefit2Text' },
        { checkbox: 'showBenefit3', wrap: 'benefit3Text' },
        { checkbox: 'showPoint1', wrap: 'point1Text' },
        { checkbox: 'showPoint2', wrap: 'point2Text' },
        { checkbox: 'showPoint3', wrap: 'point3Text' }
      ];

      qsa(form, '[data-preview]').forEach((input) => {
        const name = input.getAttribute('data-preview');
        updateText(container, name, input.value);
        input.addEventListener('input', function () {
          updateText(container, name, input.value);
        });
      });

      qsa(form, '[data-preview-file]').forEach((input) => {
        const name = input.getAttribute('data-preview-file');
        input.addEventListener('change', function (e) {
          const file = e.target.files && e.target.files[0];
          if (!file) return;

          const reader = new FileReader();
          reader.onload = function (ev) {
            updateImage(container, name, ev.target.result);
          };
          reader.readAsDataURL(file);
        });
      });

      qsa(form, '[data-pos-input]').forEach((input) => {
        input.addEventListener('input', function () {
          refreshCommonPositions(container, form);
        });
      });

      qsa(form, '[data-badge-pos]').forEach((input) => {
        input.addEventListener('input', function () {
          refreshBadgePositions(container, form);
        });
      });

      togglePairs.forEach((item) => {
        const checkbox = qs(form, 'input[name="' + item.checkbox + '"]');
        if (!checkbox) return;

        updateToggle(container, item.wrap, checkbox.checked);
        checkbox.addEventListener('change', function () {
          updateToggle(container, item.wrap, checkbox.checked);
        });
      });

      refreshCommonPositions(container, form);
      refreshBadgePositions(container, form);
      bindDrag(container, form);
    });
  })();
  </script>
</body>
</html>
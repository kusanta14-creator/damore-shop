<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= mode === 'edit' ? '상품 수정' : '상품 등록' %> | DAMORE ADMIN</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg: #f5f3ef;
      --white: #ffffff;
      --black: #111111;
      --muted: #6f6a63;
      --line: rgba(17, 17, 17, 0.08);
      --gold: #9d8660;
      --shadow: 0 18px 50px rgba(0, 0, 0, 0.08);
      --radius: 24px;
      --max: 1480px;
      --soft: #efe9df;
      --red: #b23a2c;
      --red-bg: #fff1ee;
      --green: #1f7a4d;
      --green-bg: #edf7f0;
    }

    body {
      font-family: "Pretendard", "Noto Sans KR", Arial, sans-serif;
      background: var(--bg);
      color: var(--black);
      line-height: 1.6;
    }

    a {
      text-decoration: none;
      color: inherit;
    }

    button,
    input,
    textarea,
    select {
      font: inherit;
    }

    .container {
      width: 100%;
      max-width: var(--max);
      margin: 0 auto;
      padding: 0 24px;
    }

    .page {
      padding: 40px 0 80px;
    }

    .page-head {
      margin-bottom: 22px;
    }

    .page-head small {
      display: inline-block;
      margin-bottom: 10px;
      color: var(--gold);
      font-size: 12px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      font-weight: 700;
    }

    .page-head h1 {
      font-size: 38px;
      margin-bottom: 10px;
    }

    .page-head p {
      color: var(--muted);
      font-size: 15px;
    }

    .top-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 24px;
    }

    .top-btn {
      min-width: 160px;
      height: 46px;
      padding: 0 18px;
      border-radius: 999px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      font-weight: 800;
      border: 0;
      cursor: pointer;
    }

    .top-btn-dark {
      background: #111;
      color: #fff;
    }

    .top-btn-light {
      background: var(--soft);
      color: #111;
    }

    .admin-layout {
      display: grid;
      grid-template-columns: minmax(0, 1.08fr) minmax(360px, 0.7fr);
      gap: 24px;
      align-items: start;
    }

    .card {
      background: #fff;
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 28px;
    }

    .preview-sticky {
      position: sticky;
      top: 24px;
    }

    .section-title {
      font-size: 24px;
      margin-bottom: 18px;
    }

    .section-block + .section-block {
      margin-top: 28px;
      padding-top: 28px;
      border-top: 1px solid var(--line);
    }

    .section-label {
      font-size: 18px;
      font-weight: 800;
      margin-bottom: 14px;
    }

    .grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px;
    }

    .form-group {
      margin-bottom: 18px;
    }

    .full {
      grid-column: 1 / -1;
    }

    label {
      display: block;
      margin-bottom: 8px;
      font-size: 14px;
      font-weight: 700;
    }

    input[type="text"],
    input[type="number"],
    input[type="file"],
    textarea,
    select {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 14px 16px;
      font-size: 14px;
      outline: none;
      background: #fff;
      transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }

    input[type="text"]:focus,
    input[type="number"]:focus,
    textarea:focus,
    select:focus {
      border-color: rgba(157, 134, 96, 0.8);
      box-shadow: 0 0 0 4px rgba(157, 134, 96, 0.12);
    }

    textarea {
      min-height: 120px;
      resize: vertical;
    }

    .help {
      margin-top: 6px;
      font-size: 12px;
      color: var(--muted);
    }

    .preview-box {
      margin-top: 10px;
      padding: 14px 16px;
      border-radius: 16px;
      background: #faf8f4;
      border: 1px solid var(--line);
      font-size: 13px;
      color: var(--muted);
      line-height: 1.8;
    }

    .preview-value {
      color: #111;
      font-weight: 800;
      word-break: break-all;
    }

    .preview-image-list {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 10px;
      margin-top: 12px;
    }

    .preview-item {
      overflow: hidden;
      border-radius: 16px;
      background: #fff;
      border: 1px solid rgba(17, 17, 17, 0.06);
    }

    .preview-item img,
    .preview-item video {
      width: 100%;
      height: 140px;
      object-fit: cover;
      display: block;
      background: #ece8e1;
    }

    .preview-item .cap {
      padding: 8px 10px;
      font-size: 11px;
      color: #666;
      word-break: break-all;
      background: #fff;
    }

    .check-row {
      display: flex;
      align-items: center;
      gap: 10px;
      min-height: 52px;
      padding: 0 14px;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: #fff;
    }

    .check-row input[type="checkbox"] {
      width: 18px;
      height: 18px;
    }

    .actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 10px;
    }

    .submit-btn {
      min-width: 180px;
      height: 54px;
      padding: 0 20px;
      border: 0;
      border-radius: 999px;
      cursor: pointer;
      font-size: 15px;
      font-weight: 800;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .submit-btn-dark {
      background: #111;
      color: #fff;
    }

    .submit-btn-light {
      background: var(--soft);
      color: #111;
    }

    .checkbox-list {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
      margin-top: 10px;
    }

    .checkbox-card {
      display: flex;
      gap: 10px;
      align-items: center;
      border: 1px solid #eee;
      border-radius: 14px;
      padding: 10px;
      background: #fafafa;
      cursor: pointer;
    }

    .checkbox-card input[type="checkbox"] {
      width: 18px;
      height: 18px;
      margin: 0;
      padding: 0;
      flex-shrink: 0;
    }

    .checkbox-card img {
      width: 52px;
      height: 52px;
      object-fit: cover;
      border-radius: 10px;
      background: #ddd;
      flex-shrink: 0;
    }

    .checkbox-card-text {
      min-width: 0;
    }

    .checkbox-card-title {
      font-size: 13px;
      font-weight: 700;
      line-height: 1.35;
      word-break: break-word;
    }

    .checkbox-card-price {
      font-size: 12px;
      color: #666;
      margin-top: 4px;
    }

    .live-title {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 14px;
    }

    .live-title h2 {
      font-size: 22px;
    }

    .live-chip {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 32px;
      padding: 0 12px;
      border-radius: 999px;
      background: #111;
      color: #fff;
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.02em;
    }

    .product-stage {
      padding: 18px;
      border-radius: 22px;
      background: linear-gradient(180deg, #f9f7f3 0%, #efe9df 100%);
      border: 1px solid var(--line);
    }

    .product-card {
      overflow: hidden;
      border-radius: 24px;
      background: #fff;
      box-shadow: 0 16px 34px rgba(17, 17, 17, 0.08);
    }

    .product-thumb {
      position: relative;
      aspect-ratio: 3 / 4;
      background: #ece8e1;
      overflow: hidden;
    }

    .product-thumb img,
    .product-thumb video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .product-badge-best {
      position: absolute;
      top: 16px;
      left: 16px;
      z-index: 2;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 32px;
      padding: 0 12px;
      border-radius: 999px;
      background: rgba(17, 17, 17, 0.92);
      color: #fff;
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.06em;
    }

    .product-badge-status {
      position: absolute;
      top: 16px;
      right: 16px;
      z-index: 2;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 32px;
      padding: 0 12px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 800;
    }

    .product-badge-status.active {
      background: var(--green-bg);
      color: var(--green);
    }

    .product-badge-status.soldout {
      background: var(--red-bg);
      color: var(--red);
    }

    .is-hidden {
      display: none !important;
    }

    .product-body {
      padding: 20px;
    }

    .product-category {
      color: var(--gold);
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      margin-bottom: 8px;
    }

    .product-name {
      font-size: 24px;
      font-weight: 800;
      line-height: 1.28;
      margin-bottom: 10px;
      word-break: keep-all;
    }

    .product-summary {
      color: #6f6a63;
      font-size: 14px;
      margin-bottom: 14px;
      word-break: break-word;
    }

    .product-price-row {
      display: flex;
      align-items: baseline;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 16px;
    }

    .product-price {
      font-size: 26px;
      font-weight: 900;
      letter-spacing: -0.03em;
    }

    .product-old-price {
      color: #9c958b;
      font-size: 15px;
      text-decoration: line-through;
      font-weight: 700;
    }

    .product-discount {
      color: var(--red);
      font-size: 14px;
      font-weight: 800;
    }

    .product-meta {
      display: grid;
      gap: 14px;
      margin-bottom: 16px;
    }

    .meta-block h3 {
      font-size: 13px;
      margin-bottom: 8px;
      color: #5d564d;
    }

    .chip-list {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .chip {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 34px;
      padding: 0 12px;
      border-radius: 999px;
      background: #f6f3ed;
      border: 1px solid rgba(17, 17, 17, 0.06);
      color: #111;
      font-size: 13px;
      font-weight: 700;
    }

    .chip.empty {
      color: #8e877d;
      background: #fbfaf8;
    }

    .product-desc {
      padding-top: 16px;
      border-top: 1px solid rgba(17, 17, 17, 0.08);
      color: #5d564d;
      font-size: 14px;
      line-height: 1.8;
      white-space: pre-line;
      word-break: break-word;
      min-height: 72px;
    }

    .thumb-strip {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
      margin-top: 16px;
    }

    .mini-card {
      overflow: hidden;
      border-radius: 16px;
      background: #fff;
      border: 1px solid rgba(17, 17, 17, 0.06);
    }

    .mini-card .mini-label {
      padding: 10px 12px;
      font-size: 12px;
      font-weight: 800;
      color: #5d564d;
      border-bottom: 1px solid rgba(17, 17, 17, 0.06);
      background: #faf8f4;
    }

    .mini-card .mini-image {
      aspect-ratio: 4 / 3;
      background: #ece8e1;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #8e877d;
      font-size: 12px;
      overflow: hidden;
    }

    .mini-card .mini-image img,
    .mini-card .mini-image video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .list-box {
      margin-top: 16px;
      padding: 16px;
      background: #fff;
      border-radius: 18px;
      border: 1px solid rgba(17, 17, 17, 0.06);
    }

    .list-box h3 {
      font-size: 14px;
      margin-bottom: 10px;
    }

    .empty-text {
      color: #8e877d;
      font-size: 13px;
    }

    @media (max-width: 1080px) {
      .admin-layout {
        grid-template-columns: 1fr;
      }

      .preview-sticky {
        position: static;
      }
    }

    @media (max-width: 760px) {
      .grid,
      .checkbox-list,
      .preview-image-list,
      .thumb-strip {
        grid-template-columns: 1fr;
      }

      .top-btn,
      .submit-btn {
        width: 100%;
      }

      .container {
        padding: 0 16px;
      }

      .card {
        padding: 20px;
      }

      .page-head h1 {
        font-size: 32px;
      }
    }
  </style>
</head>
<body>
  <%
    const safeMode = typeof mode !== 'undefined' ? mode : (product && product._id ? 'edit' : 'create');
    const safeProduct = typeof product !== 'undefined' && product ? product : null;
    const safeAllProducts = typeof allProducts !== 'undefined' && Array.isArray(allProducts) ? allProducts : [];
    const isEdit = safeMode === 'edit';

    const selectedAdditionalProducts = Array.isArray(safeProduct?.additionalProducts)
      ? safeProduct.additionalProducts.map((item) => String(item))
      : [];

    const optionGroup1 = safeProduct?.optionGroups?.[0] || { name: '', values: [] };
    const optionGroup2 = safeProduct?.optionGroups?.[1] || { name: '', values: [] };

    const optionGroup1Text = Array.isArray(optionGroup1.values)
      ? optionGroup1.values.map((item) => item.value).join('\n')
      : '';

    const optionGroup2Text = Array.isArray(optionGroup2.values)
      ? optionGroup2.values.map((item) => item.value).join('\n')
      : '';

    const numericPrice = Number(safeProduct?.price || 0);
    const numericOldPrice = Number(safeProduct?.oldPrice || 0);
    const discountPercent = numericOldPrice > numericPrice && numericOldPrice > 0
      ? Math.round(((numericOldPrice - numericPrice) / numericOldPrice) * 100)
      : 0;
  %>

  <main class="page">
    <div class="container">
      <div class="page-head">
        <small>Admin Product</small>
        <h1><%= isEdit ? '상품 수정' : '상품 등록' %></h1>
        <p>기존 UI 느낌 유지 + 새 상품 구조 반영 버전입니다.</p>
      </div>

      <div class="top-actions">
        <a href="/admin/products" class="top-btn top-btn-dark">상품 목록 가기</a>
        <button type="button" class="top-btn top-btn-light" onclick="history.back()">뒤로가기</button>
      </div>

      <div class="admin-layout">
        <div class="card">
          <h2 class="section-title">상품 정보 입력</h2>

          <form
            method="POST"
            enctype="multipart/form-data"
            action="<%= isEdit ? `/admin/products/${safeProduct._id}/edit` : '/admin/products/new' %>"
            id="productForm">

            <div class="section-block">
              <div class="section-label">기본 정보</div>

              <div class="grid">
                <div class="form-group">
                  <label for="name">상품명</label>
                  <input type="text" id="name" name="name" value="<%= safeProduct?.name || '' %>" required />
                </div>

                <div class="form-group">
                  <label for="category">카테고리</label>
                  <input type="text" id="category" name="category" value="<%= safeProduct?.category || '' %>" />
                </div>

                <div class="form-group full">
                  <label for="summary">한줄 요약</label>
                  <input type="text" id="summary" name="summary" value="<%= safeProduct?.summary || '' %>" placeholder="예: 여리핏 데일리 무드 셔츠" />
                </div>

                <div class="form-group full">
                  <label for="desc">상품 설명</label>
                  <textarea id="desc" name="desc"><%= safeProduct?.desc || '' %></textarea>
                </div>

                <div class="form-group">
                  <label for="tag">태그</label>
                  <input type="text" id="tag" name="tag" value="<%= safeProduct?.tag || '' %>" placeholder="NEW / BEST / MD추천" />
                </div>

                <div class="form-group">
                  <label for="shippingFeeText">배송비 문구</label>
                  <input type="text" id="shippingFeeText" name="shippingFeeText" value="<%= safeProduct?.shippingFeeText || '무료배송' %>" />
                </div>
              </div>
            </div>

            <div class="section-block">
              <div class="section-label">가격 / 혜택</div>

              <div class="grid">
                <div class="form-group">
                  <label for="price">판매가</label>
                  <input type="number" id="price" name="price" min="0" value="<%= safeProduct?.price ?? 0 %>" required />
                </div>

                <div class="form-group">
                  <label for="oldPrice">정가</label>
                  <input type="number" id="oldPrice" name="oldPrice" min="0" value="<%= safeProduct?.oldPrice ?? 0 %>" />
                </div>

                <div class="form-group">
                  <label for="reviewCount">리뷰 수</label>
                  <input type="number" id="reviewCount" name="reviewCount" min="0" value="<%= safeProduct?.reviewCount ?? 0 %>" />
                </div>

                <div class="form-group">
                  <label for="status">상태</label>
                  <select id="status" name="status">
                    <option value="onsale" <%= safeProduct?.status !== 'soldout' ? 'selected' : '' %>>판매중</option>
                    <option value="soldout" <%= safeProduct?.status === 'soldout' ? 'selected' : '' %>>품절</option>
                  </select>
                </div>

                <div class="form-group">
                  <label for="couponEnabled">쿠폰 노출 여부</label>
                  <select id="couponEnabled" name="couponEnabled">
                    <option value="false" <%= safeProduct?.couponDisplay?.enabled !== true ? 'selected' : '' %>>사용 안함</option>
                    <option value="true" <%= safeProduct?.couponDisplay?.enabled === true ? 'selected' : '' %>>사용</option>
                  </select>
                </div>

                <div class="form-group">
                  <label for="couponLabel">쿠폰 문구</label>
                  <input type="text" id="couponLabel" name="couponLabel" value="<%= safeProduct?.couponDisplay?.label || '' %>" placeholder="10% 할인쿠폰 다운로드" />
                </div>

                <div class="form-group full">
                  <label>BEST 상품 여부</label>
                  <div class="check-row">
                    <input
                      type="checkbox"
                      id="isBest"
                      name="isBest"
                      value="true"
                      <%= safeProduct?.isBest ? 'checked' : '' %> />
                    <label for="isBest" style="margin:0;">BEST 상품으로 노출</label>
                  </div>
                </div>
              </div>
            </div>

            <div class="section-block">
              <div class="section-label">대표 미디어</div>

              <div class="grid">
                <div class="form-group full">
                  <label for="imageFile">대표 이미지 업로드</label>
                  <input type="file" id="imageFile" name="imageFile" accept="image/png,image/jpeg,image/jpg,image/webp" />
                  <div class="help">홈 / 목록 / 상세 상단에서 메인으로 사용</div>

                  <% if (safeProduct?.image) { %>
                    <div class="preview-box">
                      현재 대표 이미지:
                      <span class="preview-value"><%= safeProduct.image %></span>
                    </div>
                  <% } %>
                </div>

                <div class="form-group full">
                  <label for="image">대표 이미지 경로 직접 입력</label>
                  <input type="text" id="image" name="image" value="<%= safeProduct?.image || '' %>" placeholder="/uploads/products/main.jpg" />
                </div>

                <div class="form-group full">
                  <label for="videoFile">상품 영상 업로드</label>
                  <input type="file" id="videoFile" name="videoFile" accept="video/mp4,video/webm,video/quicktime,video/x-m4v" />
                  <div class="help">짧은 영상 1개 권장</div>

                  <% if (safeProduct?.video) { %>
                    <div class="preview-box">
                      현재 상품 영상:
                      <span class="preview-value"><%= safeProduct.video %></span>
                    </div>
                  <% } %>
                </div>

                <div class="form-group full">
                  <label for="video">상품 영상 경로 직접 입력</label>
                  <input type="text" id="video" name="video" value="<%= safeProduct?.video || '' %>" placeholder="/uploads/products/sample.mp4" />
                </div>
              </div>
            </div>

            <div class="section-block">
              <div class="section-label">서브 이미지 / 상세 이미지</div>

              <div class="form-group">
                <label for="subImageFiles">서브 이미지 여러 장 업로드</label>
                <input type="file" id="subImageFiles" name="subImageFiles" accept="image/png,image/jpeg,image/jpg,image/webp" multiple />
                <div class="help">상세 상단 썸네일 / 슬라이드 영역</div>

                <% if (safeProduct?.subImages?.length) { %>
                  <div class="preview-image-list">
                    <% safeProduct.subImages.forEach((img) => { %>
                      <div class="preview-item">
                        <img src="<%= img %>" alt="서브 이미지" />
                        <div class="cap"><%= img %></div>
                      </div>
                      <input type="hidden" name="existingSubImages" value="<%= img %>" />
                    <% }) %>
                  </div>
                <% } %>
              </div>

              <div class="form-group">
                <label for="detailImageFiles">상세 이미지 여러 장 업로드</label>
                <input type="file" id="detailImageFiles" name="detailImageFiles" accept="image/png,image/jpeg,image/jpg,image/webp" multiple />
                <div class="help">상세 하단 긴 설명 영역</div>

                <% if (safeProduct?.detailImages?.length) { %>
                  <div class="preview-image-list">
                    <% safeProduct.detailImages.forEach((img) => { %>
                      <div class="preview-item">
                        <img src="<%= img %>" alt="상세 이미지" />
                        <div class="cap"><%= img %></div>
                      </div>
                      <input type="hidden" name="existingDetailImages" value="<%= img %>" />
                    <% }) %>
                  </div>
                <% } %>
              </div>
            </div>

            <div class="section-block">
              <div class="section-label">옵션 드롭다운</div>

              <div class="grid">
                <div class="form-group">
                  <label for="optionGroup1Name">옵션 그룹 1 이름</label>
                  <input type="text" id="optionGroup1Name" name="optionGroup1Name" value="<%= optionGroup1.name || '' %>" placeholder="예: 컬러" />
                </div>

                <div class="form-group">
                  <label for="optionGroup2Name">옵션 그룹 2 이름</label>
                  <input type="text" id="optionGroup2Name" name="optionGroup2Name" value="<%= optionGroup2.name || '' %>" placeholder="예: 사이즈" />
                </div>

                <div class="form-group">
                  <label for="optionGroup1Values">옵션 그룹 1 값</label>
                  <textarea id="optionGroup1Values" name="optionGroup1Values" placeholder="한 줄에 하나씩 입력&#10;예: 크림&#10;블랙&#10;핑크"><%= optionGroup1Text %></textarea>
                </div>

                <div class="form-group">
                  <label for="optionGroup2Values">옵션 그룹 2 값</label>
                  <textarea id="optionGroup2Values" name="optionGroup2Values" placeholder="한 줄에 하나씩 입력&#10;예: S&#10;M&#10;L"><%= optionGroup2Text %></textarea>
                </div>
              </div>
            </div>

            <div class="section-block">
              <div class="section-label">추가상품 연결</div>

              <div class="form-group">
                <label>추가상품 선택</label>
                <div class="help">상세페이지에서 함께 보여줄 상품들</div>

                <div class="checkbox-list">
                  <% safeAllProducts.forEach((item) => { %>
                    <% const checked = selectedAdditionalProducts.includes(String(item._id)); %>
                    <label class="checkbox-card">
                      <input
                        type="checkbox"
                        name="additionalProducts"
                        value="<%= item._id %>"
                        <%= checked ? 'checked' : '' %> />

                      <% if (item.image) { %>
                        <img src="<%= item.image %>" alt="<%= item.name %>" />
                      <% } else { %>
                        <img src="https://dummyimage.com/100x100/e5e5e5/999999&text=NO" alt="이미지 없음" />
                      <% } %>

                      <div class="checkbox-card-text">
                        <div class="checkbox-card-title"><%= item.name %></div>
                        <div class="checkbox-card-price">₩<%= Number(item.price || 0).toLocaleString() %></div>
                      </div>
                    </label>
                  <% }) %>
                </div>
              </div>
            </div>

            <div class="section-block">
              <div class="section-label">가이드</div>

              <div class="form-group">
                <label for="washImageFile">세탁가이드 이미지 업로드</label>
                <input type="file" id="washImageFile" name="washImageFile" accept="image/png,image/jpeg,image/jpg,image/webp" />
                <% if (safeProduct?.guide?.washImage) { %>
                  <input type="hidden" name="existingWashImage" value="<%= safeProduct.guide.washImage %>" />
                  <div class="preview-box">
                    현재 세탁가이드 이미지:
                    <span class="preview-value"><%= safeProduct.guide.washImage %></span>
                  </div>
                <% } %>
              </div>

              <div class="form-group">
                <label for="sizeGuideImageFile">사이즈 측정방법 이미지 업로드</label>
                <input type="file" id="sizeGuideImageFile" name="sizeGuideImageFile" accept="image/png,image/jpeg,image/jpg,image/webp" />
                <% if (safeProduct?.guide?.sizeGuideImage) { %>
                  <input type="hidden" name="existingSizeGuideImage" value="<%= safeProduct.guide.sizeGuideImage %>" />
                  <div class="preview-box">
                    현재 사이즈가이드 이미지:
                    <span class="preview-value"><%= safeProduct.guide.sizeGuideImage %></span>
                  </div>
                <% } %>
              </div>

              <div class="form-group">
                <label for="copyrightNotice">이미지 저작권 안내</label>
                <textarea id="copyrightNotice" name="copyrightNotice"><%= safeProduct?.guide?.copyrightNotice || '' %></textarea>
              </div>

              <div class="form-group">
                <label for="shippingExchangeReturn">배송 / 교환 / 반품 안내</label>
                <textarea id="shippingExchangeReturn" name="shippingExchangeReturn"><%= safeProduct?.guide?.shippingExchangeReturn || '' %></textarea>
              </div>
            </div>

            <div class="actions">
              <button type="submit" class="submit-btn submit-btn-dark">
                <%= isEdit ? '상품 수정 완료' : '상품 등록하기' %>
              </button>
              <a href="/admin/products" class="submit-btn submit-btn-light">취소하고 목록으로</a>
            </div>
          </form>
        </div>

        <div class="preview-sticky">
          <div class="card">
            <div class="live-title">
              <h2>실시간 상품 미리보기</h2>
              <span class="live-chip">LIVE</span>
            </div>

            <div class="product-stage">
              <div class="product-card">
                <div class="product-thumb">
                  <img
                    id="liveMainImage"
                    src="<%= safeProduct?.image || 'https://images.unsplash.com/photo-1441986300917-64674bd600d8?auto=format&fit=crop&w=1200&q=80' %>"
                    alt="상품 대표 이미지" />

                  <video
                    id="liveVideo"
                    class="<%= safeProduct?.video ? '' : 'is-hidden' %>"
                    src="<%= safeProduct?.video || '' %>"
                    muted
                    loop
                    playsinline
                    controls
                    style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; background:#000;">
                  </video>

                  <div class="product-badge-best <%= safeProduct?.isBest ? '' : 'is-hidden' %>" id="liveBestBadge">BEST</div>

                  <div
                    class="product-badge-status <%= safeProduct?.status === 'soldout' ? 'soldout' : 'active' %>"
                    id="liveStatusBadge">
                    <%= safeProduct?.status === 'soldout' ? '품절' : '판매중' %>
                  </div>
                </div>

                <div class="product-body">
                  <div class="product-category" id="liveCategory"><%= safeProduct?.category || 'CATEGORY' %></div>
                  <div class="product-name" id="liveName"><%= safeProduct?.name || '상품명이 여기에 표시됩니다.' %></div>
                  <div class="product-summary" id="liveSummary"><%= safeProduct?.summary || '한줄 요약이 여기에 표시됩니다.' %></div>

                  <div class="product-price-row">
                    <div class="product-price" id="livePrice"><%= Number(safeProduct?.price || 0).toLocaleString('ko-KR') %>원</div>

                    <div class="product-old-price <%= numericOldPrice > 0 ? '' : 'is-hidden' %>" id="liveOldPrice">
                      <%= numericOldPrice > 0 ? Number(numericOldPrice).toLocaleString('ko-KR') + '원' : '' %>
                    </div>

                    <div class="product-discount <%= discountPercent > 0 ? '' : 'is-hidden' %>" id="liveDiscount">
                      <%= discountPercent > 0 ? discountPercent + '% OFF' : '' %>
                    </div>
                  </div>

                  <div class="product-meta">
                    <div class="meta-block">
                      <h3>옵션 1</h3>
                      <div class="chip-list" id="liveOptionGroup1">
                        <% if (optionGroup1Text) { %>
                          <% optionGroup1Text.split('\n').filter(Boolean).forEach((item) => { %>
                            <span class="chip"><%= item %></span>
                          <% }) %>
                        <% } else { %>
                          <span class="chip empty">선택 없음</span>
                        <% } %>
                      </div>
                    </div>

                    <div class="meta-block">
                      <h3>옵션 2</h3>
                      <div class="chip-list" id="liveOptionGroup2">
                        <% if (optionGroup2Text) { %>
                          <% optionGroup2Text.split('\n').filter(Boolean).forEach((item) => { %>
                            <span class="chip"><%= item %></span>
                          <% }) %>
                        <% } else { %>
                          <span class="chip empty">선택 없음</span>
                        <% } %>
                      </div>
                    </div>

                    <div class="meta-block">
                      <h3>혜택 / 태그</h3>
                      <div class="chip-list">
                        <span class="chip" id="liveShipping"><%= safeProduct?.shippingFeeText || '무료배송' %></span>

                        <span class="chip <%= safeProduct?.couponDisplay?.enabled ? '' : 'empty' %>" id="liveCoupon">
                          <%= safeProduct?.couponDisplay?.enabled ? (safeProduct?.couponDisplay?.label || '쿠폰 사용') : '쿠폰 없음' %>
                        </span>

                        <span class="chip <%= safeProduct?.tag ? '' : 'empty' %>" id="liveTag">
                          <%= safeProduct?.tag || '태그 없음' %>
                        </span>
                      </div>
                    </div>
                  </div>

                  <div class="product-desc" id="liveDescription"><%= safeProduct?.desc || '상품 설명이 여기에 표시됩니다.' %></div>
                </div>
              </div>

              <div class="thumb-strip">
                <div class="mini-card">
                  <div class="mini-label">대표 이미지</div>
                  <div class="mini-image">
                    <img
                      id="liveMirrorMainImage"
                      src="<%= safeProduct?.image || 'https://images.unsplash.com/photo-1441986300917-64674bd600d8?auto=format&fit=crop&w=1200&q=80' %>"
                      alt="대표 이미지 미리보기" />
                  </div>
                </div>

                <div class="mini-card">
                  <div class="mini-label">상품 영상</div>
                  <div class="mini-image">
                    <% if (safeProduct?.video) { %>
                      <video src="<%= safeProduct.video %>" muted loop playsinline controls></video>
                    <% } else { %>
                      <span>영상 없음</span>
                    <% } %>
                  </div>
                </div>

                <div class="mini-card">
                  <div class="mini-label">서브 이미지</div>
                  <div class="mini-image" id="liveSubImageFirst">
                    <% if (safeProduct?.subImages?.[0]) { %>
                      <img src="<%= safeProduct.subImages[0] %>" alt="서브 이미지 첫장" />
                    <% } else { %>
                      <span>없음</span>
                    <% } %>
                  </div>
                </div>
              </div>

              <div class="list-box">
                <h3>상세 이미지 미리보기</h3>
                <div class="thumb-strip" id="liveDetailImages">
                  <% if (safeProduct?.detailImages?.length) { %>
                    <% safeProduct.detailImages.slice(0, 6).forEach((img, index) => { %>
                      <div class="mini-card">
                        <div class="mini-label">상세 이미지 <%= index + 1 %></div>
                        <div class="mini-image">
                          <img src="<%= img %>" alt="상세 이미지 <%= index + 1 %>" />
                        </div>
                      </div>
                    <% }) %>
                  <% } else { %>
                    <div class="empty-text" id="liveDetailImagesEmpty">아직 상세 이미지가 없습니다.</div>
                  <% } %>
                </div>
              </div>

              <div class="list-box">
                <h3>추가상품 연결 수</h3>
                <div class="empty-text" id="liveAdditionalCount"><%= selectedAdditionalProducts.length %>개 선택됨</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script>
    (function () {
      const nameInput = document.getElementById('name');
      const categoryInput = document.getElementById('category');
      const summaryInput = document.getElementById('summary');
      const descInput = document.getElementById('desc');
      const priceInput = document.getElementById('price');
      const oldPriceInput = document.getElementById('oldPrice');
      const tagInput = document.getElementById('tag');
      const shippingInput = document.getElementById('shippingFeeText');
      const couponEnabledInput = document.getElementById('couponEnabled');
      const couponLabelInput = document.getElementById('couponLabel');
      const statusInput = document.getElementById('status');
      const bestInput = document.getElementById('isBest');

      const imageFileInput = document.getElementById('imageFile');
      const imagePathInput = document.getElementById('image');
      const videoFileInput = document.getElementById('videoFile');
      const videoPathInput = document.getElementById('video');
      const subImageFilesInput = document.getElementById('subImageFiles');
      const detailImageFilesInput = document.getElementById('detailImageFiles');

      const optionGroup1NameInput = document.getElementById('optionGroup1Name');
      const optionGroup1ValuesInput = document.getElementById('optionGroup1Values');
      const optionGroup2NameInput = document.getElementById('optionGroup2Name');
      const optionGroup2ValuesInput = document.getElementById('optionGroup2Values');

      const liveName = document.getElementById('liveName');
      const liveCategory = document.getElementById('liveCategory');
      const liveSummary = document.getElementById('liveSummary');
      const livePrice = document.getElementById('livePrice');
      const liveOldPrice = document.getElementById('liveOldPrice');
      const liveDiscount = document.getElementById('liveDiscount');
      const liveDescription = document.getElementById('liveDescription');
      const liveBestBadge = document.getElementById('liveBestBadge');
      const liveStatusBadge = document.getElementById('liveStatusBadge');
      const liveTag = document.getElementById('liveTag');
      const liveShipping = document.getElementById('liveShipping');
      const liveCoupon = document.getElementById('liveCoupon');

      const liveMainImage = document.getElementById('liveMainImage');
      const liveMirrorMainImage = document.getElementById('liveMirrorMainImage');
      const liveVideo = document.getElementById('liveVideo');
      const liveSubImageFirst = document.getElementById('liveSubImageFirst');
      const liveDetailImages = document.getElementById('liveDetailImages');
      const liveAdditionalCount = document.getElementById('liveAdditionalCount');

      const liveOptionGroup1 = document.getElementById('liveOptionGroup1');
      const liveOptionGroup2 = document.getElementById('liveOptionGroup2');

      function formatWon(value) {
        return Number(value || 0).toLocaleString('ko-KR') + '원';
      }

      function buildChips(values) {
        const list = (values || []).filter(Boolean);
        if (!list.length) {
          return '<span class="chip empty">선택 없음</span>';
        }
        return list.map((value) => '<span class="chip">' + value + '</span>').join('');
      }

      function splitLines(value) {
        return String(value || '')
          .split('\n')
          .map((item) => item.trim())
          .filter(Boolean);
      }

      function syncBasicPreview() {
        const priceValue = Number(priceInput.value || 0);
        const oldPriceValue = Number(oldPriceInput.value || 0);

        liveName.textContent = nameInput.value.trim() || '상품명이 여기에 표시됩니다.';
        liveCategory.textContent = categoryInput.value.trim() || 'CATEGORY';
        liveSummary.textContent = summaryInput.value.trim() || '한줄 요약이 여기에 표시됩니다.';
        liveDescription.textContent = descInput.value.trim() || '상품 설명이 여기에 표시됩니다.';
        livePrice.textContent = formatWon(priceValue);

        if (oldPriceValue > 0) {
          liveOldPrice.classList.remove('is-hidden');
          liveOldPrice.textContent = formatWon(oldPriceValue);
        } else {
          liveOldPrice.classList.add('is-hidden');
          liveOldPrice.textContent = '';
        }

        if (oldPriceValue > priceValue && oldPriceValue > 0) {
          const discount = Math.round(((oldPriceValue - priceValue) / oldPriceValue) * 100);
          liveDiscount.classList.remove('is-hidden');
          liveDiscount.textContent = discount + '% OFF';
        } else {
          liveDiscount.classList.add('is-hidden');
          liveDiscount.textContent = '';
        }

        const tagValue = tagInput.value.trim();
        liveTag.textContent = tagValue || '태그 없음';
        liveTag.classList.toggle('empty', !tagValue);

        liveShipping.textContent = shippingInput.value.trim() || '무료배송';

        if (couponEnabledInput.value === 'true') {
          liveCoupon.textContent = couponLabelInput.value.trim() || '쿠폰 사용';
          liveCoupon.classList.remove('empty');
        } else {
          liveCoupon.textContent = '쿠폰 없음';
          liveCoupon.classList.add('empty');
        }

        liveBestBadge.classList.toggle('is-hidden', !bestInput.checked);

        if (statusInput.value === 'soldout') {
          liveStatusBadge.textContent = '품절';
          liveStatusBadge.classList.remove('active');
          liveStatusBadge.classList.add('soldout');
        } else {
          liveStatusBadge.textContent = '판매중';
          liveStatusBadge.classList.remove('soldout');
          liveStatusBadge.classList.add('active');
        }
      }

      function syncOptionPreview() {
        liveOptionGroup1.previousElementSibling.textContent = optionGroup1NameInput.value.trim() || '옵션 1';
        liveOptionGroup2.previousElementSibling.textContent = optionGroup2NameInput.value.trim() || '옵션 2';
        liveOptionGroup1.innerHTML = buildChips(splitLines(optionGroup1ValuesInput.value));
        liveOptionGroup2.innerHTML = buildChips(splitLines(optionGroup2ValuesInput.value));
      }

      function readImage(file, callback) {
        if (!file) return;
        const reader = new FileReader();
        reader.onload = function (event) {
          callback(event.target.result);
        };
        reader.readAsDataURL(file);
      }

      function syncMainImagePreview() {
        const file = imageFileInput.files && imageFileInput.files[0];
        if (file) {
          readImage(file, function (src) {
            liveMainImage.src = src;
            liveMirrorMainImage.src = src;
          });
          return;
        }

        const path = imagePathInput.value.trim();
        if (path) {
          liveMainImage.src = path;
          liveMirrorMainImage.src = path;
        }
      }

      function syncVideoPreview() {
        const file = videoFileInput.files && videoFileInput.files[0];
        if (file) {
          const url = URL.createObjectURL(file);
          liveVideo.src = url;
          liveVideo.classList.remove('is-hidden');
          return;
        }

        const path = videoPathInput.value.trim();
        if (path) {
          liveVideo.src = path;
          liveVideo.classList.remove('is-hidden');
        } else {
          liveVideo.src = '';
          liveVideo.classList.add('is-hidden');
        }
      }

      function syncSubImagePreview() {
        const files = subImageFilesInput.files ? Array.from(subImageFilesInput.files) : [];
        if (!files.length) return;

        const first = files[0];
        readImage(first, function (src) {
          liveSubImageFirst.innerHTML = '<img src="' + src + '" alt="서브 이미지 첫장">';
        });
      }

      function syncDetailImagesPreview() {
        const files = detailImageFilesInput.files ? Array.from(detailImageFilesInput.files) : [];
        if (!files.length) return;

        liveDetailImages.innerHTML = '';

        files.slice(0, 6).forEach(function (file, index) {
          const reader = new FileReader();
          reader.onload = function (event) {
            const html = [
              '<div class="mini-card">',
              '<div class="mini-label">상세 이미지 ' + (index + 1) + '</div>',
              '<div class="mini-image"><img src="' + event.target.result + '" alt="상세 이미지 ' + (index + 1) + '"></div>',
              '</div>'
            ].join('');
            liveDetailImages.insertAdjacentHTML('beforeend', html);
          };
          reader.readAsDataURL(file);
        });
      }

      function syncAdditionalCount() {
        const checked = document.querySelectorAll('input[name="additionalProducts"]:checked').length;
        liveAdditionalCount.textContent = checked + '개 선택됨';
      }

      [
        nameInput,
        categoryInput,
        summaryInput,
        descInput,
        priceInput,
        oldPriceInput,
        tagInput,
        shippingInput,
        couponEnabledInput,
        couponLabelInput,
        statusInput,
        bestInput
      ].forEach(function (el) {
        if (!el) return;
        el.addEventListener('input', syncBasicPreview);
        el.addEventListener('change', syncBasicPreview);
      });

      [optionGroup1NameInput, optionGroup1ValuesInput, optionGroup2NameInput, optionGroup2ValuesInput].forEach(function (el) {
        if (!el) return;
        el.addEventListener('input', syncOptionPreview);
        el.addEventListener('change', syncOptionPreview);
      });

      imageFileInput.addEventListener('change', syncMainImagePreview);
      imagePathInput.addEventListener('input', syncMainImagePreview);
      videoFileInput.addEventListener('change', syncVideoPreview);
      videoPathInput.addEventListener('input', syncVideoPreview);
      subImageFilesInput.addEventListener('change', syncSubImagePreview);
      detailImageFilesInput.addEventListener('change', syncDetailImagesPreview);

      document.querySelectorAll('input[name="additionalProducts"]').forEach(function (checkbox) {
        checkbox.addEventListener('change', syncAdditionalCount);
      });

      syncBasicPreview();
      syncOptionPreview();
      syncVideoPreview();
      syncAdditionalCount();
    })();
  </script>
</body>
</html>
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= product ? '상품 수정' : '상품 등록' %> | DAMORE ADMIN</title>
  <style>
    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #f7f7f7;
      color: #111;
      padding: 30px 20px 60px;
    }

    .wrap {
      max-width: 1180px;
      margin: 0 auto;
    }

    h1 {
      margin: 0 0 24px;
      font-size: 32px;
    }

    .top-actions {
      display: flex;
      gap: 10px;
      margin-bottom: 24px;
      flex-wrap: wrap;
    }

    .top-actions a {
      border: 1px solid #ddd;
      background: #fff;
      color: #111;
      padding: 10px 14px;
      border-radius: 10px;
      text-decoration: none;
      font-size: 14px;
    }

    .form-grid {
      display: grid;
      grid-template-columns: 1.15fr 0.85fr;
      gap: 24px;
      align-items: start;
    }

    .card {
      background: #fff;
      border: 1px solid #ececec;
      border-radius: 16px;
      padding: 22px;
      box-shadow: 0 6px 20px rgba(0,0,0,0.04);
      margin-bottom: 20px;
    }

    .card h2 {
      margin: 0 0 18px;
      font-size: 20px;
    }

    .field {
      margin-bottom: 16px;
    }

    .field label {
      display: block;
      font-size: 14px;
      font-weight: 700;
      margin-bottom: 8px;
    }

    .field input[type="text"],
    .field input[type="number"],
    .field textarea,
    .field select {
      width: 100%;
      padding: 12px 14px;
      border: 1px solid #ddd;
      border-radius: 10px;
      font-size: 14px;
      outline: none;
      background: #fff;
    }

    .field textarea {
      min-height: 100px;
      resize: vertical;
    }

    .row-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }

    .row-3 {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 14px;
    }

    .hint {
      font-size: 12px;
      color: #777;
      margin-top: 6px;
      line-height: 1.5;
    }

    .upload-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 18px;
    }

    .upload-box {
      position: relative;
      border: 1.5px dashed #cfcfcf;
      background: #fafafa;
      border-radius: 18px;
      min-height: 240px;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 20px;
      cursor: pointer;
      transition: 0.2s ease;
      overflow: hidden;
    }

    .upload-box:hover {
      border-color: #999;
      background: #f3f3f3;
    }

    .upload-box.dragover {
      border-color: #111;
      background: #efefef;
    }

    .upload-box input[type="file"] {
      display: none;
    }

    .upload-placeholder {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 14px;
      color: #555;
      pointer-events: none;
    }

    .upload-placeholder svg {
      width: 96px;
      height: 96px;
      stroke: #111;
      stroke-width: 1.8;
      fill: none;
    }

    .upload-title {
      font-size: 18px;
      font-weight: 700;
      color: #111;
    }

    .upload-sub {
      font-size: 13px;
      color: #777;
      line-height: 1.5;
    }

    .preview-single {
      width: 100%;
      height: 100%;
      display: none;
      position: absolute;
      inset: 0;
      background: #fff;
    }

    .preview-single img,
    .preview-single video {
      width: 100%;
      height: 100%;
      object-fit: contain;
      background: #f5f5f5;
    }

    .preview-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(115px, 1fr));
      gap: 12px;
      margin-top: 14px;
    }

    .preview-item {
      position: relative;
      background: #f3f3f3;
      border-radius: 12px;
      overflow: hidden;
      aspect-ratio: 1 / 1;
      border: 1px solid #e3e3e3;
    }

    .preview-item img,
    .preview-item video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .preview-badge {
      position: absolute;
      top: 6px;
      left: 6px;
      background: rgba(17,17,17,0.8);
      color: #fff;
      font-size: 11px;
      padding: 4px 6px;
      border-radius: 999px;
    }

    .quick-box {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-top: 8px;
    }

    .quick-btn {
      border: 1px solid #ddd;
      background: #fff;
      padding: 7px 10px;
      border-radius: 999px;
      font-size: 12px;
      cursor: pointer;
    }

    .submit-wrap {
      display: flex;
      gap: 12px;
      margin-top: 10px;
      flex-wrap: wrap;
    }

    .submit-wrap button,
    .submit-wrap a {
      border: 0;
      background: #111;
      color: #fff;
      padding: 13px 18px;
      border-radius: 10px;
      cursor: pointer;
      font-size: 14px;
      text-decoration: none;
    }

    .submit-wrap .sub-btn {
      background: #666;
    }

    .sticky-card {
      position: sticky;
      top: 20px;
    }

    .mini-preview-box {
      background: #fafafa;
      border: 1px solid #eee;
      border-radius: 14px;
      padding: 16px;
    }

    .mini-preview-image {
      width: 100%;
      aspect-ratio: 4 / 5;
      background: #efefef;
      border-radius: 12px;
      overflow: hidden;
      margin-bottom: 14px;
    }

    .mini-preview-image img,
    .mini-preview-image video {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .mini-preview-name {
      font-size: 18px;
      font-weight: 700;
      margin-bottom: 8px;
    }

    .mini-preview-price {
      font-size: 20px;
      font-weight: 800;
      margin-bottom: 8px;
    }

    .mini-preview-desc {
      color: #666;
      line-height: 1.6;
      font-size: 14px;
      word-break: break-word;
    }

    .existing-list {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 10px;
    }

    .existing-chip {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 10px;
      border: 1px solid #ddd;
      border-radius: 10px;
      background: #fafafa;
      font-size: 12px;
    }

    @media (max-width: 980px) {
      .form-grid {
        grid-template-columns: 1fr;
      }

      .sticky-card {
        position: static;
      }

      .row-2,
      .row-3 {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <%
    const safeProduct = product || {};
    const safeGuide = safeProduct.guide || {};
    const safeWearInfo = safeGuide.wearInfo || {};
    const safeOptionGroups = Array.isArray(safeProduct.optionGroups) ? safeProduct.optionGroups : [];
    const safeColorGroup = safeOptionGroups[0] || null;
    const safeSizeGroup = safeOptionGroups[1] || null;
    const safeCategories = Array.isArray(categories) ? categories : [];

    const categoryMap = {};
    safeCategories.forEach((item) => {
      const key = String(item && item.name ? item.name : '').trim().toLowerCase();
      if (!key) return;

      categoryMap[key] = {
        name: key,
        label: String(item && item.name ? item.name : '').trim(),
        subCategories: Array.isArray(item && item.subCategories) ? item.subCategories : []
      };
    });
  %>

  <div class="wrap">
    <h1><%= product ? '상품 수정' : '상품 등록' %></h1>

    <div class="top-actions">
      <a href="/admin/dashboard">대시보드</a>
      <a href="/admin/products">상품 목록</a>
    </div>

    <form action="<%= product ? '/admin/products/' + product._id + '/edit' : '/admin/products/new' %>" method="POST" enctype="multipart/form-data">
      <div class="form-grid">
        <div>
          <div class="card">
            <h2>기본 정보</h2>

            <div class="field">
              <label for="name">상품명</label>
              <input type="text" id="name" name="name" value="<%= safeProduct.name || '' %>" required />
            </div>

            <div class="field">
              <label for="summary">한줄 설명</label>
              <input type="text" id="summary" name="summary" value="<%= safeProduct.summary || '' %>" />
            </div>

            <div class="field">
              <label for="desc">상세 설명</label>
              <textarea id="desc" name="desc"><%= safeProduct.desc || '' %></textarea>
            </div>

            <div class="row-3">
              <div class="field">
                <label for="price">판매가</label>
                <input type="number" id="price" name="price" min="0" value="<%= safeProduct.price || 0 %>" required />
              </div>

              <div class="field">
                <label for="oldPrice">소비자가</label>
                <input type="number" id="oldPrice" name="oldPrice" min="0" value="<%= safeProduct.oldPrice || 0 %>" />
              </div>

              <div class="field">
                <label for="stock">재고</label>
                <input type="number" id="stock" name="stock" min="0" value="<%= safeProduct.stock || 0 %>" />
              </div>
            </div>

            <div class="row-3">
              <div class="field">
                <label for="category">카테고리</label>
                <select id="category" name="category">
                  <option value="">카테고리 선택</option>
                  <% safeCategories.forEach((item) => { %>
                    <% const value = String(item && item.name ? item.name : '').trim().toLowerCase(); %>
                    <option value="<%= value %>" <%= String(safeProduct.category || '').trim().toLowerCase() === value ? 'selected' : '' %>>
                      <%= item && item.name ? item.name : '' %>
                    </option>
                  <% }) %>
                </select>
              </div>

              <div class="field">
                <label for="subCategory">서브카테고리</label>
                <select id="subCategory" name="subCategory">
                  <option value="">서브카테고리 선택</option>
                </select>
              </div>

              <div class="field">
                <label for="tag">태그</label>
                <input type="text" id="tag" name="tag" value="<%= safeProduct.tag || '' %>" />
              </div>
            </div>

            <div class="row-3">
              <div class="field">
                <label for="status">상태</label>
                <select id="status" name="status">
                  <option value="active" <%= safeProduct.status === 'active' ? 'selected' : '' %>>노출</option>
                  <option value="onsale" <%= safeProduct.status === 'onsale' ? 'selected' : '' %>>세일</option>
                  <option value="soldout" <%= safeProduct.status === 'soldout' ? 'selected' : '' %>>품절</option>
                  <option value="hidden" <%= safeProduct.status === 'hidden' ? 'selected' : '' %>>숨김</option>
                </select>
              </div>

              <div class="field">
                <label for="shippingFeeText">배송 문구</label>
                <input type="text" id="shippingFeeText" name="shippingFeeText" value="<%= safeProduct.shippingFeeText || '무료배송' %>" />
              </div>

              <div class="field">
                <label for="isBest">베스트 상품</label>
                <select id="isBest" name="isBest">
                  <option value="false" <%= !safeProduct.isBest ? 'selected' : '' %>>아니오</option>
                  <option value="true" <%= safeProduct.isBest ? 'selected' : '' %>>예</option>
                </select>
              </div>
            </div>
          </div>

          <div class="card">
            <h2>업로드</h2>

            <div class="upload-grid">
              <div>
                <label style="display:block;font-weight:700;margin-bottom:10px;">대표 이미지</label>

                <label class="upload-box" id="mainUploadBox">
                  <input type="file" id="mainImageInput" name="imageFile" accept="image/*,video/*" />
                  <div class="upload-placeholder" id="mainPlaceholder">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M6 19h12a4 4 0 0 0 .5-8A6.5 6.5 0 0 0 6.2 8.3 4.5 4.5 0 0 0 6 19Z"></path>
                      <path d="M12 16V9"></path>
                      <path d="m9 12 3-3 3 3"></path>
                    </svg>
                    <div class="upload-title">대표 이미지 / 영상 업로드</div>
                    <div class="upload-sub">클릭하거나 파일을 드래그하세요<br>이미지 또는 영상 1개</div>
                  </div>
                  <div class="preview-single" id="mainPreview"></div>
                </label>

                <% if (safeProduct.image || safeProduct.video) { %>
                  <div class="existing-list">
                    <% if (safeProduct.image) { %>
                      <span class="existing-chip">기존 대표 이미지 유지</span>
                    <% } %>
                    <% if (safeProduct.video) { %>
                      <span class="existing-chip">기존 대표 영상 유지</span>
                    <% } %>
                  </div>
                <% } %>
              </div>

              <div>
                <label style="display:block;font-weight:700;margin-bottom:10px;">추가 이미지</label>

                <label class="upload-box" id="subUploadBox" style="min-height:180px;">
                  <input type="file" id="subImagesInput" name="subImageFiles" accept="image/*" multiple />
                  <div class="upload-placeholder">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M6 19h12a4 4 0 0 0 .5-8A6.5 6.5 0 0 0 6.2 8.3 4.5 4.5 0 0 0 6 19Z"></path>
                      <path d="M12 16V9"></path>
                      <path d="m9 12 3-3 3 3"></path>
                    </svg>
                    <div class="upload-title">추가 이미지 여러 장 업로드</div>
                    <div class="upload-sub">상세페이지 상단 썸네일용</div>
                  </div>
                </label>

                <div class="preview-grid" id="subPreviewGrid"></div>

                <% (safeProduct.subImages || []).forEach((img) => { %>
                  <input type="hidden" name="existingSubImages" value="<%= img %>">
                <% }) %>
              </div>

              <div>
                <label style="display:block;font-weight:700;margin-bottom:10px;">상세페이지 이미지</label>

                <label class="upload-box" id="detailUploadBox" style="min-height:180px;">
                  <input type="file" id="detailImagesInput" name="detailImageFiles" accept="image/*,video/*" multiple />
                  <div class="upload-placeholder">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M6 19h12a4 4 0 0 0 .5-8A6.5 6.5 0 0 0 6.2 8.3 4.5 4.5 0 0 0 6 19Z"></path>
                      <path d="M12 16V9"></path>
                      <path d="m9 12 3-3 3 3"></path>
                    </svg>
                    <div class="upload-title">상세 이미지 / 영상 업로드</div>
                    <div class="upload-sub">상세페이지 본문에 들어갈 자료</div>
                  </div>
                </label>

                <div class="preview-grid" id="detailPreviewGrid"></div>

                <% (safeProduct.detailImages || []).forEach((img) => { %>
                  <input type="hidden" name="existingDetailImages" value="<%= img %>">
                <% }) %>
              </div>

              <div class="field">
                <label for="video">동영상 URL(선택)</label>
                <input type="text" id="video" name="video" value="<%= safeProduct.video || '' %>" placeholder="https://..." />
                <div class="hint">직접 파일 업로드 외에 URL 방식 영상도 가능</div>
              </div>
            </div>
          </div>

          <div class="card">
            <h2>옵션 간편 입력</h2>

            <div class="field">
              <label for="colorsInput">색상</label>
              <input
                type="text"
                id="colorsInput"
                name="colorsInput"
                placeholder="예: 검정색, 하얀색, 베이지"
                value="<%= safeColorGroup && Array.isArray(safeColorGroup.values) ? safeColorGroup.values.map(v => v.value).join(', ') : '' %>" />
              <div class="quick-box">
                <button type="button" class="quick-btn" onclick="appendText('colorsInput','검정색')">검정색</button>
                <button type="button" class="quick-btn" onclick="appendText('colorsInput','하얀색')">하얀색</button>
                <button type="button" class="quick-btn" onclick="appendText('colorsInput','회색')">회색</button>
                <button type="button" class="quick-btn" onclick="appendText('colorsInput','베이지')">베이지</button>
                <button type="button" class="quick-btn" onclick="appendText('colorsInput','네이비')">네이비</button>
              </div>
            </div>

            <div class="field">
              <label for="sizesInput">사이즈</label>
              <input
                type="text"
                id="sizesInput"
                name="sizesInput"
                placeholder="예: S, M, L, XL"
                value="<%= safeSizeGroup && Array.isArray(safeSizeGroup.values) ? safeSizeGroup.values.map(v => v.value).join(', ') : '' %>" />
              <div class="quick-box">
                <button type="button" class="quick-btn" onclick="appendText('sizesInput','S')">S</button>
                <button type="button" class="quick-btn" onclick="appendText('sizesInput','M')">M</button>
                <button type="button" class="quick-btn" onclick="appendText('sizesInput','L')">L</button>
                <button type="button" class="quick-btn" onclick="appendText('sizesInput','XL')">XL</button>
                <button type="button" class="quick-btn" onclick="appendText('sizesInput','FREE')">FREE</button>
              </div>
            </div>

            <div class="field">
              <label for="modelInfo">모델 정보</label>
              <input type="text" id="modelInfo" name="modelInfo" value="<%= safeProduct.modelInfo || '' %>" placeholder="예: 신혜성 178cm / 70kg (상의 100~105 / 하의 30~31)" />
            </div>
          </div>

          <div class="card">
            <h2>착용 정보</h2>

            <div class="row-2">
              <div class="field">
                <label for="wearSeason">계절감</label>
                <select id="wearSeason" name="wearSeason">
                  <option value="봄/가을" <%= safeWearInfo.season === '봄/가을' ? 'selected' : '' %>>봄/가을</option>
                  <option value="여름" <%= safeWearInfo.season === '여름' ? 'selected' : '' %>>여름</option>
                  <option value="겨울" <%= safeWearInfo.season === '겨울' ? 'selected' : '' %>>겨울</option>
                </select>
              </div>

              <div class="field">
                <label for="wearElasticity">신축성</label>
                <select id="wearElasticity" name="wearElasticity">
                  <option value="없음" <%= safeWearInfo.elasticity === '없음' ? 'selected' : '' %>>없음</option>
                  <option value="적당함" <%= safeWearInfo.elasticity === '적당함' ? 'selected' : '' %>>적당함</option>
                  <option value="좋음" <%= safeWearInfo.elasticity === '좋음' ? 'selected' : '' %>>좋음</option>
                </select>
              </div>
            </div>

            <div class="row-2">
              <div class="field">
                <label for="wearThickness">두께감</label>
                <select id="wearThickness" name="wearThickness">
                  <option value="얇음" <%= safeWearInfo.thickness === '얇음' ? 'selected' : '' %>>얇음</option>
                  <option value="적당함" <%= safeWearInfo.thickness === '적당함' ? 'selected' : '' %>>적당함</option>
                  <option value="두꺼움" <%= safeWearInfo.thickness === '두꺼움' ? 'selected' : '' %>>두꺼움</option>
                </select>
              </div>

              <div class="field">
                <label for="wearWeight">무게감</label>
                <select id="wearWeight" name="wearWeight">
                  <option value="가벼움" <%= safeWearInfo.weight === '가벼움' ? 'selected' : '' %>>가벼움</option>
                  <option value="적당함" <%= safeWearInfo.weight === '적당함' ? 'selected' : '' %>>적당함</option>
                  <option value="무거움" <%= safeWearInfo.weight === '무거움' ? 'selected' : '' %>>무거움</option>
                </select>
              </div>
            </div>
          </div>

          <div class="submit-wrap">
            <button type="submit"><%= product ? '상품 수정 저장' : '상품 등록' %></button>
            <button type="button" class="sub-btn" onclick="fillSample()">샘플값 자동 입력</button>
            <a href="/admin/products">목록으로</a>
          </div>
        </div>

        <div>
          <div class="card sticky-card">
            <h2>실시간 미리보기</h2>

            <div class="mini-preview-box">
              <div class="mini-preview-image" id="miniPreviewImage">
                <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:#888;">미리보기 없음</div>
              </div>

              <div class="mini-preview-name" id="miniName">상품명</div>
              <div class="mini-preview-price" id="miniPrice">0원</div>
              <div class="mini-preview-desc" id="miniSummary">상품 설명이 여기에 표시됩니다.</div>
            </div>

            <div class="hint" style="margin-top:14px;">
              저장 전에 기본 상품 정보만 빠르게 체크하는 관리자 미리보기
            </div>
          </div>
        </div>
      </div>
    </form>
  </div>

  <script id="category-data" type="application/json"><%- JSON.stringify(categoryMap) %></script>

  <script>
    const CATEGORY_MAP = JSON.parse(
      document.getElementById('category-data')?.textContent || '{}'
    );

    const initialCategory = "<%= String(safeProduct.category || '').trim().toLowerCase() %>";
    const initialSubCategory = "<%= String(safeProduct.subCategory || '').trim() %>";

    const nameInput = document.getElementById('name');
    const summaryInput = document.getElementById('summary');
    const priceInput = document.getElementById('price');
    const categorySelect = document.getElementById('category');
    const subCategorySelect = document.getElementById('subCategory');

    const miniName = document.getElementById('miniName');
    const miniPrice = document.getElementById('miniPrice');
    const miniSummary = document.getElementById('miniSummary');
    const miniPreviewImage = document.getElementById('miniPreviewImage');

    function updateMiniPreview() {
      miniName.textContent = nameInput.value || '상품명';
      miniSummary.textContent = summaryInput.value || '상품 설명이 여기에 표시됩니다.';
      miniPrice.textContent = Number(priceInput.value || 0).toLocaleString() + '원';
    }

    function appendText(id, value) {
      const input = document.getElementById(id);
      if (!input) return;

      const current = input.value.trim();
      if (!current) {
        input.value = value;
        return;
      }

      const arr = current.split(',').map(v => v.trim()).filter(Boolean);
      if (!arr.includes(value)) {
        arr.push(value);
      }
      input.value = arr.join(', ');
    }

    function renderSubCategories(categoryValue, selectedSub = '') {
      if (!subCategorySelect) return;

      const info = CATEGORY_MAP[String(categoryValue || '').trim().toLowerCase()] || null;
      const subs = info && Array.isArray(info.subCategories) ? info.subCategories : [];

      subCategorySelect.innerHTML = '<option value="">서브카테고리 선택</option>';

      subs.forEach((sub) => {
        const option = document.createElement('option');
        option.value = sub;
        option.textContent = sub;
        if (String(selectedSub || '').trim() === String(sub || '').trim()) {
          option.selected = true;
        }
        subCategorySelect.appendChild(option);
      });
    }

    function fillSample() {
      if (!nameInput.value) nameInput.value = '샘플 후드 데님 자켓';
      if (!summaryInput.value) summaryInput.value = '레이어드 무드가 살아있는 데일리 아우터';
      if (!priceInput.value) priceInput.value = '35000';

      const oldPrice = document.getElementById('oldPrice');
      const shippingFeeText = document.getElementById('shippingFeeText');
      const colorsInput = document.getElementById('colorsInput');
      const sizesInput = document.getElementById('sizesInput');
      const modelInfo = document.getElementById('modelInfo');
      const wearSeason = document.getElementById('wearSeason');
      const wearElasticity = document.getElementById('wearElasticity');
      const wearThickness = document.getElementById('wearThickness');
      const wearWeight = document.getElementById('wearWeight');

      if (oldPrice && !oldPrice.value) oldPrice.value = '45900';
      if (shippingFeeText && !shippingFeeText.value) shippingFeeText.value = '무료배송';
      if (colorsInput && !colorsInput.value) colorsInput.value = '검정색, 베이지';
      if (sizesInput && !sizesInput.value) sizesInput.value = 'M, L, XL';
      if (modelInfo && !modelInfo.value) modelInfo.value = '신혜성 178cm / 70kg (상의 100~105 / 하의 30~31)';
      if (wearSeason && !wearSeason.value) wearSeason.value = '봄/가을';
      if (wearElasticity && !wearElasticity.value) wearElasticity.value = '적당함';
      if (wearThickness && !wearThickness.value) wearThickness.value = '적당함';
      if (wearWeight && !wearWeight.value) wearWeight.value = '적당함';

      updateMiniPreview();
    }

    function renderSinglePreview(file, previewEl, placeholderEl) {
      if (!file || !previewEl) return;

      const url = URL.createObjectURL(file);
      const isVideo = file.type.startsWith('video/');

      previewEl.innerHTML = isVideo
        ? '<video src="' + url + '" controls muted playsinline></video>'
        : '<img src="' + url + '" alt="preview" />';

      previewEl.style.display = 'block';
      if (placeholderEl) placeholderEl.style.display = 'none';

      miniPreviewImage.innerHTML = isVideo
        ? '<video src="' + url + '" controls muted playsinline></video>'
        : '<img src="' + url + '" alt="main preview" />';
    }

    function renderMultiPreview(files, gridEl, badgeText) {
      if (!gridEl) return;
      gridEl.innerHTML = '';

      Array.from(files).forEach((file) => {
        const url = URL.createObjectURL(file);
        const isVideo = file.type.startsWith('video/');
        const item = document.createElement('div');
        item.className = 'preview-item';

        item.innerHTML = `
          <div class="preview-badge">${badgeText}</div>
          ${isVideo
            ? `<video src="${url}" muted playsinline controls></video>`
            : `<img src="${url}" alt="preview">`
          }
        `;

        gridEl.appendChild(item);
      });
    }

    function setupUploadBox(boxId, inputId, previewCallback) {
      const box = document.getElementById(boxId);
      const input = document.getElementById(inputId);
      if (!box || !input) return;

      ['dragenter', 'dragover'].forEach(evt => {
        box.addEventListener(evt, (e) => {
          e.preventDefault();
          e.stopPropagation();
          box.classList.add('dragover');
        });
      });

      ['dragleave', 'drop'].forEach(evt => {
        box.addEventListener(evt, (e) => {
          e.preventDefault();
          e.stopPropagation();
          box.classList.remove('dragover');
        });
      });

      box.addEventListener('drop', (e) => {
        const dt = e.dataTransfer;
        if (!dt || !dt.files || !dt.files.length) return;

        input.files = dt.files;
        previewCallback(dt.files);
      });

      input.addEventListener('change', () => {
        if (!input.files || !input.files.length) return;
        previewCallback(input.files);
      });
    }

    nameInput.addEventListener('input', updateMiniPreview);
    summaryInput.addEventListener('input', updateMiniPreview);
    priceInput.addEventListener('input', updateMiniPreview);

    if (categorySelect) {
      categorySelect.addEventListener('change', function () {
        renderSubCategories(categorySelect.value, '');
      });
    }

    renderSubCategories(initialCategory, initialSubCategory);
    updateMiniPreview();

    setupUploadBox('mainUploadBox', 'mainImageInput', (files) => {
      const file = files[0];
      renderSinglePreview(
        file,
        document.getElementById('mainPreview'),
        document.getElementById('mainPlaceholder')
      );
    });

    setupUploadBox('subUploadBox', 'subImagesInput', (files) => {
      renderMultiPreview(files, document.getElementById('subPreviewGrid'), '추가');
    });

    setupUploadBox('detailUploadBox', 'detailImagesInput', (files) => {
      renderMultiPreview(files, document.getElementById('detailPreviewGrid'), '상세');
    });
  </script>
</body>
</html>
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= mode === 'edit' ? '숏폼 수정' : '숏폼 등록' %></title>
  <style>
    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #f6f3ee;
      color: #111;
    }

    .wrap {
      max-width: 760px;
      margin: 40px auto;
      padding: 0 20px;
    }

    .card {
      background: #fff;
      border-radius: 24px;
      padding: 28px;
      box-shadow: 0 18px 40px rgba(0, 0, 0, 0.06);
    }

    h1 {
      margin: 0 0 24px;
      font-size: 30px;
    }

    .row {
      margin-bottom: 18px;
    }

    label {
      display: block;
      margin-bottom: 8px;
      font-size: 14px;
      font-weight: 700;
    }

    input,
    select {
      width: 100%;
      height: 50px;
      border: 1px solid #ddd;
      border-radius: 12px;
      padding: 0 14px;
      font-size: 14px;
      outline: none;
    }

    input[type="file"] {
      height: auto;
      padding: 12px 14px;
    }

    input[readonly] {
      background: #fafafa;
    }

    .hint {
      margin-top: 6px;
      font-size: 12px;
      color: #666;
      line-height: 1.5;
    }

    .media-preview {
      margin-top: 12px;
      border-radius: 16px;
      overflow: hidden;
      background: #111;
      border: 1px solid #eee;
    }

    .media-preview video {
      display: block;
      width: 100%;
      max-height: 520px;
      object-fit: contain;
      background: #000;
    }

    .actions {
      display: flex;
      gap: 10px;
      margin-top: 24px;
    }

    .btn {
      flex: 1;
      height: 52px;
      border: 0;
      border-radius: 999px;
      font-weight: 800;
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .save-btn {
      background: #111;
      color: #fff;
    }

    .back-btn {
      background: #eee;
      color: #111;
    }
  </style>
</head>
<body>
  <%
    const safeProducts = (products || []).map((product) => ({
      _id: String(product._id),
      name: product.name || '',
      price: Number(product.price || 0)
    }));
  %>

  <div class="wrap">
    <div class="card">
      <h1><%= mode === 'edit' ? '숏폼 수정' : '숏폼 등록' %></h1>

      <form
        method="POST"
        enctype="multipart/form-data"
        action="<%= mode === 'edit' ? `/admin/shorts/${short._id}/edit` : '/admin/shorts/new' %>">

        <div class="row">
          <label>제목</label>
          <input type="text" name="title" value="<%= short?.title || '' %>" placeholder="예: 데일리 무드 코디" />
        </div>

        <div class="row">
          <label>영상 업로드</label>
          <input type="file" name="videoFile" accept="video/*" <%= mode === 'create' ? 'required' : '' %> />
          <div class="hint">업로드하면 자동으로 mp4(H.264) 형식으로 변환됨</div>

          <% if (short?.video) { %>
            <div class="media-preview">
              <video src="<%= short.video %>" controls preload="metadata"></video>
            </div>
          <% } %>
        </div>

        <div class="row">
          <label>연결 상품</label>
          <select name="productId" id="productId">
            <option value="">상품 선택</option>
            <% products.forEach((product) => { %>
              <option
                value="<%= product._id %>"
                <%= String(short?.productId || '') === String(product._id) ? 'selected' : '' %>>
                <%= product.name %>
              </option>
            <% }) %>
          </select>
        </div>

        <div class="row">
          <label>상품명</label>
          <input type="text" id="productTitle" name="productTitle" value="<%= short?.productTitle || '' %>" readonly />
        </div>

        <div class="row">
          <label>가격</label>
          <input type="text" id="productPrice" name="productPrice" value="<%= short?.productPrice || '' %>" readonly />
        </div>

        <div class="row">
          <label>링크</label>
          <input type="text" id="link" name="link" value="<%= short?.link || '/about' %>" readonly />
        </div>

        <div class="row">
          <label>정렬순서</label>
          <input type="number" name="sortOrder" value="<%= short?.sortOrder ?? 0 %>" />
        </div>

        <div class="row">
          <label>노출여부</label>
          <select name="isVisible">
            <option value="true" <%= short?.isVisible !== false ? 'selected' : '' %>>노출</option>
            <option value="false" <%= short?.isVisible === false ? 'selected' : '' %>>숨김</option>
          </select>
        </div>

        <div class="actions">
          <button type="submit" class="btn save-btn">저장</button>
          <a href="/admin/shorts" class="btn back-btn">목록으로</a>
        </div>
      </form>
    </div>
  </div>

  <script id="products-json" type="application/json"><%- JSON.stringify(safeProducts) %></script>

  <script>
    const products = JSON.parse(document.getElementById('products-json').textContent || '[]');
    const productSelect = document.getElementById('productId');
    const productTitleInput = document.getElementById('productTitle');
    const productPriceInput = document.getElementById('productPrice');
    const linkInput = document.getElementById('link');

    function formatPrice(value) {
      return '₩' + Number(value || 0).toLocaleString();
    }

    function applyProduct(productId) {
      const selected = products.find((product) => product._id === productId);

      if (!selected) {
        productTitleInput.value = '';
        productPriceInput.value = '';
        linkInput.value = '/about';
        return;
      }

      productTitleInput.value = selected.name || '';
      productPriceInput.value = formatPrice(selected.price || 0);
      linkInput.value = '/products/' + selected._id;
    }

    if (productSelect) {
      productSelect.addEventListener('change', function () {
        applyProduct(this.value);
      });

      if (productSelect.value) {
        applyProduct(productSelect.value);
      }
    }
  </script>
</body>
</html>
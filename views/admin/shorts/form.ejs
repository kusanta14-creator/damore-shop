<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= mode === 'edit' ? '숏폼 수정' : '숏폼 등록' %> | DAMORE ADMIN</title>
  <style>
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #f6f3ee;
      color: #111;
    }
    .wrap {
      max-width: 820px;
      margin: 0 auto;
      padding: 40px 20px;
    }
    .card {
      background: #fff;
      border-radius: 24px;
      padding: 28px;
      box-shadow: 0 18px 40px rgba(0,0,0,0.06);
    }
    h1 {
      margin: 0 0 24px;
      font-size: 30px;
    }
    .row {
      margin-bottom: 16px;
    }
    label {
      display: block;
      margin-bottom: 8px;
      font-size: 14px;
      font-weight: 700;
    }
    input,
    select {
      width: 100%;
      height: 50px;
      border: 1px solid #ddd;
      border-radius: 12px;
      padding: 0 14px;
      font-size: 14px;
      outline: none;
    }
    .actions {
      display: flex;
      gap: 10px;
      margin-top: 24px;
    }
    .btn {
      flex: 1;
      height: 52px;
      border: 0;
      border-radius: 999px;
      font-weight: 800;
      cursor: pointer;
    }
    .save-btn {
      background: #111;
      color: #fff;
    }
    .back-btn {
      background: #eee;
      color: #111;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="card">
      <h1><%= mode === 'edit' ? '숏폼 수정' : '숏폼 등록' %></h1>

      <form method="POST" action="<%= mode === 'edit' ? `/admin/shorts/${short._id}/edit` : '/admin/shorts/new' %>">
        <div class="row">
          <label>제목</label>
          <input type="text" name="title" value="<%= short?.title || '' %>" />
        </div>

        <div class="row">
          <label>상단 라벨</label>
          <input type="text" name="brandLabel" value="<%= short?.brandLabel || 'DAMORE SHORTS' %>" />
        </div>

        <div class="row">
          <label>영상 경로 (필수)</label>
          <input type="text" name="video" value="<%= short?.video || '' %>" placeholder="/videos/short1.mp4" required />
        </div>

        <div class="row">
          <label>포스터 이미지</label>
          <input type="text" name="poster" value="<%= short?.poster || '' %>" placeholder="/images/short-poster1.jpg" />
        </div>

        <div class="row">
          <label>클릭 링크</label>
          <input type="text" name="link" value="<%= short?.link || '/about' %>" />
        </div>

        <div class="row">
          <label>연결 상품</label>
          <select name="productId">
            <option value="">상품 직접 선택 안함</option>
            <% products.forEach((product) => { %>
              <option value="<%= product._id %>" <%= String(short?.productId || '') === String(product._id) ? 'selected' : '' %>>
                <%= product.name %>
              </option>
            <% }) %>
          </select>
        </div>

        <div class="row">
          <label>상품명 표시</label>
          <input type="text" name="productTitle" value="<%= short?.productTitle || '' %>" />
        </div>

        <div class="row">
          <label>상품가격 표시</label>
          <input type="text" name="productPrice" value="<%= short?.productPrice || '' %>" placeholder="₩26,900" />
        </div>

        <div class="row">
          <label>상품 썸네일</label>
          <input type="text" name="productThumb" value="<%= short?.productThumb || '' %>" />
        </div>

        <div class="row">
          <label>정렬순서</label>
          <input type="number" name="sortOrder" value="<%= short?.sortOrder ?? 0 %>" />
        </div>

        <div class="row">
          <label>노출여부</label>
          <select name="isVisible">
            <option value="true" <%= short?.isVisible !== false ? 'selected' : '' %>>노출</option>
            <option value="false" <%= short?.isVisible === false ? 'selected' : '' %>>숨김</option>
          </select>
        </div>

        <div class="actions">
          <button type="submit" class="btn save-btn">저장</button>
          <a href="/admin/shorts" class="btn back-btn">목록으로</a>
        </div>
      </form>
    </div>
  </div>
</body>
</html>
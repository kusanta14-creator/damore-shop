<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>숏폼 관리 | DAMORE ADMIN</title>
  <style>
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #f6f3ee;
      color: #111;
    }
    .wrap {
      max-width: 1200px;
      margin: 0 auto;
      padding: 40px 20px;
    }
    .top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      margin-bottom: 24px;
      flex-wrap: wrap;
    }
    h1 {
      margin: 0;
      font-size: 32px;
    }
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 44px;
      padding: 0 16px;
      border-radius: 999px;
      background: #111;
      color: #fff;
      text-decoration: none;
      font-weight: 700;
      border: 0;
      cursor: pointer;
    }
    .back {
      color: #666;
      text-decoration: none;
      font-size: 14px;
    }
    .grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 18px;
    }
    .card {
      background: #fff;
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 12px 30px rgba(0,0,0,0.06);
    }
    .thumb {
      aspect-ratio: 9 / 16;
      background: #ddd;
    }
    .thumb video,
    .thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .body {
      padding: 14px;
    }
    .title {
      font-size: 15px;
      font-weight: 800;
      margin-bottom: 8px;
    }
    .meta {
      font-size: 13px;
      color: #666;
      margin-bottom: 6px;
    }
    .actions {
      display: flex;
      gap: 8px;
      margin-top: 12px;
    }
    .actions a,
    .actions button {
      flex: 1;
      min-height: 40px;
      border-radius: 12px;
      border: 0;
      cursor: pointer;
      text-decoration: none;
      font-weight: 700;
    }
    .edit-btn {
      background: #111;
      color: #fff;
    }
    .delete-btn {
      background: #eee;
      color: #111;
    }
    @media (max-width: 1100px) {
      .grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    @media (max-width: 760px) {
      .grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <a href="/admin/dashboard" class="back">← 관리자 메인으로</a>

    <div class="top">
      <h1>숏폼 관리</h1>
      <a href="/admin/shorts/new" class="btn">숏폼 등록</a>
    </div>

    <div class="grid">
      <% shorts.forEach((item) => { %>
        <div class="card">
          <div class="thumb">
            <% if (item.video) { %>
              <video src="<%= item.video %>" muted playsinline preload="metadata"></video>
            <% } else if (item.poster) { %>
              <img src="<%= item.poster %>" alt="<%= item.title %>">
            <% } %>
          </div>

          <div class="body">
            <div class="title"><%= item.title || '제목 없음' %></div>
            <div class="meta">노출: <%= item.isVisible ? 'ON' : 'OFF' %></div>
            <div class="meta">정렬순서: <%= item.sortOrder %></div>
            <div class="meta">연결링크: <%= item.link || '-' %></div>

            <div class="actions">
              <a href="/admin/shorts/<%= item._id %>/edit" class="edit-btn">수정</a>
              <form method="POST" action="/admin/shorts/<%= item._id %>/delete" style="flex:1;">
                <button type="submit" class="delete-btn">삭제</button>
              </form>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</body>
</html>
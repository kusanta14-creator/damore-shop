<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>공지사항 관리 | DAMORE ADMIN</title>
  <style>
    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #f7f7f7;
      color: #111;
      padding: 30px 20px 60px;
    }

    .wrap {
      max-width: 1100px;
      margin: 0 auto;
    }

    h1 {
      margin: 0 0 24px;
      font-size: 32px;
    }

    .top-actions {
      display: flex;
      gap: 10px;
      margin-bottom: 24px;
      flex-wrap: wrap;
    }

    .top-actions a {
      border: 1px solid #ddd;
      background: #fff;
      color: #111;
      padding: 10px 14px;
      border-radius: 10px;
      text-decoration: none;
      font-size: 14px;
    }

    .board-card {
      background: #fff;
      border: 1px solid #ececec;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 6px 20px rgba(0,0,0,0.04);
    }

    .board-head,
    .board-row {
      display: grid;
      grid-template-columns: 90px 1fr 120px 120px 180px;
      gap: 12px;
      align-items: center;
      padding: 16px 18px;
      border-bottom: 1px solid #f0f0f0;
    }

    .board-head {
      background: #fafafa;
      font-weight: 800;
      font-size: 14px;
    }

    .board-row {
      font-size: 14px;
    }

    .board-row:last-child {
      border-bottom: 0;
    }

    .title {
      font-weight: 700;
    }

    .actions {
      display: flex;
      gap: 8px;
      justify-content: flex-end;
      flex-wrap: wrap;
    }

    .actions a,
    .actions button {
      border: 1px solid #ddd;
      background: #fff;
      color: #111;
      padding: 7px 10px;
      border-radius: 8px;
      font-size: 12px;
      cursor: pointer;
      text-decoration: none;
    }

    .empty-box {
      padding: 60px 20px;
      text-align: center;
      color: #777;
      font-size: 15px;
    }

    form {
      margin: 0;
    }

    @media (max-width: 900px) {
      .board-head {
        display: none;
      }

      .board-row {
        grid-template-columns: 1fr;
        gap: 8px;
      }

      .actions {
        justify-content: flex-start;
      }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <h1>공지사항 관리</h1>

    <div class="top-actions">
      <a href="/admin/dashboard">대시보드</a>
      <a href="/admin/notices/new">공지 작성</a>
    </div>

    <div class="board-card">
      <% if (notices && notices.length > 0) { %>
        <div class="board-head">
          <div>고정</div>
          <div>제목</div>
          <div>노출</div>
          <div>등록일</div>
          <div style="text-align:right;">관리</div>
        </div>

        <% notices.forEach((notice) => { %>
          <div class="board-row">
            <div><%= notice.isPinned ? '상단고정' : '-' %></div>
            <div class="title"><%= notice.title %></div>
            <div><%= notice.isVisible ? '노출' : '숨김' %></div>
            <div><%= new Date(notice.createdAt).toLocaleDateString('ko-KR') %></div>
            <div class="actions">
              <a href="/community/notice/<%= notice._id %>" target="_blank">보기</a>
              <a href="/admin/notices/<%= notice._id %>/edit">수정</a>
              <form action="/admin/notices/<%= notice._id %>/delete" method="POST" onsubmit="return confirm('삭제할까요?');">
                <button type="submit">삭제</button>
              </form>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <div class="empty-box">등록된 공지사항이 없습니다.</div>
      <% } %>
    </div>
  </div>
</body>
</html>
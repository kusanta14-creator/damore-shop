  }

  .benefit-line:last-child {
    border-bottom: 0;
  }

  .benefit-label,
  .benefit-value {
    font-weight: 700;
  }

  .option-wrap {
    margin-bottom: 10px;
    border-top: 1px solid var(--line);
    padding-top: 12px;
  }

  .option-group {
    margin-bottom: 12px;
  }

  .option-title {
    font-size: 11px;
    font-weight: 700;
    color: #6f675d;
    margin-bottom: 7px;
  }

  .option-values {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .option-chip {
    min-width: 34px;
    height: 30px;
    padding: 0 12px;
    border: 1px solid #d2cabf;
    background: #fff;
    color: #444;
    font-size: 11px;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: .2s ease;
  }

  .option-chip.active {
    background: #111;
    color: #fff;
    border-color: #111;
  }

  .option-chip.soldout {
    opacity: 0.45;
    cursor: not-allowed;
    text-decoration: line-through;
  }

  .error-text {
    min-height: 14px;
    margin-top: 4px;
    color: var(--danger);
    font-size: 10px;
    font-weight: 700;
  }

  .with-section {
    margin: 16px 0 12px;
    border-top: 1px solid var(--line);
    padding-top: 14px;
  }

  .with-title {
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 4px;
  }

  .with-sub {
    font-size: 11px;
    color: var(--danger);
    margin-bottom: 10px;
  }

  .with-wrap {
    position: relative;
  }

  .with-viewport {
    overflow: hidden;
  }

  .with-track {
    display: flex;
    gap: 8px;
    transition: transform .25s ease;
    will-change: transform;
  }

  .with-card {
    min-width: 76px;
    max-width: 76px;
    flex: 0 0 76px;
  }

  .with-thumb {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1.25;
    background: #e8e1d6;
    overflow: hidden;
    margin-bottom: 5px;
  }

  .with-rank {
    position: absolute;
    top: 0;
    left: 0;
    width: 16px;
    height: 16px;
    background: rgba(0, 0, 0, 0.68);
    color: #fff;
    font-size: 9px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .with-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .with-name {
    font-size: 9px;
    line-height: 1.35;
    min-height: 28px;
    color: #333;
    margin-bottom: 4px;
    word-break: keep-all;
  }

  .with-price-row {
    display: flex;
    flex-direction: column;
    gap: 1px;
    margin-bottom: 6px;
  }

  .with-sale {
    color: var(--danger);
    font-size: 9px;
    font-weight: 700;
  }

  .with-price {
    font-size: 10px;
    font-weight: 800;
  }

  .with-old {
    color: #9a9288;
    text-decoration: line-through;
    font-size: 9px;
  }

  .with-btn {
    width: 100%;
    height: 18px;
    border: 0;
    background: #fb625f;
    color: #fff;
    font-size: 9px;
    font-weight: 700;
    cursor: pointer;
  }

  .with-btn.selected {
    background: #111;
  }

  .with-nav {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
    margin-top: 8px;
  }

  .with-arrow {
    width: 16px;
    height: 16px;
    border: 1px solid #d8d0c4;
    background: transparent;
    color: #777;
    cursor: pointer;
    line-height: 1;
    font-size: 10px;
  }

  .with-page {
    font-size: 10px;
    color: #555;
    min-width: 28px;
    text-align: center;
  }

  .selected-box {
    background: transparent;
    border-top: 1px solid var(--line);
    padding-top: 12px;
    margin-bottom: 12px;
  }

  .selected-name {
    font-size: 11px;
    font-weight: 700;
    margin-bottom: 6px;
  }

  .selected-meta {
    font-size: 10px;
    color: #6f675d;
    margin-bottom: 10px;
    min-height: 16px;
  }

  .qty-total-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 12px;
    flex-wrap: wrap;
  }

  .qty-row {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    background: transparent;
    height: 28px;
  }

  .qty-btn {
    width: 22px;
    height: 22px;
    border: 1px solid #ddd6cb;
    background: var(--soft-2);
    font-size: 11px;
    cursor: pointer;
    color: #555;
  }

  .qty-input {
    width: 28px;
    height: 22px;
    border: 1px solid #ddd6cb;
    background: var(--soft-2);
    text-align: center;
    outline: none;
    font-size: 10px;
    color: #444;
  }

  .total-box {
    text-align: right;
    font-size: 10px;
    color: #666;
  }

  .total-price {
    display: block;
    font-size: 14px;
    color: #111;
    font-weight: 900;
    margin-top: 2px;
  }

  .btn-grid-main {
    display: grid;
    grid-template-columns: 1fr 36px 36px;
    gap: 6px;
    margin-top: 10px;
  }

  .btn-grid-sub {
    display: grid;
    grid-template-columns: 1fr;
    gap: 6px;
    margin-top: 6px;
  }

  .action-btn {
    border: 0;
    font-size: 10px;
    font-weight: 800;
    cursor: pointer;
  }

  .action-btn:disabled {
    opacity: .55;
    cursor: not-allowed;
  }

  .btn-buy {
    background: var(--brown-dark);
    color: #fff;
    height: 32px;
  }

  .btn-cart-icon,
  .btn-wish-icon {
    background: var(--icon);
    color: #444;
    border: 1px solid #d8d0c4;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    height: 32px;
  }

  .btn-npay {
    background: var(--green);
    color: #fff;
    height: 30px;
    font-size: 10px;
  }

  .content-wrap {
    max-width: 820px;
    margin: 80px auto 0;
    padding-top: 18px;
    border-top: 1px solid var(--line);
  }

  .content-nav {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: 0;
    margin-bottom: 26px;
    font-size: 11px;
    color: #7d766e;
    text-align: center;
  }

  .content-nav a {
    position: relative;
    padding: 0 14px;
    font-weight: 500;
    transition: color .2s ease;

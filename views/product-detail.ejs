<%
  const safeProduct = typeof product !== 'undefined' && product ? product : {};
  const safeAddOnProducts =
    typeof addOnProducts !== 'undefined' && Array.isArray(addOnProducts)
      ? addOnProducts.filter(Boolean)
      : [];

  const safeName = safeProduct.name || '상품명';
  const safePrice = Number(safeProduct.price || 0);
  const safeOldPrice = Number(safeProduct.oldPrice || safeProduct.price || 0);
  const safeStock = Number(safeProduct.stock || 0);
  const safeStatus = safeProduct.status || '';
  const safeSummary = safeProduct.summary || '';
  const safeDesc = safeProduct.desc || safeProduct.description || '';
  const safeSubImages = Array.isArray(safeProduct.subImages) ? safeProduct.subImages.filter(Boolean) : [];
  const safeDetailImages = Array.isArray(safeProduct.detailImages) ? safeProduct.detailImages.filter(Boolean) : [];
  const safeOptionGroups = Array.isArray(safeProduct.optionGroups) ? safeProduct.optionGroups.filter(Boolean) : [];
  const safeGuide = safeProduct.guide || {};

  let colorGroup = null;
  let sizeGroup = null;

  if (safeOptionGroups.length >= 1) colorGroup = safeOptionGroups[0];
  if (safeOptionGroups.length >= 2) sizeGroup = safeOptionGroups[1];

  const galleryItems = [];
  if (safeProduct.image) galleryItems.push({ type: 'image', src: safeProduct.image });
  if (safeProduct.video) galleryItems.push({ type: 'video', src: safeProduct.video });

  safeSubImages.forEach((img) => {
    if (!galleryItems.find((item) => item.src === img)) {
      galleryItems.push({ type: 'image', src: img });
    }
  });

  const discountRate =
    safeOldPrice > safePrice && safeOldPrice > 0
      ? Math.round((1 - safePrice / safeOldPrice) * 100)
      : 0;

  const rewardPoint = Math.floor(safePrice * 0.01);
  const interestCount = Math.max(Number(safeProduct.likeCount || 0), 238);
  const isSoldOut = safeStatus === 'soldout' || safeStock <= 0;
  const modelInfo = safeProduct.modelInfo || '신혜성 178cm / 70kg (상의 100~105 / 하의 30~31)';
  const shippingText = safeProduct.shippingFeeText || '무료배송';
  const hasColorGroup = !!(colorGroup && Array.isArray(colorGroup.values) && colorGroup.values.length > 0);
  const hasSizeGroup = !!(sizeGroup && Array.isArray(sizeGroup.values) && sizeGroup.values.length > 0);
%>

<%- include('partials/header') %>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    --bg: #f4f1eb;
    --white: #ffffff;
    --text: #222222;
    --muted: #7a746c;
    --line: #ddd6cb;
    --soft: #f8f5f0;
    --soft-2: #f2ede6;
    --brown: #9d856c;
    --brown-dark: #876f57;
    --green: #03c75a;
    --danger: #ef625d;
    --icon: #f3eee7;
    --max: 1120px;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: "Pretendard", "Noto Sans KR", Arial, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button,
  input,
  select,
  textarea {
    font: inherit;
  }

  img,
  video {
    display: block;
    max-width: 100%;
  }

  .page {
    max-width: var(--max);
    margin: 0 auto;
    padding: 28px 18px 90px;
  }

  .layout {
    display: grid;
    grid-template-columns: 520px 360px;
    gap: 40px;
    justify-content: center;
    align-items: start;
  }

  .gallery-col {
    width: 100%;
    max-width: 520px;
  }

  .gallery-main {
    width: 100%;
    max-width: 520px;
    margin: 0 auto;
    aspect-ratio: 4 / 5.4;
    background: #e7e0d5;
    overflow: hidden;
  }

  .gallery-main img,
  .gallery-main video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    background: #e7e0d5;
  }

  .thumbs-wrap {
    margin-top: 10px;
  }

  .thumbs {
    display: flex;
    gap: 6px;
    flex-wrap: nowrap;
    overflow-x: auto;
    padding-bottom: 4px;
  }

  .thumb-btn {
    width: 58px;
    height: 72px;
    min-width: 58px;
    border: 1px solid #d8d0c4;
    background: #fff;
    overflow: hidden;
    cursor: pointer;
    padding: 0;
    opacity: .72;
    transition: .2s ease;
  }

  .thumb-btn.active {
    border-color: #111;
    opacity: 1;
  }

  .thumb-btn img,
  .thumb-btn video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .purchase-box {
    position: sticky;
    top: 18px;
    background: transparent;
  }

  .interest-bubble {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 5px 10px;
    border: 1px solid #d9d1c6;
    border-radius: 999px;
    background: #f8f5ef;
    color: #62594f;
    font-size: 10px;
    font-weight: 600;
    margin-bottom: 10px;
  }

  .title-row {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 8px;
  }

  .title {
    font-size: 21px;
    line-height: 1.35;
    font-weight: 800;
    word-break: keep-all;
  }

  .new-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 24px;
    height: 18px;
    padding: 0 5px;
    background: #f6b21a;
    color: #fff;
    font-size: 10px;
    font-weight: 700;
  }

  .summary-top {
    font-size: 12px;
    color: #61594f;
    margin-bottom: 12px;
    white-space: pre-line;
    word-break: keep-all;
    line-height: 1.7;
  }

  .price-lines {
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    margin-bottom: 12px;
  }

  .price-line {
    min-height: 38px;
    display: grid;
    grid-template-columns: 86px 1fr;
    align-items: center;
    border-bottom: 1px solid var(--line);
    font-size: 11px;
  }

  .price-line:last-child {
    border-bottom: 0;
  }

  .price-label {
    color: #70685f;
    font-weight: 700;
  }

  .price-old {
    color: #8b847a;
    text-decoration: line-through;
    margin-right: 10px;
    font-size: 11px;
  }

  .price-main {
    font-size: 18px;
    font-weight: 900;
  }

  .price-discount {
    color: var(--danger);
    margin-left: 6px;
    font-weight: 800;
    font-size: 11px;
  }

  .detail-info {
    margin-bottom: 12px;
  }

  .detail-row {
    display: grid;
    grid-template-columns: 88px minmax(0, 1fr);
    gap: 12px;
    padding: 4px 0;
    font-size: 11px;
    align-items: start;
  }

  .detail-row-label {
    color: #6f675d;
    font-weight: 700;
    white-space: nowrap;
    line-height: 1.65;
  }

  .detail-row-value {
    color: #2b2b2b;
    font-weight: 500;
    line-height: 1.65;
    word-break: keep-all;
    text-align: left;
  }

  .coupon-row {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 10px;
  }

  .coupon-btn {
    height: 30px;
    padding: 0 14px;
    border: 0;
    background: var(--brown);
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    cursor: pointer;
  }

  .benefit-box {
    border: 1px solid var(--line);
    background: transparent;
    margin-bottom: 14px;
  }

  .benefit-line {
    min-height: 38px;
    padding: 0 12px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    border-bottom: 1px solid var(--line);

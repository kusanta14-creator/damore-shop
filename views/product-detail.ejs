<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= (product && product.name) ? product.name : '상품상세' %> | DAMORE</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg: #f4f1eb;
      --white: #ffffff;
      --text: #222222;
      --muted: #7a746c;
      --line: #ddd6cb;
      --soft: #f8f5f0;
      --soft-2: #f2ede6;
      --brown: #9d856c;
      --green: #03c75a;
      --danger: #ef625d;
      --icon: #f3eee7;
      --max: 1180px;
    }

    body {
      font-family: "Pretendard", "Noto Sans KR", Arial, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
    }

    a { color: inherit; text-decoration: none; }
    button, input, select, textarea { font: inherit; }
    img, video { display: block; max-width: 100%; }

    .site-header {
      background: var(--white);
      border-bottom: 1px solid var(--line);
    }

    .site-header-inner {
      max-width: var(--max);
      margin: 0 auto;
      padding: 14px 18px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
    }

    .logo {
      font-size: 22px;
      font-weight: 800;
      letter-spacing: 0.08em;
    }

    .gnb {
      display: flex;
      gap: 18px;
      flex-wrap: wrap;
      font-size: 13px;
      color: #444;
    }

    .page {
      max-width: var(--max);
      margin: 0 auto;
      padding: 20px 18px 70px;
    }

    .layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 392px;
      gap: 34px;
      align-items: start;
    }

    .gallery-main {
      width: 100%;
      aspect-ratio: 1 / 1.24;
      background: #e7e0d5;
      overflow: hidden;
    }

    .gallery-main img,
    .gallery-main video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      background: #e7e0d5;
    }

    .thumbs {
      display: flex;
      gap: 6px;
      margin-top: 6px;
      flex-wrap: wrap;
    }

    .thumb-btn {
      width: 58px;
      height: 58px;
      border: 1px solid #d8d0c4;
      background: #fff;
      overflow: hidden;
      cursor: pointer;
      padding: 0;
    }

    .thumb-btn.active {
      border-color: #111;
    }

    .thumb-btn img,
    .thumb-btn video {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .purchase-box {
      position: sticky;
      top: 16px;
    }

    .interest-bubble {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 6px 12px;
      border: 1px solid #d9d1c6;
      border-radius: 999px;
      background: #f8f5ef;
      color: #62594f;
      font-size: 11px;
      font-weight: 600;
      margin-bottom: 10px;
    }

    .title-row {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 6px;
    }

    .title {
      font-size: 21px;
      line-height: 1.38;
      font-weight: 700;
      word-break: keep-all;
    }

    .new-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 24px;
      height: 18px;
      padding: 0 5px;
      background: #f6b21a;
      color: #fff;
      font-size: 10px;
      font-weight: 700;
    }

    .summary-top {
      font-size: 12px;
      color: #61594f;
      margin-bottom: 10px;
      white-space: pre-line;
      word-break: keep-all;
    }

    .price-lines {
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
      margin-bottom: 10px;
    }

    .price-line {
      min-height: 40px;
      display: grid;
      grid-template-columns: 92px 1fr;
      align-items: center;
      border-bottom: 1px solid var(--line);
      font-size: 12px;
    }

    .price-line:last-child {
      border-bottom: 0;
    }

    .price-label {
      color: #70685f;
      font-weight: 600;
    }

    .price-old {
      color: #8b847a;
      text-decoration: line-through;
      margin-right: 10px;
    }

    .price-main {
      font-size: 15px;
      font-weight: 800;
    }

    .price-discount {
      color: var(--danger);
      margin-left: 6px;
      font-weight: 700;
    }

    .toggle-bar {
      height: 34px;
      border: 1px solid var(--line);
      background: var(--soft);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      color: #333;
      margin-bottom: 12px;
      user-select: none;
    }

    .detail-info {
      margin-bottom: 10px;
    }

    .detail-row {
      display: grid !important;
      grid-template-columns: 70px 1fr !important;
      gap: 8px;
      padding: 4px 0;
      font-size: 11px;
      align-items: center;
    }

    .detail-row-label {
      color: #6f675d;
      font-weight: 600;
      letter-spacing: -0.01em;
    }

    .detail-row-value {
      color: #2b2b2b;
      font-weight: 500;
      letter-spacing: 0.02em;
      display: flex;
      align-items: center;
      word-break: keep-all;
      white-space: pre-line;
    }

    .coupon-row {
      display: flex;
      justify-content: flex-end;
      margin-bottom: 10px;
    }

    .coupon-btn {
      height: 30px;
      padding: 0 14px;
      border: 0;
      background: var(--brown);
      color: #fff;
      font-size: 11px;
      font-weight: 700;
      cursor: pointer;
    }

    .benefit-box {
      border: 1px solid var(--line);
      background: var(--soft);
      margin-bottom: 12px;
    }

    .benefit-line {
      min-height: 40px;
      padding: 0 12px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      border-bottom: 1px solid var(--line);
      font-size: 12px;
    }

    .benefit-line:last-child {
      border-bottom: 0;
    }

    .benefit-label,
    .benefit-value {
      font-weight: 700;
    }

    .benefit-toggle {
      height: 26px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      color: #5f574c;
    }

    .option-wrap {
      margin-bottom: 10px;
    }

    .option-group {
      margin-bottom: 10px;
    }

    .option-title {
      font-size: 12px;
      font-weight: 600;
      color: #6f675d;
      margin-bottom: 6px;
    }

    .option-values {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }

    .option-chip {
      min-width: 34px;
      height: 28px;
      padding: 0 10px;
      border: 1px solid #d2cabf;
      background: #fff;
      color: #444;
      font-size: 11px;
      font-weight: 600;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
    }

    .option-chip.active {
      background: #111;
      color: #fff;
      border-color: #111;
    }

    .option-chip.soldout {
      opacity: 0.45;
      cursor: not-allowed;
      text-decoration: line-through;
    }

    .error-text {
      min-height: 14px;
      margin-top: 4px;
      color: var(--danger);
      font-size: 10px;
      font-weight: 700;
    }

    .with-section {
      margin: 14px 0 10px;
      border-top: 1px solid var(--line);
      padding-top: 14px;
    }

    .with-title {
      font-size: 12px;
      font-weight: 800;
      margin-bottom: 2px;
    }

    .with-sub {
      font-size: 11px;
      color: var(--danger);
      margin-bottom: 10px;
    }

    .with-wrap {
      position: relative;
    }

    .with-viewport {
      overflow: hidden;
    }

    .with-track {
      display: flex;
      gap: 10px;
      transition: transform .25s ease;
      will-change: transform;
    }

    .with-card {
      min-width: 124px;
      max-width: 124px;
      flex: 0 0 124px;
    }

    .with-thumb {
      position: relative;
      width: 100%;
      aspect-ratio: 1 / 1.18;
      background: #e8e1d6;
      overflow: hidden;
      margin-bottom: 6px;
    }

    .with-rank {
      position: absolute;
      top: 0;
      left: 0;
      width: 18px;
      height: 18px;
      background: rgba(0, 0, 0, 0.65);
      color: #fff;
      font-size: 10px;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .with-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .with-name {
      font-size: 11px;
      line-height: 1.35;
      min-height: 30px;
      color: #333;
      margin-bottom: 4px;
      word-break: keep-all;
    }

    .with-price-row {
      display: flex;
      align-items: baseline;
      gap: 4px;
      flex-wrap: wrap;
      margin-bottom: 6px;
    }

    .with-sale {
      color: var(--danger);
      font-size: 11px;
      font-weight: 700;
    }

    .with-price {
      font-size: 11px;
      font-weight: 800;
    }

    .with-old {
      color: #9a9288;
      text-decoration: line-through;
      font-size: 10px;
    }

    .with-btn {
      width: 100%;
      height: 26px;
      border: 0;
      background: #fb625f;
      color: #fff;
      font-size: 11px;
      font-weight: 700;
      cursor: pointer;
    }

    .with-nav {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 10px;
      margin-top: 10px;
    }

    .with-arrow {
      width: 22px;
      height: 22px;
      border: 1px solid #d8d0c4;
      background: var(--soft);
      color: #777;
      cursor: pointer;
      line-height: 1;
    }

    .with-page {
      font-size: 11px;
      color: #555;
      min-width: 36px;
      text-align: center;
    }

    .selected-box {
      background: var(--soft);
      border: 1px solid var(--line);
      padding: 10px;
      margin-bottom: 12px;
    }

    .selected-name {
      font-size: 12px;
      font-weight: 700;
      margin-bottom: 6px;
    }

    .selected-meta {
      font-size: 11px;
      color: #6f675d;
      margin-bottom: 8px;
    }

    .qty-total-row {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 12px;
      flex-wrap: wrap;
    }

    .qty-row {
      display: inline-flex;
      align-items: center;
      gap: 2px;
      background: var(--soft);
      height: 30px;
    }

    .qty-btn {
      width: 24px;
      height: 24px;
      border: 0;
      background: var(--soft-2);
      font-size: 12px;
      cursor: pointer;
      color: #555;
    }

    .qty-input {
      width: 28px;
      height: 24px;
      border: 0;
      background: var(--soft-2);
      text-align: center;
      outline: none;
      font-size: 11px;
      color: #444;
    }

    .total-box {
      text-align: right;
      font-size: 10px;
      color: #666;
    }

    .total-price {
      display: block;
      font-size: 18px;
      color: #111;
      font-weight: 800;
      margin-top: 2px;
    }

    .btn-grid-main {
      display: grid;
      grid-template-columns: 1fr 48px 48px;
      gap: 6px;
      margin-top: 10px;
    }

    .btn-grid-sub {
      display: grid;
      grid-template-columns: 1fr;
      gap: 6px;
      margin-top: 6px;
    }

    .action-btn {
      border: 0;
      font-size: 11px;
      font-weight: 800;
      cursor: pointer;
    }

    .btn-buy {
      background: var(--brown);
      color: #fff;
      height: 48px;
    }

    .btn-cart-icon,
    .btn-wish-icon {
      background: var(--icon);
      color: #444;
      border: 1px solid #d8d0c4;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      height: 48px;
    }

    .btn-npay {
      background: var(--green);
      color: #fff;
      height: 38px;
    }

    .section {
      margin-top: 36px;
      background: #fff;
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
    }

    .tab-nav {
      display: flex;
      justify-content: center;
      border-bottom: 1px solid var(--line);
      overflow-x: auto;
    }

    .tab-btn {
      min-width: 100px;
      height: 42px;
      border: 0;
      border-right: 1px solid var(--line);
      background: #fff;
      cursor: pointer;
      font-size: 11px;
      font-weight: 700;
      color: #666;
      flex-shrink: 0;
    }

    .tab-btn:last-child {
      border-right: 0;
    }

    .tab-btn.active {
      background: #111;
      color: #fff;
    }

    .tab-panel {
      display: none;
      padding: 24px;
    }

    .tab-panel.active {
      display: block;
    }

    .detail-images {
      display: grid;
      gap: 18px;
    }

    .detail-images img {
      width: 100%;
    }

    .guide-text {
      font-size: 12px;
      color: #555;
      white-space: pre-line;
      word-break: keep-all;
    }

    @media (max-width: 1100px) {
      .layout {
        grid-template-columns: 1fr;
      }

      .purchase-box {
        position: static;
      }
    }

    @media (max-width: 640px) {
      .site-header-inner {
        flex-direction: column;
        align-items: flex-start;
      }

      .page {
        padding: 14px 12px 60px;
      }

      .title {
        font-size: 19px;
      }

      .btn-grid-main {
        grid-template-columns: 1fr 44px 44px;
      }

      .with-card {
        min-width: 114px;
        max-width: 114px;
        flex-basis: 114px;
      }

      .tab-panel {
        padding: 18px 14px;
      }
    }
  </style>
</head>
<body>
  <%
    const safeProduct = product || {};
    const safeSubImages = Array.isArray(safeProduct.subImages) ? safeProduct.subImages.filter(Boolean) : [];
    const safeDetailImages = Array.isArray(safeProduct.detailImages) ? safeProduct.detailImages.filter(Boolean) : [];
    const safeDesc = safeProduct.desc || safeProduct.description || '';
    const safeSummary = safeProduct.summary || '';
    const safeName = safeProduct.name || '상품명';
    const safePrice = Number(safeProduct.price || 0);
    const safeOldPrice = Number(safeProduct.oldPrice || safeProduct.price || 0);
    const safeStock = Number(safeProduct.stock || 0);
    const safeShipping = safeProduct.shippingFeeText || '무료배송';
    const isSoldOut = safeProduct.status === 'soldout' || (safeStock > 0 ? safeStock <= 0 : false);

    const safeOptionGroups = Array.isArray(safeProduct.optionGroups) ? safeProduct.optionGroups.filter(Boolean) : [];
    let colorGroup = null;
    let sizeGroup = null;

    if (safeOptionGroups.length >= 1) colorGroup = safeOptionGroups[0];
    if (safeOptionGroups.length >= 2) sizeGroup = safeOptionGroups[1];

    const colorValues = colorGroup && Array.isArray(colorGroup.values) ? colorGroup.values.filter(Boolean) : [];
    const sizeValues = sizeGroup && Array.isArray(sizeGroup.values) ? sizeGroup.values.filter(Boolean) : [];

    const galleryItems = [];
    if (safeProduct.image) galleryItems.push({ type: 'image', src: safeProduct.image });
    if (safeProduct.video) galleryItems.push({ type: 'video', src: safeProduct.video });
    safeSubImages.forEach((img) => {
      if (!galleryItems.find((item) => item.src === img)) {
        galleryItems.push({ type: 'image', src: img });
      }
    });

    const discountRate =
      safeOldPrice > safePrice && safeOldPrice > 0
        ? Math.round((1 - safePrice / safeOldPrice) * 100)
        : 0;

    const rewardPoint = Math.floor(safePrice * 0.01);
    const interestCount = Math.max(Number(safeProduct.likeCount || 0), 238);
    const safeAddOnProducts = Array.isArray(addOnProducts) ? addOnProducts.filter(Boolean) : [];
  %>

  <header class="site-header">
    <div class="site-header-inner">
      <a href="/" class="logo">DAMORE</a>
      <nav class="gnb">
        <a href="/">HOME</a>
        <a href="/category/outer">OUTER</a>
        <a href="/category/top">TOP</a>
        <a href="/category/bottom">BOTTOM</a>
        <a href="/category/dress">DRESS</a>
        <a href="/category/acc">ACC</a>
      </nav>
    </div>
  </header>

  <div
    id="productData"
    data-price="<%= safePrice %>"
    data-stock="<%= safeStock %>"
    data-has-color="<%= colorValues.length > 0 ? 'true' : 'false' %>"
    data-has-size="<%= sizeValues.length > 0 ? 'true' : 'false' %>"
  ></div>

  <div class="page">
    <div class="layout">
      <div class="gallery-col">
        <div class="gallery-main" id="galleryStage">
          <% if (galleryItems.length > 0) { %>
            <% if (galleryItems[0].type === 'video') { %>
              <video src="<%= galleryItems[0].src %>" controls playsinline preload="metadata"></video>
            <% } else { %>
              <img src="<%= galleryItems[0].src %>" alt="<%= safeName %>">
            <% } %>
          <% } else { %>
            <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:#999;">이미지 없음</div>
          <% } %>
        </div>

        <% if (galleryItems.length > 1) { %>
          <div class="thumbs" id="thumbs">
            <% galleryItems.forEach((item, index) => { %>
              <button
                type="button"
                class="thumb-btn <%= index === 0 ? 'active' : '' %>"
                data-type="<%= item.type %>"
                data-src="<%= item.src %>"
              >
                <% if (item.type === 'video') { %>
                  <video src="<%= item.src %>" muted playsinline preload="metadata"></video>
                <% } else { %>
                  <img src="<%= item.src %>" alt="썸네일">
                <% } %>
              </button>
            <% }) %>
          </div>
        <% } %>
      </div>

      <div class="purchase-col">
        <div class="purchase-box">
          <div class="interest-bubble">🔔 <%= interestCount.toLocaleString() %>명이 이 옷을 관심상품에 담아두었어요.</div>

          <div class="title-row">
            <div class="title"><%= safeName %></div>
            <div class="new-badge">NEW</div>
          </div>

          <% if (safeSummary) { %>
            <div class="summary-top"><%= safeSummary %></div>
          <% } %>

          <div class="price-lines">
            <div class="price-line">
              <div class="price-label">소비자가</div>
              <div>
                <span class="price-old"><%= safeOldPrice.toLocaleString() %>원</span>
              </div>
            </div>

            <div class="price-line">
              <div class="price-label">회원판매가</div>
              <div>
                <span class="price-main">KRW <%= safePrice.toLocaleString() %></span>
                <% if (discountRate > 0) { %>
                  <span class="price-discount">(<%= discountRate %>% off)</span>
                <% } %>
              </div>
            </div>
          </div>

          <div class="toggle-bar">자세히 보기 ∧</div>

          <div class="detail-info">
            <div class="detail-row">
              <div class="detail-row-label">상품간략설명</div>
              <div class="detail-row-value"><%= safeSummary || '-' %></div>
            </div>

            <div class="detail-row">
              <div class="detail-row-label">SIZE(cm)</div>
              <div class="detail-row-value">
                <%= sizeValues.length > 0 ? sizeValues.map(v => v.value).join(' / ') : 'FREE' %>
              </div>
            </div>

            <div class="detail-row">
              <div class="detail-row-label">MODEL</div>
              <div class="detail-row-value">신혜성 178cm / 70kg (상의 100~105 / 하의 30~31)</div>
            </div>

            <div class="detail-row">
              <div class="detail-row-label">배송비(비회원)</div>
              <div class="detail-row-value"><%= safeShipping %></div>
            </div>
          </div>

          <div class="coupon-row">
            <button type="button" class="coupon-btn" onclick="alert('쿠폰 다운로드 기능은 다음 단계에서 연결')">쿠폰 확인</button>
          </div>

          <div class="benefit-box">
            <div class="benefit-line">
              <div class="benefit-label">예상 최저가ⓘ</div>
              <div class="benefit-value"><%= safePrice.toLocaleString() %>원</div>
            </div>
            <div class="benefit-line">
              <div class="benefit-label">최대 적립 혜택</div>
              <div class="benefit-value"><%= rewardPoint.toLocaleString() %>P</div>
            </div>
            <div class="benefit-toggle">자세히 보기 ˅</div>
          </div>

          <form id="productForm" method="POST">
            <input type="hidden" name="productId" value="<%= safeProduct._id || '' %>">
            <input type="hidden" name="selectedOption" id="selectedOptionInput" value="">
            <input type="hidden" name="option" id="legacyOptionInput" value="">
            <input type="hidden" name="selectedColor" id="selectedColorInput" value="">
            <input type="hidden" name="quantity" id="quantityHidden" value="1">
            <input type="hidden" name="selectedAddOnIds" id="selectedAddOnIdsInput" value="">
            <input type="hidden" name="selectedAddOnNames" id="selectedAddOnNamesInput" value="">
            <input type="hidden" name="selectedAddOnTotal" id="selectedAddOnTotalInput" value="0">

            <div class="option-wrap">
              <% if (colorValues.length > 0) { %>
                <div class="option-group">
                  <div class="option-title">색상</div>
                  <div class="option-values" id="colorWrap">
                    <% colorValues.forEach((item) => { %>
                      <button
                        type="button"
                        class="option-chip <%= item.isSoldOut ? 'soldout' : '' %>"
                        data-color="<%= item.value %>"
                        data-soldout="<%= item.isSoldOut ? 'true' : 'false' %>"
                      >
                        <%= item.value %>
                      </button>
                    <% }) %>
                  </div>
                  <div class="error-text" id="colorError"></div>
                </div>
              <% } %>

              <% if (sizeValues.length > 0) { %>
                <div class="option-group">
                  <div class="option-title">사이즈</div>
                  <div class="option-values" id="sizeWrap">
                    <% sizeValues.forEach((item) => { %>
                      <button
                        type="button"
                        class="option-chip <%= item.isSoldOut ? 'soldout' : '' %>"
                        data-size="<%= item.value %>"
                        data-soldout="<%= item.isSoldOut ? 'true' : 'false' %>"
                      >
                        <%= item.value %>
                      </button>
                    <% }) %>
                  </div>
                  <div class="error-text" id="optionError"></div>
                </div>
              <% } %>
            </div>

            <% if (safeAddOnProducts.length > 0) { %>
              <div class="with-section">
                <div class="with-title">이 상품 구매하시는분들 이것도 같이 담고 할인받아요 🔥</div>
                <div class="with-sub">추가상품</div>

                <div class="with-wrap">
                  <div class="with-viewport">
                    <div class="with-track" id="withTrack">
                      <% safeAddOnProducts.forEach((item, index) => { 
                        const addPrice = Number(item.price || 0);
                        const addOldPrice = Number(item.oldPrice || item.price || 0);
                        const addDiscount = addOldPrice > addPrice && addOldPrice > 0
                          ? Math.round((1 - addPrice / addOldPrice) * 100)
                          : 0;
                      %>
                        <div class="with-card">
                          <div class="with-thumb">
                            <div class="with-rank"><%= index + 1 %></div>
                            <% if (item.image) { %>
                              <img src="<%= item.image %>" alt="<%= item.name || '추가상품' %>">
                            <% } %>
                          </div>

                          <div class="with-name"><%= item.name || '추가상품' %></div>

                          <div class="with-price-row">
                            <% if (addDiscount > 0) { %>
                              <span class="with-sale"><%= addDiscount %>%</span>
                              <span class="with-price"><%= addPrice.toLocaleString() %>원</span>
                              <span class="with-old"><%= addOldPrice.toLocaleString() %>원</span>
                            <% } else { %>
                              <span class="with-price"><%= addPrice.toLocaleString() %>원</span>
                            <% } %>
                          </div>

                          <button
                            type="button"
                            class="with-btn add-on-select-btn"
                            data-id="<%= item._id || '' %>"
                            data-name="<%= item.name || '추가상품' %>"
                            data-price="<%= addPrice %>"
                          >
                            선택
                          </button>
                        </div>
                      <% }) %>
                    </div>
                  </div>

                  <div class="with-nav">
                    <button type="button" class="with-arrow" id="withPrev">‹</button>
                    <span class="with-page" id="withPage">1/1</span>
                    <button type="button" class="with-arrow" id="withNext">›</button>
                  </div>
                </div>
              </div>
            <% } %>

            <div class="selected-box">
              <div class="selected-name"><%= safeName %></div>
              <div class="selected-meta" id="selectedMetaText">옵션을 선택해주세요.</div>

              <div class="qty-total-row">
                <div class="qty-row">
                  <button type="button" class="qty-btn" id="minusBtn">-</button>
                  <input
                    type="number"
                    id="qtyInput"
                    class="qty-input"
                    value="1"
                    min="1"
                    max="<%= Math.max(safeStock || 1, 1) %>"
                  />
                  <button type="button" class="qty-btn" id="plusBtn">+</button>
                </div>

                <div class="total-box">
                  TOTAL
                  <span class="total-price" id="totalPrice"><%= safePrice.toLocaleString() %></span>
                </div>
              </div>
            </div>

            <div class="btn-grid-main">
              <button
                type="button"
                class="action-btn btn-buy"
                id="buyBtn"
                <%= isSoldOut ? 'disabled' : '' %>
              >
                바로구매
              </button>

              <button
                type="button"
                class="action-btn btn-cart-icon"
                id="cartBtn"
                aria-label="장바구니"
                <%= isSoldOut ? 'disabled' : '' %>
              >
                🛒
              </button>

              <button
                type="button"
                class="action-btn btn-wish-icon"
                aria-label="찜"
                onclick="alert('찜 기능은 다음 단계에서 연결')"
              >
                ♡
              </button>
            </div>

            <div class="btn-grid-sub">
              <button
                type="button"
                class="action-btn btn-npay"
                onclick="alert('네이버페이 구매는 다음 단계에서 연결')"
                <%= isSoldOut ? 'disabled' : '' %>
              >
                Npay 구매
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <div class="section">
      <div class="tab-nav">
        <button type="button" class="tab-btn active" data-tab="detail">DETAIL</button>
        <button type="button" class="tab-btn" data-tab="review">REVIEW</button>
        <button type="button" class="tab-btn" data-tab="qna">Q&A</button>
        <button type="button" class="tab-btn" data-tab="guide">GUIDE</button>
      </div>

      <div class="tab-panel active" data-panel="detail">
        <% if (safeDetailImages.length > 0) { %>
          <div class="detail-images">
            <% safeDetailImages.forEach((img, index) => { %>
              <img src="<%= img %>" alt="상세 이미지 <%= index + 1 %>">
            <% }) %>
          </div>
        <% } else if (safeDesc) { %>
          <div class="guide-text"><%= safeDesc %></div>
        <% } else { %>
          <div class="guide-text">등록된 상세 정보가 없습니다.</div>
        <% } %>
      </div>

      <div class="tab-panel" data-panel="review">
        <div class="guide-text">리뷰 영역은 다음 단계에서 연결</div>
      </div>

      <div class="tab-panel" data-panel="qna">
        <div class="guide-text">Q&A 영역은 다음 단계에서 연결</div>
      </div>

      <div class="tab-panel" data-panel="guide">
        <% if (safeProduct.guide && safeProduct.guide.sizeGuideImage) { %>
          <div class="guide-text" style="margin-bottom: 10px;">사이즈 가이드</div>
          <img src="<%= safeProduct.guide.sizeGuideImage %>" alt="사이즈 가이드" style="width:100%;">
        <% } %>

        <% if (safeProduct.guide && safeProduct.guide.washImage) { %>
          <div class="guide-text" style="margin: 20px 0 10px;">세탁 안내</div>
          <img src="<%= safeProduct.guide.washImage %>" alt="세탁 안내" style="width:100%;">
        <% } %>

        <% if (safeProduct.guide && safeProduct.guide.shippingExchangeReturn) { %>
          <div class="guide-text" style="margin-top:20px;"><%= safeProduct.guide.shippingExchangeReturn %></div>
        <% } %>
      </div>
    </div>
  </div>

  <script>
    const productDataEl = document.getElementById('productData');

    const price = Number(productDataEl?.dataset.price || 0);
    const stock = Number(productDataEl?.dataset.stock || 0);
    const hasColor = productDataEl?.dataset.hasColor === 'true';
    const hasSize = productDataEl?.dataset.hasSize === 'true';

    const colorWrap = document.getElementById('colorWrap');
    const sizeWrap = document.getElementById('sizeWrap');
    const colorButtons = colorWrap ? colorWrap.querySelectorAll('.option-chip') : [];
    const sizeButtons = sizeWrap ? sizeWrap.querySelectorAll('.option-chip') : [];

    const selectedOptionInput = document.getElementById('selectedOptionInput');
    const legacyOptionInput = document.getElementById('legacyOptionInput');
    const selectedColorInput = document.getElementById('selectedColorInput');

    const optionError = document.getElementById('optionError');
    const colorError = document.getElementById('colorError');

    const addOnSelectButtons = document.querySelectorAll('.add-on-select-btn');
    const selectedAddOnIdsInput = document.getElementById('selectedAddOnIdsInput');
    const selectedAddOnNamesInput = document.getElementById('selectedAddOnNamesInput');
    const selectedAddOnTotalInput = document.getElementById('selectedAddOnTotalInput');

    const qtyInput = document.getElementById('qtyInput');
    const quantityHidden = document.getElementById('quantityHidden');
    const minusBtn = document.getElementById('minusBtn');
    const plusBtn = document.getElementById('plusBtn');
    const totalPrice = document.getElementById('totalPrice');
    const selectedMetaText = document.getElementById('selectedMetaText');

    const productForm = document.getElementById('productForm');
    const cartBtn = document.getElementById('cartBtn');
    const buyBtn = document.getElementById('buyBtn');

    const galleryStage = document.getElementById('galleryStage');
    const thumbs = document.getElementById('thumbs');

    const withTrack = document.getElementById('withTrack');
    const withPrev = document.getElementById('withPrev');
    const withNext = document.getElementById('withNext');
    const withPage = document.getElementById('withPage');

    let selectedAddOns = [];
    let withIndex = 0;

    function syncSelections() {
      const colorValue = selectedColorInput ? selectedColorInput.value : '';
      const sizeValue = selectedOptionInput ? selectedOptionInput.value : '';

      const metaParts = [];
      if (colorValue) metaParts.push(`색상: ${colorValue}`);
      if (sizeValue) metaParts.push(`사이즈: ${sizeValue}`);
      if (selectedAddOns.length) metaParts.push(`추가상품: ${selectedAddOns.map(item => item.name).join(', ')}`);

      if (selectedMetaText) {
        selectedMetaText.textContent = metaParts.length ? metaParts.join(' / ') : '옵션을 선택해주세요.';
      }
    }

    function syncAddOnInputs() {
      const ids = selectedAddOns.map(item => item.id);
      const names = selectedAddOns.map(item => item.name);
      const total = selectedAddOns.reduce((sum, item) => sum + item.price, 0);

      if (selectedAddOnIdsInput) selectedAddOnIdsInput.value = ids.join(',');
      if (selectedAddOnNamesInput) selectedAddOnNamesInput.value = names.join(',');
      if (selectedAddOnTotalInput) selectedAddOnTotalInput.value = String(total);

      return total;
    }

    function updateTotal() {
      let qty = Number(qtyInput?.value || 1);

      if (qty < 1) qty = 1;
      if (stock > 0 && qty > stock) qty = stock;

      if (qtyInput) qtyInput.value = qty;
      if (quantityHidden) quantityHidden.value = qty;

      const addOnTotal = syncAddOnInputs();
      const finalTotal = (price * qty) + addOnTotal;

      if (totalPrice) totalPrice.textContent = finalTotal.toLocaleString();
      syncSelections();
    }

    colorButtons.forEach((button) => {
      button.addEventListener('click', function () {
        if (button.dataset.soldout === 'true') return;
        colorButtons.forEach((btn) => btn.classList.remove('active'));
        button.classList.add('active');
        if (selectedColorInput) selectedColorInput.value = button.dataset.color || '';
        if (colorError) colorError.textContent = '';
        syncSelections();
      });
    });

    sizeButtons.forEach((button) => {
      button.addEventListener('click', function () {
        if (button.dataset.soldout === 'true') return;
        sizeButtons.forEach((btn) => btn.classList.remove('active'));
        button.classList.add('active');
        if (selectedOptionInput) selectedOptionInput.value = button.dataset.size || '';
        if (legacyOptionInput) legacyOptionInput.value = button.dataset.size || '';
        if (optionError) optionError.textContent = '';
        syncSelections();
      });
    });

    addOnSelectButtons.forEach((button) => {
      button.addEventListener('click', function () {
        const id = button.dataset.id || '';
        const name = button.dataset.name || '';
        const priceValue = Number(button.dataset.price || 0);
        const exists = selectedAddOns.find(item => item.id === id);

        if (exists) {
          selectedAddOns = selectedAddOns.filter(item => item.id !== id);
          button.textContent = '선택';
          button.style.background = '#fb625f';
        } else {
          selectedAddOns.push({ id, name, price: priceValue });
          button.textContent = '선택됨';
          button.style.background = '#111';
        }

        updateTotal();
      });
    });

    if (minusBtn) {
      minusBtn.addEventListener('click', function () {
        qtyInput.value = Math.max(Number(qtyInput.value || 1) - 1, 1);
        updateTotal();
      });
    }

    if (plusBtn) {
      plusBtn.addEventListener('click', function () {
        const next = Number(qtyInput.value || 1) + 1;
        qtyInput.value = stock > 0 ? Math.min(next, stock) : next;
        updateTotal();
      });
    }

    if (qtyInput) qtyInput.addEventListener('input', updateTotal);

    function validateForm() {
      syncSelections();

      if (hasColor && selectedColorInput && !selectedColorInput.value) {
        if (colorError) colorError.textContent = '색상을 선택해주세요.';
        return false;
      }

      if (hasSize && selectedOptionInput && !selectedOptionInput.value) {
        if (optionError) optionError.textContent = '사이즈를 선택해주세요.';
        return false;
      }

      return true;
    }

    if (cartBtn) {
      cartBtn.addEventListener('click', function () {
        if (!validateForm()) return;
        productForm.action = '/cart/add';
        productForm.submit();
      });
    }

    if (buyBtn) {
      buyBtn.addEventListener('click', function () {
        if (!validateForm()) return;
        productForm.action = '/buy-now';
        productForm.submit();
      });
    }

    if (thumbs && galleryStage) {
      thumbs.addEventListener('click', function (e) {
        const thumb = e.target.closest('.thumb-btn');
        if (!thumb) return;

        const type = thumb.dataset.type;
        const src = thumb.dataset.src;

        if (type === 'video') {
          galleryStage.innerHTML = `<video src="${src}" controls playsinline preload="metadata"></video>`;
        } else {
          galleryStage.innerHTML = `<img src="${src}" alt="상품 이미지">`;
        }

        thumbs.querySelectorAll('.thumb-btn').forEach((item) => item.classList.remove('active'));
        thumb.classList.add('active');
      });
    }

    function moveWith(direction) {
      if (!withTrack) return;

      const cards = withTrack.querySelectorAll('.with-card');
      if (!cards.length) return;

      const cardWidth = cards[0].offsetWidth + 10;
      const viewport = withTrack.parentElement;
      const visibleCount = Math.max(Math.floor(viewport.offsetWidth / cardWidth), 1);
      const totalPages = Math.max(Math.ceil(cards.length / visibleCount), 1);
      const maxIndex = Math.max(cards.length - visibleCount, 0);

      withIndex += direction;
      if (withIndex < 0) withIndex = 0;
      if (withIndex > maxIndex) withIndex = maxIndex;

      withTrack.style.transform = `translateX(-${withIndex * cardWidth}px)`;

      const currentPage = Math.min(Math.floor(withIndex / visibleCount) + 1, totalPages);
      if (withPage) withPage.textContent = `${currentPage}/${totalPages}`;
    }

    if (withPrev) withPrev.addEventListener('click', () => moveWith(-1));
    if (withNext) withNext.addEventListener('click', () => moveWith(1));
    window.addEventListener('resize', () => moveWith(0));

    const tabButtons = document.querySelectorAll('.tab-btn');
    const tabPanels = document.querySelectorAll('.tab-panel');

    tabButtons.forEach((button) => {
      button.addEventListener('click', function () {
        const target = button.dataset.tab;
        tabButtons.forEach((btn) => btn.classList.remove('active'));
        tabPanels.forEach((panel) => panel.classList.remove('active'));
        button.classList.add('active');
        const panel = document.querySelector(`[data-panel="${target}"]`);
        if (panel) panel.classList.add('active');
      });
    });

    updateTotal();
    moveWith(0);
  </script>
</body>
</html>
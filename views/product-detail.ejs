<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= product.name %> | DAMORE</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg: #f8f6f2;
      --white: #ffffff;
      --black: #111111;
      --text: #222222;
      --muted: #7a746c;
      --line: #e9e4db;
      --soft: #f4efe7;
      --soft-2: #faf7f2;
      --point: #9a8463;
      --danger: #c44b3b;
      --shadow: 0 16px 40px rgba(0, 0, 0, 0.05);
      --radius: 20px;
      --max: 1280px;
    }

    body {
      font-family: "Pretendard", "Noto Sans KR", Arial, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    button,
    input,
    select,
    textarea {
      font: inherit;
    }

    img,
    video {
      max-width: 100%;
      display: block;
    }

    .page {
      max-width: var(--max);
      margin: 0 auto;
      padding: 24px 20px 90px;
    }

    .breadcrumb {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      font-size: 12px;
      color: var(--muted);
      margin-bottom: 20px;
    }

    .layout {
      display: grid;
      grid-template-columns: minmax(0, 1.08fr) minmax(360px, 430px);
      gap: 34px;
      align-items: start;
    }

    .gallery-col {
      min-width: 0;
    }

    .gallery-main {
      width: 100%;
      border-radius: 18px;
      overflow: hidden;
      background: #ece7de;
      margin-bottom: 14px;
      box-shadow: var(--shadow);
      aspect-ratio: 1 / 1.22;
    }

    .gallery-main img,
    .gallery-main video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      background: #ece7de;
    }

    .thumbs {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .thumb-btn {
      width: 74px;
      height: 74px;
      padding: 0;
      border: 1px solid var(--line);
      border-radius: 12px;
      overflow: hidden;
      cursor: pointer;
      background: #fff;
    }

    .thumb-btn.active {
      border-color: #111;
    }

    .thumb-btn img,
    .thumb-btn video {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .right-col {
      min-width: 0;
    }

    .purchase-box {
      position: sticky;
      top: 16px;
      background: var(--white);
      border: 1px solid var(--line);
      border-radius: 18px;
      padding: 24px;
      box-shadow: var(--shadow);
    }

    .brand-line {
      font-size: 12px;
      color: var(--point);
      letter-spacing: 0.16em;
      font-weight: 700;
      text-transform: uppercase;
      margin-bottom: 10px;
    }

    .title {
      font-size: 30px;
      line-height: 1.32;
      font-weight: 800;
      word-break: keep-all;
      margin-bottom: 10px;
    }

    .summary {
      color: var(--muted);
      font-size: 14px;
      margin-bottom: 14px;
      white-space: pre-line;
      word-break: keep-all;
    }

    .interest-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 14px;
      font-size: 13px;
    }

    .interest-text {
      color: var(--muted);
    }

    .coupon-btn {
      height: 38px;
      padding: 0 14px;
      border: 1px solid #d8cfbf;
      background: #fff;
      border-radius: 999px;
      cursor: pointer;
      font-size: 12px;
      font-weight: 800;
      color: #111;
      white-space: nowrap;
    }

    .price-area {
      display: flex;
      align-items: flex-end;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 16px;
    }

    .discount-rate {
      font-size: 16px;
      color: var(--danger);
      font-weight: 800;
      margin-bottom: 2px;
    }

    .main-price {
      font-size: 30px;
      font-weight: 900;
      line-height: 1;
    }

    .old-price {
      font-size: 15px;
      color: #999;
      text-decoration: line-through;
      margin-bottom: 2px;
    }

    .product-table {
      width: 100%;
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
      margin-bottom: 18px;
    }

    .product-table tr + tr {
      border-top: 1px solid var(--line);
    }

    .product-table th,
    .product-table td {
      padding: 11px 0;
      vertical-align: top;
      font-size: 13px;
      text-align: left;
    }

    .product-table th {
      width: 108px;
      color: var(--muted);
      font-weight: 700;
      padding-right: 10px;
    }

    .product-table td {
      color: #222;
      font-weight: 600;
      word-break: keep-all;
    }

    .form-group {
      margin-bottom: 14px;
    }

    .label {
      display: block;
      margin-bottom: 8px;
      font-size: 13px;
      font-weight: 800;
      color: #222;
    }

    .select-box,
    .qty-input {
      width: 100%;
      height: 46px;
      border: 1px solid #dcd4c7;
      border-radius: 10px;
      padding: 0 14px;
      background: #fff;
      outline: none;
      font-size: 14px;
    }

    .qty-row {
      display: flex;
      gap: 10px;
      align-items: center;
    }

    .qty-btn {
      width: 42px;
      height: 42px;
      border: 1px solid #dcd4c7;
      background: #fff;
      border-radius: 10px;
      cursor: pointer;
      font-size: 18px;
      font-weight: 800;
      flex-shrink: 0;
    }

    .qty-input {
      text-align: center;
      flex: 1;
      padding: 0;
    }

    .with-item-mini {
      margin-top: 12px;
      padding: 14px;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: var(--soft-2);
    }

    .with-item-mini-title {
      font-size: 13px;
      font-weight: 800;
      margin-bottom: 10px;
    }

    .with-item-mini-list {
      display: grid;
      gap: 10px;
    }

    .with-item-mini-card {
      display: flex;
      gap: 10px;
      align-items: center;
      border: 1px solid var(--line);
      background: #fff;
      border-radius: 12px;
      padding: 10px;
    }

    .with-item-mini-check {
      width: 18px;
      height: 18px;
      flex-shrink: 0;
      cursor: pointer;
    }

    .with-item-mini-thumb {
      width: 56px;
      height: 56px;
      object-fit: cover;
      border-radius: 10px;
      background: #ece7de;
      flex-shrink: 0;
    }

    .with-item-mini-info {
      min-width: 0;
      flex: 1;
    }

    .with-item-mini-name {
      font-size: 13px;
      font-weight: 700;
      line-height: 1.45;
      word-break: keep-all;
    }

    .with-item-mini-price {
      font-size: 12px;
      color: var(--muted);
      margin-top: 2px;
    }

    .total-box {
      margin-top: 16px;
      padding: 16px;
      border-radius: 14px;
      background: var(--soft);
    }

    .total-label {
      font-size: 12px;
      color: var(--muted);
      margin-bottom: 6px;
      font-weight: 700;
    }

    .total-price {
      font-size: 28px;
      font-weight: 900;
      line-height: 1;
    }

    .error-text {
      min-height: 18px;
      margin-top: 6px;
      font-size: 12px;
      color: var(--danger);
      font-weight: 700;
    }

    .action-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-top: 14px;
    }

    .action-btn {
      height: 50px;
      border: 0;
      border-radius: 12px;
      cursor: pointer;
      font-size: 14px;
      font-weight: 800;
    }

    .btn-soft {
      background: #ece5d9;
      color: #111;
    }

    .btn-dark {
      background: #111;
      color: #fff;
    }

    .wide-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-top: 10px;
    }

    .btn-line {
      height: 48px;
      border-radius: 12px;
      border: 1px solid #d8cfbf;
      background: #fff;
      cursor: pointer;
      font-size: 14px;
      font-weight: 800;
    }

    .btn-npay {
      background: #00c73c;
      color: #fff;
      border: 0;
    }

    .section {
      margin-top: 34px;
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 18px;
      padding: 28px;
      box-shadow: var(--shadow);
    }

    .tab-nav {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 20px;
    }

    .tab-btn {
      min-height: 40px;
      padding: 0 14px;
      border-radius: 999px;
      border: 1px solid #d8cfbf;
      background: #fff;
      cursor: pointer;
      font-size: 13px;
      font-weight: 800;
    }

    .tab-btn.active {
      background: #111;
      color: #fff;
      border-color: #111;
    }

    .tab-panel {
      display: none;
    }

    .tab-panel.active {
      display: block;
    }

    .section-title {
      font-size: 24px;
      font-weight: 800;
      margin-bottom: 18px;
    }

    .detail-images {
      display: grid;
      gap: 18px;
    }

    .detail-images img {
      width: 100%;
      border-radius: 16px;
    }

    .guide-block + .guide-block {
      margin-top: 28px;
    }

    .guide-label {
      font-size: 14px;
      font-weight: 800;
      margin-bottom: 10px;
    }

    .guide-text {
      font-size: 14px;
      color: #555;
      white-space: pre-line;
      word-break: keep-all;
    }

    .review-summary {
      display: grid;
      grid-template-columns: 220px 1fr;
      gap: 24px;
      align-items: center;
      margin-bottom: 24px;
    }

    .review-score-box {
      background: var(--soft-2);
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 20px;
      text-align: center;
    }

    .review-score {
      font-size: 40px;
      font-weight: 900;
      line-height: 1;
      margin-bottom: 8px;
    }

    .star-row {
      display: flex;
      justify-content: center;
      gap: 2px;
      color: #c7a867;
      font-size: 18px;
      margin-bottom: 8px;
    }

    .review-count {
      font-size: 13px;
      color: var(--muted);
      font-weight: 700;
    }

    .review-list,
    .inquiry-list,
    .with-item-bottom-list {
      display: grid;
      gap: 14px;
    }

    .review-item,
    .inquiry-item {
      border: 1px solid var(--line);
      border-radius: 14px;
      background: var(--soft-2);
      padding: 16px;
    }

    .review-head,
    .inquiry-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 8px;
    }

    .review-author,
    .inquiry-author {
      font-size: 13px;
      font-weight: 800;
    }

    .review-date,
    .inquiry-date {
      font-size: 12px;
      color: #888;
    }

    .review-body,
    .inquiry-body {
      font-size: 14px;
      color: #555;
      white-space: pre-line;
      word-break: keep-all;
    }

    .inquiry-form {
      display: grid;
      gap: 10px;
      margin-top: 18px;
      padding-top: 18px;
      border-top: 1px solid var(--line);
    }

    .text-input,
    .text-area {
      width: 100%;
      border: 1px solid #dcd4c7;
      border-radius: 10px;
      padding: 13px 14px;
      outline: none;
      background: #fff;
    }

    .text-area {
      min-height: 120px;
      resize: vertical;
    }

    .submit-btn {
      height: 46px;
      border: 0;
      border-radius: 10px;
      background: #111;
      color: #fff;
      cursor: pointer;
      font-weight: 800;
    }

    .with-item-bottom-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 16px;
    }

    .with-item-bottom-card {
      display: block;
      border: 1px solid var(--line);
      border-radius: 14px;
      overflow: hidden;
      background: #fff;
    }

    .with-item-bottom-thumb {
      width: 100%;
      aspect-ratio: 1 / 1.18;
      object-fit: cover;
      background: #ece7de;
    }

    .with-item-bottom-info {
      padding: 12px;
    }

    .with-item-bottom-name {
      font-size: 13px;
      font-weight: 700;
      line-height: 1.45;
      min-height: 38px;
      word-break: keep-all;
      margin-bottom: 6px;
    }

    .with-item-bottom-price {
      font-size: 14px;
      font-weight: 900;
    }

    .empty {
      color: #777;
      font-size: 14px;
    }

    @media (max-width: 1024px) {
      .layout {
        grid-template-columns: 1fr;
      }

      .purchase-box {
        position: static;
      }

      .review-summary {
        grid-template-columns: 1fr;
      }

      .with-item-bottom-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 640px) {
      .page {
        padding: 16px 14px 70px;
      }

      .purchase-box,
      .section {
        padding: 20px;
      }

      .title {
        font-size: 26px;
      }

      .main-price {
        font-size: 28px;
      }

      .total-price {
        font-size: 24px;
      }

      .action-grid,
      .wide-grid {
        grid-template-columns: 1fr;
      }

      .with-item-bottom-grid {
        grid-template-columns: 1fr 1fr;
        gap: 12px;
      }
    }
  </style>
</head>
<body>
  <%
    const safeSubImages = Array.isArray(product.subImages) ? product.subImages.filter(Boolean) : [];
    const safeDetailImages = Array.isArray(product.detailImages) ? product.detailImages.filter(Boolean) : [];
    const safeDesc = product.desc || product.description || '';
    const safeSummary = product.summary || '';
    const isSoldOut = product.status === 'soldout' || Number(product.stock || 0) <= 0;
    const safeAddOnProducts = Array.isArray(addOnProducts) ? addOnProducts : [];
    const safeOptionGroups = Array.isArray(product.optionGroups) ? product.optionGroups.filter(Boolean) : [];

    let colorGroup = null;
    let sizeGroup = null;

    if (safeOptionGroups.length >= 1) colorGroup = safeOptionGroups[0];
    if (safeOptionGroups.length >= 2) sizeGroup = safeOptionGroups[1];

    if (!sizeGroup && colorGroup && /size|사이즈/i.test(colorGroup.name || '')) {
      sizeGroup = colorGroup;
      colorGroup = null;
    }

    const galleryItems = [];
    if (product.image) galleryItems.push({ type: 'image', src: product.image });
    if (product.video) galleryItems.push({ type: 'video', src: product.video });

    safeSubImages.forEach((img) => {
      if (!galleryItems.find((item) => item.src === img)) {
        galleryItems.push({ type: 'image', src: img });
      }
    });

    const discountRate =
      Number(product.oldPrice || 0) > Number(product.price || 0)
        ? Math.round((1 - Number(product.price || 0) / Number(product.oldPrice || 0)) * 100)
        : 0;

    const rewardPoint = Math.floor(Number(product.price || 0) * 0.01);
    const 관심수 = Math.max(Number(product.likeCount || 0), 12);

    const reviewSamples = [
      {
        author: 'damore***',
        date: '2026-04-18',
        rating: 5,
        body: '핏이 예쁘고 실제로 받아보니 원단도 좋아요. 데일리룩으로 손이 자주 갑니다.'
      },
      {
        author: 'style***',
        date: '2026-04-16',
        rating: 4,
        body: '컬러감이 화면이랑 거의 비슷하고 사이즈도 정사이즈 느낌이에요.'
      }
    ];

    const inquirySamples = [
      {
        author: 'guest***',
        date: '2026-04-20',
        title: '배송 문의',
        body: '오늘 주문하면 언제쯤 출고되나요?'
      },
      {
        author: 'look***',
        date: '2026-04-19',
        title: '사이즈 문의',
        body: '평소 55~66 입는데 어떤 사이즈가 좋을까요?'
      }
    ];
  %>

  <div
    id="productData"
    data-price="<%= Number(product.price || 0) %>"
    data-stock="<%= Number(product.stock || 0) %>"
    data-has-color="<%= colorGroup && Array.isArray(colorGroup.values) && colorGroup.values.length > 0 ? 'true' : 'false' %>"
    data-has-size="<%= sizeGroup && Array.isArray(sizeGroup.values) && sizeGroup.values.length > 0 ? 'true' : 'false' %>"
  ></div>

  <div class="page">
    <div class="breadcrumb">
      <a href="/">HOME</a>
      <% if (product.category) { %>
        <span>/</span>
        <a href="/category/<%= product.category %>"><%= product.category %></a>
      <% } %>
      <span>/</span>
      <span><%= product.name %></span>
    </div>

    <div class="layout">
      <div class="gallery-col">
        <div class="gallery-main" id="galleryStage">
          <% if (galleryItems.length > 0) { %>
            <% if (galleryItems[0].type === 'video') { %>
              <video src="<%= galleryItems[0].src %>" controls playsinline preload="metadata"></video>
            <% } else { %>
              <img src="<%= galleryItems[0].src %>" alt="<%= product.name %>">
            <% } %>
          <% } %>
        </div>

        <% if (galleryItems.length > 1) { %>
          <div class="thumbs" id="thumbs">
            <% galleryItems.forEach((item, index) => { %>
              <button
                type="button"
                class="thumb-btn <%= index === 0 ? 'active' : '' %>"
                data-type="<%= item.type %>"
                data-src="<%= item.src %>"
              >
                <% if (item.type === 'video') { %>
                  <video src="<%= item.src %>" muted playsinline preload="metadata"></video>
                <% } else { %>
                  <img src="<%= item.src %>" alt="썸네일">
                <% } %>
              </button>
            <% }) %>
          </div>
        <% } %>
      </div>

      <div class="right-col">
        <div class="purchase-box">
          <div class="brand-line">DAMORE</div>
          <div class="title"><%= product.name %></div>

          <% if (safeSummary) { %>
            <div class="summary"><%= safeSummary %></div>
          <% } %>

          <div class="interest-row">
            <div class="interest-text">지금 <strong><%= 관심수.toLocaleString() %>명</strong>이 관심있게 보고 있어요</div>
            <button type="button" class="coupon-btn" onclick="alert('쿠폰 다운로드 기능은 다음 단계에서 연결')">
              할인쿠폰 받기
            </button>
          </div>

          <div class="price-area">
            <% if (discountRate > 0) { %>
              <div class="discount-rate"><%= discountRate %>%</div>
            <% } %>
            <div class="main-price"><%= Number(product.price || 0).toLocaleString() %>원</div>
            <% if (Number(product.oldPrice || 0) > 0) { %>
              <div class="old-price"><%= Number(product.oldPrice || 0).toLocaleString() %>원</div>
            <% } %>
          </div>

          <table class="product-table">
            <tbody>
              <tr>
                <th>상품요약정보</th>
                <td><%= safeSummary || product.name %></td>
              </tr>
              <tr>
                <th>적립금</th>
                <td><%= rewardPoint.toLocaleString() %>원 (1%)</td>
              </tr>
              <tr>
                <th>배송비</th>
                <td><%= product.shippingFeeText || '3,000원 (70,000원 이상 무료배송)' %></td>
              </tr>
              <tr>
                <th>상품상태</th>
                <td><%= isSoldOut ? '품절' : '구매가능' %></td>
              </tr>
            </tbody>
          </table>

          <form id="productForm" method="POST">
            <input type="hidden" name="productId" value="<%= product._id %>">
            <input type="hidden" name="selectedOption" id="selectedOptionInput" value="">
            <input type="hidden" name="option" id="legacyOptionInput" value="">
            <input type="hidden" name="selectedColor" id="selectedColorInput" value="">
            <input type="hidden" name="quantity" id="quantityHidden" value="1">
            <input type="hidden" name="selectedAddOnIds" id="selectedAddOnIdsInput" value="">
            <input type="hidden" name="selectedAddOnNames" id="selectedAddOnNamesInput" value="">
            <input type="hidden" name="selectedAddOnTotal" id="selectedAddOnTotalInput" value="0">

            <% if (colorGroup && Array.isArray(colorGroup.values) && colorGroup.values.length > 0) { %>
              <div class="form-group">
                <label class="label"><%= colorGroup.name || '색상' %></label>
                <select id="colorSelect" class="select-box">
                  <option value="">색상을 선택해주세요</option>
                  <% colorGroup.values.forEach((item) => { %>
                    <option
                      value="<%= item.value %>"
                      <%= item.isSoldOut ? 'disabled' : '' %>
                    >
                      <%= item.value %><%= item.isSoldOut ? ' (품절)' : '' %>
                    </option>
                  <% }) %>
                </select>
                <div class="error-text" id="colorError"></div>
              </div>
            <% } %>

            <% if (sizeGroup && Array.isArray(sizeGroup.values) && sizeGroup.values.length > 0) { %>
              <div class="form-group">
                <label class="label"><%= sizeGroup.name || '사이즈' %></label>
                <select id="sizeSelect" class="select-box">
                  <option value="">사이즈를 선택해주세요</option>
                  <% sizeGroup.values.forEach((item) => { %>
                    <option
                      value="<%= item.value %>"
                      <%= item.isSoldOut ? 'disabled' : '' %>
                    >
                      <%= item.value %><%= item.isSoldOut ? ' (품절)' : '' %>
                    </option>
                  <% }) %>
                </select>
                <div class="error-text" id="optionError"></div>
              </div>
            <% } %>

            <div class="form-group">
              <label class="label">수량</label>
              <div class="qty-row">
                <button type="button" class="qty-btn" id="minusBtn">-</button>
                <input
                  type="number"
                  class="qty-input"
                  id="qtyInput"
                  value="1"
                  min="1"
                  max="<%= Math.max(Number(product.stock || 1), 1) %>"
                />
                <button type="button" class="qty-btn" id="plusBtn">+</button>
              </div>
            </div>

            <% if (safeAddOnProducts.length > 0) { %>
              <div class="with-item-mini">
                <div class="with-item-mini-title">WITH ITEM</div>
                <div class="with-item-mini-list" id="addOnList">
                  <% safeAddOnProducts.forEach((item) => { %>
                    <label class="with-item-mini-card">
                      <input
                        type="checkbox"
                        class="with-item-mini-check add-on-check"
                        data-id="<%= item._id %>"
                        data-name="<%= item.name %>"
                        data-price="<%= Number(item.price || 0) %>"
                      >
                      <% if (item.image) { %>
                        <img src="<%= item.image %>" alt="<%= item.name %>" class="with-item-mini-thumb">
                      <% } else { %>
                        <div class="with-item-mini-thumb"></div>
                      <% } %>
                      <div class="with-item-mini-info">
                        <div class="with-item-mini-name"><%= item.name %></div>
                        <div class="with-item-mini-price"><%= Number(item.price || 0).toLocaleString() %>원</div>
                      </div>
                    </label>
                  <% }) %>
                </div>
              </div>
            <% } %>

            <div class="total-box">
              <div class="total-label">TOTAL</div>
              <div class="total-price" id="totalPrice"><%= Number(product.price || 0).toLocaleString() %>원</div>
            </div>

            <div class="action-grid">
              <button
                type="button"
                class="action-btn btn-soft"
                id="cartBtn"
                <%= isSoldOut ? 'disabled' : '' %>
              >
                장바구니
              </button>
              <button
                type="button"
                class="action-btn btn-dark"
                id="buyBtn"
                <%= isSoldOut ? 'disabled' : '' %>
              >
                바로구매
              </button>
            </div>

            <div class="wide-grid">
              <button
                type="button"
                class="btn-line btn-npay"
                onclick="alert('네이버페이 구매는 다음 단계에서 연결')"
                <%= isSoldOut ? 'disabled' : '' %>
              >
                네이버페이 구매
              </button>
              <button
                type="button"
                class="btn-line"
                onclick="alert('찜 기능은 다음 단계에서 연결')"
              >
                찜
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <div class="section">
      <div class="tab-nav">
        <button type="button" class="tab-btn active" data-tab="detail">상세정보</button>
        <button type="button" class="tab-btn" data-tab="review">리뷰</button>
        <button type="button" class="tab-btn" data-tab="inquiry">문의</button>
      </div>

      <div class="tab-panel active" data-panel="detail">
        <div class="section-title">상품 상세정보</div>

        <% if (safeDetailImages.length > 0) { %>
          <div class="detail-images">
            <% safeDetailImages.forEach((img, index) => { %>
              <img src="<%= img %>" alt="상세 이미지 <%= index + 1 %>">
            <% }) %>
          </div>
        <% } else if (safeDesc) { %>
          <div class="guide-text"><%= safeDesc %></div>
        <% } else { %>
          <div class="empty">등록된 상세 정보가 없습니다.</div>
        <% } %>

        <% if (
          (product.guide && product.guide.sizeGuideImage) ||
          (product.guide && product.guide.washImage) ||
          (product.guide && product.guide.shippingExchangeReturn) ||
          (product.guide && product.guide.copyrightNotice)
        ) { %>
          <div style="margin-top: 30px;">
            <% if (product.guide && product.guide.sizeGuideImage) { %>
              <div class="guide-block">
                <div class="guide-label">사이즈 가이드</div>
                <img src="<%= product.guide.sizeGuideImage %>" alt="사이즈 가이드" style="border-radius:16px;">
              </div>
            <% } %>

            <% if (product.guide && product.guide.washImage) { %>
              <div class="guide-block">
                <div class="guide-label">세탁 안내</div>
                <img src="<%= product.guide.washImage %>" alt="세탁 안내" style="border-radius:16px;">
              </div>
            <% } %>

            <% if (product.guide && product.guide.shippingExchangeReturn) { %>
              <div class="guide-block">
                <div class="guide-label">배송 / 교환 / 반품 안내</div>
                <div class="guide-text"><%= product.guide.shippingExchangeReturn %></div>
              </div>
            <% } %>

            <% if (product.guide && product.guide.copyrightNotice) { %>
              <div class="guide-block">
                <div class="guide-label">저작권 안내</div>
                <div class="guide-text"><%= product.guide.copyrightNotice %></div>
              </div>
            <% } %>
          </div>
        <% } %>
      </div>

      <div class="tab-panel" data-panel="review">
        <div class="section-title">리뷰</div>

        <div class="review-summary">
          <div class="review-score-box">
            <div class="review-score">4.8</div>
            <div class="star-row">★★★★★</div>
            <div class="review-count">총 <%= Number(product.reviewCount || reviewSamples.length) %>개 리뷰</div>
          </div>

          <div class="guide-text">
            실제 구매 고객 기준으로 핏, 원단, 컬러 만족도가 높은 상품입니다.
          </div>
        </div>

        <div class="review-list">
          <% reviewSamples.forEach((review) => { %>
            <div class="review-item">
              <div class="review-head">
                <div class="review-author"><%= review.author %></div>
                <div class="review-date"><%= review.date %></div>
              </div>
              <div class="star-row" style="justify-content:flex-start; margin-bottom:10px;">
                <% for (let i = 0; i < review.rating; i++) { %>★<% } %>
              </div>
              <div class="review-body"><%= review.body %></div>
            </div>
          <% }) %>
        </div>
      </div>

      <div class="tab-panel" data-panel="inquiry">
        <div class="section-title">문의</div>

        <div class="inquiry-list">
          <% inquirySamples.forEach((item) => { %>
            <div class="inquiry-item">
              <div class="inquiry-head">
                <div class="inquiry-author"><%= item.author %> · <%= item.title %></div>
                <div class="inquiry-date"><%= item.date %></div>
              </div>
              <div class="inquiry-body"><%= item.body %></div>
            </div>
          <% }) %>
        </div>

        <form class="inquiry-form" onsubmit="event.preventDefault(); alert('문의 저장 기능은 다음 단계에서 연결')">
          <input class="text-input" type="text" placeholder="문의 제목">
          <textarea class="text-area" placeholder="문의 내용을 입력하세요"></textarea>
          <button class="submit-btn" type="submit">문의 등록</button>
        </form>
      </div>
    </div>

    <% if (safeAddOnProducts.length > 0) { %>
      <div class="section">
        <div class="section-title">WITH ITEM</div>
        <div class="with-item-bottom-grid">
          <% safeAddOnProducts.forEach((item) => { %>
            <a class="with-item-bottom-card" href="/products/<%= item._id %>">
              <% if (item.image) { %>
                <img class="with-item-bottom-thumb" src="<%= item.image %>" alt="<%= item.name %>">
              <% } else { %>
                <div class="with-item-bottom-thumb"></div>
              <% } %>
              <div class="with-item-bottom-info">
                <div class="with-item-bottom-name"><%= item.name %></div>
                <div class="with-item-bottom-price"><%= Number(item.price || 0).toLocaleString() %>원</div>
              </div>
            </a>
          <% }) %>
        </div>
      </div>
    <% } %>
  </div>

  <script>
    const productDataEl = document.getElementById('productData');

    const price = Number(productDataEl?.dataset.price || 0);
    const stock = Number(productDataEl?.dataset.stock || 0);
    const hasColor = productDataEl?.dataset.hasColor === 'true';
    const hasSize = productDataEl?.dataset.hasSize === 'true';

    const colorSelect = document.getElementById('colorSelect');
    const sizeSelect = document.getElementById('sizeSelect');

    const selectedOptionInput = document.getElementById('selectedOptionInput');
    const legacyOptionInput = document.getElementById('legacyOptionInput');
    const selectedColorInput = document.getElementById('selectedColorInput');

    const optionError = document.getElementById('optionError');
    const colorError = document.getElementById('colorError');

    const addOnChecks = document.querySelectorAll('.add-on-check');
    const selectedAddOnIdsInput = document.getElementById('selectedAddOnIdsInput');
    const selectedAddOnNamesInput = document.getElementById('selectedAddOnNamesInput');
    const selectedAddOnTotalInput = document.getElementById('selectedAddOnTotalInput');

    const qtyInput = document.getElementById('qtyInput');
    const quantityHidden = document.getElementById('quantityHidden');
    const minusBtn = document.getElementById('minusBtn');
    const plusBtn = document.getElementById('plusBtn');
    const totalPrice = document.getElementById('totalPrice');

    const productForm = document.getElementById('productForm');
    const cartBtn = document.getElementById('cartBtn');
    const buyBtn = document.getElementById('buyBtn');

    const galleryStage = document.getElementById('galleryStage');
    const thumbs = document.getElementById('thumbs');

    function syncSelections() {
      if (sizeSelect && selectedOptionInput) {
        selectedOptionInput.value = sizeSelect.value;
        legacyOptionInput.value = sizeSelect.value;
      }

      if (colorSelect && selectedColorInput) {
        selectedColorInput.value = colorSelect.value;
      }
    }

    function getSelectedAddOnTotal() {
      let sum = 0;
      addOnChecks.forEach((check) => {
        if (check.checked) {
          sum += Number(check.dataset.price || 0);
        }
      });
      return sum;
    }

    function syncAddOnInputs() {
      const ids = [];
      const names = [];
      let total = 0;

      addOnChecks.forEach((check) => {
        if (check.checked) {
          ids.push(check.dataset.id || '');
          names.push(check.dataset.name || '');
          total += Number(check.dataset.price || 0);
        }
      });

      if (selectedAddOnIdsInput) selectedAddOnIdsInput.value = ids.join(',');
      if (selectedAddOnNamesInput) selectedAddOnNamesInput.value = names.join(',');
      if (selectedAddOnTotalInput) selectedAddOnTotalInput.value = String(total);
    }

    function updateTotal() {
      let qty = Number(qtyInput?.value || 1);

      if (qty < 1) qty = 1;
      if (stock > 0 && qty > stock) qty = stock;

      if (qtyInput) qtyInput.value = qty;
      if (quantityHidden) quantityHidden.value = qty;

      const addOnTotal = getSelectedAddOnTotal();
      const finalTotal = (price * qty) + addOnTotal;

      if (totalPrice) {
        totalPrice.textContent = finalTotal.toLocaleString() + '원';
      }

      syncSelections();
      syncAddOnInputs();
    }

    if (colorSelect) {
      colorSelect.addEventListener('change', function () {
        if (colorError) colorError.textContent = '';
        syncSelections();
      });
    }

    if (sizeSelect) {
      sizeSelect.addEventListener('change', function () {
        if (optionError) optionError.textContent = '';
        syncSelections();
      });
    }

    if (minusBtn) {
      minusBtn.addEventListener('click', function () {
        qtyInput.value = Math.max(Number(qtyInput.value || 1) - 1, 1);
        updateTotal();
      });
    }

    if (plusBtn) {
      plusBtn.addEventListener('click', function () {
        const next = Number(qtyInput.value || 1) + 1;
        qtyInput.value = stock > 0 ? Math.min(next, stock) : next;
        updateTotal();
      });
    }

    if (qtyInput) {
      qtyInput.addEventListener('input', updateTotal);
    }

    addOnChecks.forEach((check) => {
      check.addEventListener('change', updateTotal);
    });

    function validateForm() {
      syncSelections();

      if (hasColor && selectedColorInput && !selectedColorInput.value) {
        if (colorError) colorError.textContent = '색상을 선택해주세요.';
        return false;
      }

      if (hasSize && selectedOptionInput && !selectedOptionInput.value) {
        if (optionError) optionError.textContent = '사이즈를 선택해주세요.';
        return false;
      }

      return true;
    }

    if (cartBtn) {
      cartBtn.addEventListener('click', function () {
        if (!validateForm()) return;
        productForm.action = '/cart/add';
        productForm.submit();
      });
    }

    if (buyBtn) {
      buyBtn.addEventListener('click', function () {
        if (!validateForm()) return;
        productForm.action = '/buy-now';
        productForm.submit();
      });
    }

    if (thumbs && galleryStage) {
      thumbs.addEventListener('click', function (e) {
        const thumb = e.target.closest('.thumb-btn');
        if (!thumb) return;

        const type = thumb.dataset.type;
        const src = thumb.dataset.src;

        if (type === 'video') {
          galleryStage.innerHTML = `<video src="${src}" controls playsinline preload="metadata"></video>`;
        } else {
          galleryStage.innerHTML = `<img src="${src}" alt="상품 이미지">`;
        }

        thumbs.querySelectorAll('.thumb-btn').forEach((item) => {
          item.classList.remove('active');
        });
        thumb.classList.add('active');
      });
    }

    const tabButtons = document.querySelectorAll('.tab-btn');
    const tabPanels = document.querySelectorAll('.tab-panel');

    tabButtons.forEach((button) => {
      button.addEventListener('click', function () {
        const target = button.dataset.tab;

        tabButtons.forEach((btn) => btn.classList.remove('active'));
        tabPanels.forEach((panel) => panel.classList.remove('active'));

        button.classList.add('active');
        const panel = document.querySelector(`[data-panel="${target}"]`);
        if (panel) panel.classList.add('active');
      });
    });

    updateTotal();
  </script>
</body>
</html>
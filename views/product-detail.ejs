<%
  const safeProduct = (typeof product !== 'undefined' && product) ? product : {};
  const safeAddOnProducts =
    (typeof addOnProducts !== 'undefined' && Array.isArray(addOnProducts))
      ? addOnProducts.filter(Boolean)
      : [];

  const safeName = safeProduct.name || '상품명';
  const safePrice = Number(safeProduct.price || 0);
  const safeOldPrice = Number(safeProduct.oldPrice || safeProduct.price || 0);
  const safeStock = Number(safeProduct.stock || 0);
  const safeStatus = safeProduct.status || '';
  const safeSummary = safeProduct.summary || '';
  const safeDesc = safeProduct.desc || safeProduct.description || '';
  const safeSubImages = Array.isArray(safeProduct.subImages) ? safeProduct.subImages.filter(Boolean) : [];
  const safeDetailImages = Array.isArray(safeProduct.detailImages) ? safeProduct.detailImages.filter(Boolean) : [];
  const safeOptionGroups = Array.isArray(safeProduct.optionGroups) ? safeProduct.optionGroups.filter(Boolean) : [];
  const safeGuide = safeProduct.guide || {};

  let colorGroup = null;
  let sizeGroup = null;

  if (safeOptionGroups.length >= 1) colorGroup = safeOptionGroups[0];
  if (safeOptionGroups.length >= 2) sizeGroup = safeOptionGroups[1];

  const galleryItems = [];
  if (safeProduct.image) galleryItems.push({ type: 'image', src: safeProduct.image });
  if (safeProduct.video) galleryItems.push({ type: 'video', src: safeProduct.video });

  safeSubImages.forEach((img) => {
    if (!galleryItems.find((item) => item.src === img)) {
      galleryItems.push({ type: 'image', src: img });
    }
  });

  const discountRate =
    safeOldPrice > safePrice && safeOldPrice > 0
      ? Math.round((1 - safePrice / safeOldPrice) * 100)
      : 0;

  const rewardPoint = Math.floor(safePrice * 0.01);
  const interestCount = Math.max(Number(safeProduct.likeCount || 0), 238);
  const isSoldOut = safeStatus === 'soldout' || safeStock <= 0;
  const modelInfo = safeProduct.modelInfo || '신혜성 178cm / 70kg (상의 100~105 / 하의 30~31)';
  const shippingText = safeProduct.shippingFeeText || '무료배송';
  const hasColorGroup = !!(colorGroup && Array.isArray(colorGroup.values) && colorGroup.values.length > 0);
  const hasSizeGroup = !!(sizeGroup && Array.isArray(sizeGroup.values) && sizeGroup.values.length > 0);

  const weeklyProducts = safeAddOnProducts.slice(0, 4).map((item) => {
    const currentPrice = Number(item && item.price ? item.price : 0);
    const originalPrice = Number(item && item.oldPrice ? item.oldPrice : 0);
    const weeklyDiscountRate =
      originalPrice > currentPrice && originalPrice > 0
        ? Math.round((1 - currentPrice / originalPrice) * 100)
        : 0;

    return {
      _id: item && item._id ? item._id : '',
      name: item && item.name ? item.name : '상품명',
      image: item && item.image ? item.image : '',
      price: currentPrice,
      originalPrice,
      discountRate: weeklyDiscountRate
    };
  });
%>


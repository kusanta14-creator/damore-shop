<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= product.name %> | DAMORE</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg: #f7f4ef;
      --card: #ffffff;
      --text: #111111;
      --muted: #6e675f;
      --line: rgba(17, 17, 17, 0.08);
      --soft: #f3ede4;
      --beige: #ede4d8;
      --point: #9d8660;
      --danger: #b23a2c;
      --shadow: 0 18px 44px rgba(0, 0, 0, 0.06);
      --radius: 24px;
      --max: 1280px;
    }

    body {
      font-family: "Pretendard", "Noto Sans KR", Arial, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    button,
    input,
    textarea,
    select {
      font: inherit;
    }

    img,
    video {
      max-width: 100%;
      display: block;
    }

    .page {
      max-width: var(--max);
      margin: 0 auto;
      padding: 28px 20px 90px;
    }

    .breadcrumb {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      font-size: 13px;
      color: var(--muted);
      margin-bottom: 22px;
    }

    .breadcrumb a:hover {
      color: var(--text);
    }

    .layout {
      display: grid;
      grid-template-columns: 1.08fr 0.92fr;
      gap: 34px;
      align-items: start;
    }

    .gallery-column {
      min-width: 0;
    }

    .gallery-main {
      width: 100%;
      border-radius: 26px;
      overflow: hidden;
      background: #ede7dc;
      aspect-ratio: 1 / 1.22;
      margin-bottom: 14px;
      box-shadow: var(--shadow);
    }

    .gallery-main img,
    .gallery-main video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      background: #ede7dc;
    }

    .thumbs {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .thumb-btn {
      width: 78px;
      height: 78px;
      border-radius: 16px;
      overflow: hidden;
      border: 2px solid transparent;
      padding: 0;
      cursor: pointer;
      background: #ede7dc;
      flex-shrink: 0;
    }

    .thumb-btn.active {
      border-color: #111;
    }

    .thumb-btn img,
    .thumb-btn video {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .purchase-column {
      min-width: 0;
    }

    .purchase-card {
      position: sticky;
      top: 20px;
      background: var(--card);
      border-radius: 28px;
      padding: 30px;
      box-shadow: var(--shadow);
    }

    .category {
      display: inline-block;
      margin-bottom: 10px;
      color: var(--point);
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    .title {
      font-size: 34px;
      line-height: 1.28;
      font-weight: 900;
      word-break: keep-all;
      margin-bottom: 10px;
    }

    .summary {
      color: var(--muted);
      font-size: 14px;
      white-space: pre-line;
      word-break: keep-all;
      margin-bottom: 16px;
    }

    .tag-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 18px;
    }

    .chip {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 32px;
      padding: 0 12px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 800;
    }

    .chip.dark {
      background: #111;
      color: #fff;
    }

    .chip.soft {
      background: #f6efe5;
      color: #876338;
    }

    .price-wrap {
      display: flex;
      align-items: flex-end;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 20px;
    }

    .discount-rate {
      font-size: 16px;
      font-weight: 900;
      color: var(--danger);
      margin-bottom: 2px;
    }

    .main-price {
      font-size: 34px;
      font-weight: 900;
      line-height: 1;
    }

    .old-price {
      font-size: 16px;
      color: #999;
      text-decoration: line-through;
      margin-bottom: 3px;
    }

    .benefit-box {
      display: grid;
      gap: 10px;
      padding: 16px;
      border-radius: 20px;
      background: #faf7f2;
      border: 1px solid var(--line);
      margin-bottom: 18px;
    }

    .benefit-row {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      font-size: 14px;
      align-items: center;
    }

    .benefit-row span {
      color: var(--muted);
    }

    .benefit-row strong {
      font-weight: 800;
      text-align: right;
      word-break: keep-all;
    }

    .stock-text {
      font-size: 14px;
      font-weight: 800;
      margin-bottom: 18px;
    }

    .stock-text.soldout {
      color: var(--danger);
    }

    .desc {
      font-size: 14px;
      color: #555;
      white-space: pre-line;
      word-break: keep-all;
      margin-bottom: 20px;
    }

    .divider {
      height: 1px;
      background: var(--line);
      margin: 20px 0;
    }

    .form-group {
      margin-bottom: 18px;
    }

    .label {
      display: block;
      font-size: 14px;
      font-weight: 800;
      margin-bottom: 10px;
    }

    .option-wrap {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .option-btn,
    .color-btn {
      min-width: 76px;
      min-height: 44px;
      padding: 10px 16px;
      border-radius: 999px;
      border: 1px solid #ddd3c5;
      background: #fff;
      cursor: pointer;
      font-size: 14px;
      font-weight: 800;
      color: #111;
    }

    .option-btn.active,
    .color-btn.active {
      background: #111;
      color: #fff;
      border-color: #111;
    }

    .option-btn.soldout,
    .color-btn.soldout {
      opacity: 0.4;
      text-decoration: line-through;
      cursor: not-allowed;
    }

    .qty-box {
      display: inline-flex;
      align-items: center;
      border: 1px solid #ddd3c5;
      border-radius: 999px;
      overflow: hidden;
      background: #fff;
    }

    .qty-btn {
      width: 42px;
      height: 42px;
      border: 0;
      background: #fff;
      cursor: pointer;
      font-size: 18px;
      font-weight: 900;
    }

    .qty-input {
      width: 60px;
      height: 42px;
      border: 0;
      outline: none;
      text-align: center;
      font-size: 14px;
      font-weight: 800;
      background: #fff;
    }

    .add-on-list {
      display: grid;
      gap: 10px;
    }

    .add-on-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      border: 1px solid #ece3d7;
      border-radius: 18px;
      background: #fcfaf7;
      padding: 12px;
    }

    .add-on-left {
      display: flex;
      align-items: center;
      gap: 12px;
      min-width: 0;
    }

    .add-on-check {
      width: 18px;
      height: 18px;
      flex-shrink: 0;
      cursor: pointer;
    }

    .add-on-thumb {
      width: 58px;
      height: 58px;
      border-radius: 12px;
      object-fit: cover;
      background: #ede7dc;
      flex-shrink: 0;
    }

    .add-on-info {
      min-width: 0;
    }

    .add-on-name {
      font-size: 14px;
      font-weight: 800;
      word-break: keep-all;
    }

    .add-on-price {
      font-size: 13px;
      color: var(--muted);
      margin-top: 2px;
    }

    .error-text {
      min-height: 18px;
      margin-top: 8px;
      font-size: 13px;
      color: var(--danger);
      font-weight: 700;
    }

    .total-box {
      margin-top: 22px;
      padding: 18px 20px;
      border-radius: 20px;
      background: #f2eadd;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .total-label {
      font-size: 14px;
      color: var(--muted);
      font-weight: 700;
    }

    .total-price {
      font-size: 30px;
      font-weight: 900;
    }

    .button-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-top: 16px;
    }

    .action-btn {
      height: 56px;
      border: 0;
      border-radius: 16px;
      cursor: pointer;
      font-size: 15px;
      font-weight: 900;
    }

    .action-btn.light {
      background: #e8dfd2;
      color: #111;
    }

    .action-btn.dark {
      background: #111;
      color: #fff;
    }

    .action-btn:disabled {
      background: #d8d2c8;
      color: #7a7368;
      cursor: not-allowed;
    }

    .section {
      margin-top: 34px;
      background: var(--card);
      border-radius: 28px;
      padding: 30px;
      box-shadow: var(--shadow);
    }

    .tab-nav {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 22px;
    }

    .tab-btn {
      min-height: 42px;
      padding: 0 16px;
      border-radius: 999px;
      border: 1px solid #ddd3c5;
      background: #fff;
      cursor: pointer;
      font-size: 14px;
      font-weight: 800;
    }

    .tab-btn.active {
      background: #111;
      color: #fff;
      border-color: #111;
    }

    .tab-panel {
      display: none;
    }

    .tab-panel.active {
      display: block;
    }

    .section-title {
      font-size: 26px;
      font-weight: 900;
      margin-bottom: 18px;
    }

    .detail-images {
      display: grid;
      gap: 18px;
    }

    .detail-images img {
      width: 100%;
      border-radius: 20px;
    }

    .guide-block + .guide-block {
      margin-top: 28px;
    }

    .guide-label {
      font-size: 15px;
      font-weight: 900;
      margin-bottom: 10px;
    }

    .guide-text {
      font-size: 14px;
      color: #555;
      white-space: pre-line;
      word-break: keep-all;
    }

    .review-summary {
      display: grid;
      grid-template-columns: 220px 1fr;
      gap: 22px;
      align-items: center;
      margin-bottom: 24px;
    }

    .review-score-box {
      border-radius: 22px;
      background: #faf7f2;
      padding: 24px;
      text-align: center;
      border: 1px solid var(--line);
    }

    .review-score {
      font-size: 42px;
      font-weight: 900;
      line-height: 1;
      margin-bottom: 6px;
    }

    .star-row {
      display: flex;
      justify-content: center;
      gap: 2px;
      color: #c7a867;
      font-size: 18px;
      margin-bottom: 8px;
    }

    .review-count {
      font-size: 14px;
      color: var(--muted);
      font-weight: 700;
    }

    .review-list,
    .inquiry-list {
      display: grid;
      gap: 14px;
    }

    .review-item,
    .inquiry-item {
      border: 1px solid #ece3d7;
      border-radius: 18px;
      background: #fcfaf7;
      padding: 18px;
    }

    .review-head,
    .inquiry-head {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 8px;
    }

    .review-author,
    .inquiry-author {
      font-size: 14px;
      font-weight: 800;
    }

    .review-date,
    .inquiry-date {
      font-size: 12px;
      color: #888;
    }

    .review-body,
    .inquiry-body {
      font-size: 14px;
      color: #555;
      white-space: pre-line;
      word-break: keep-all;
    }

    .inquiry-form {
      display: grid;
      gap: 12px;
      margin-top: 20px;
      padding-top: 20px;
      border-top: 1px solid var(--line);
    }

    .text-input,
    .text-area {
      width: 100%;
      border: 1px solid #ddd3c5;
      border-radius: 14px;
      padding: 14px 16px;
      outline: none;
      background: #fff;
    }

    .text-area {
      min-height: 120px;
      resize: vertical;
    }

    .submit-btn {
      height: 48px;
      border: 0;
      border-radius: 14px;
      background: #111;
      color: #fff;
      font-weight: 900;
      cursor: pointer;
    }

    .recommend-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 18px;
    }

    .recommend-card {
      display: block;
      border-radius: 20px;
      overflow: hidden;
      background: #fcfaf7;
      border: 1px solid #ece3d7;
    }

    .recommend-thumb {
      width: 100%;
      aspect-ratio: 1 / 1.18;
      object-fit: cover;
      background: #ede7dc;
    }

    .recommend-info {
      padding: 14px;
    }

    .recommend-name {
      font-size: 14px;
      font-weight: 800;
      line-height: 1.45;
      min-height: 42px;
      word-break: keep-all;
      margin-bottom: 6px;
    }

    .recommend-price {
      font-size: 15px;
      font-weight: 900;
    }

    .empty {
      color: #777;
      font-size: 14px;
    }

    @media (max-width: 980px) {
      .layout {
        grid-template-columns: 1fr;
      }

      .purchase-card {
        position: static;
      }

      .review-summary {
        grid-template-columns: 1fr;
      }

      .recommend-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 640px) {
      .page {
        padding: 18px 14px 70px;
      }

      .purchase-card,
      .section {
        padding: 22px;
        border-radius: 22px;
      }

      .title {
        font-size: 28px;
      }

      .main-price {
        font-size: 30px;
      }

      .total-price {
        font-size: 26px;
      }

      .button-row {
        grid-template-columns: 1fr;
      }

      .recommend-grid {
        grid-template-columns: 1fr 1fr;
        gap: 12px;
      }
    }
  </style>
</head>
<body>
  <%
    const safeSubImages = Array.isArray(product.subImages) ? product.subImages.filter(Boolean) : [];
    const safeDetailImages = Array.isArray(product.detailImages) ? product.detailImages.filter(Boolean) : [];
    const safeDesc = product.desc || product.description || '';
    const safeSummary = product.summary || '';
    const isSoldOut = product.status === 'soldout' || Number(product.stock || 0) <= 0;
    const safeAddOnProducts = Array.isArray(addOnProducts) ? addOnProducts : [];
    const safeOptionGroups = Array.isArray(product.optionGroups) ? product.optionGroups.filter(Boolean) : [];

    const legacyOptions = Array.isArray(product.options)
      ? product.options
      : (typeof product.options === 'string'
          ? product.options.split(',').map(v => v.trim()).filter(Boolean)
          : []);

    const legacyColors = Array.isArray(product.colors)
      ? product.colors
      : (typeof product.colors === 'string'
          ? product.colors.split(',').map(v => v.trim()).filter(Boolean)
          : []);

    let firstGroup = null;
    let secondGroup = null;

    if (safeOptionGroups.length >= 1) firstGroup = safeOptionGroups[0];
    if (safeOptionGroups.length >= 2) secondGroup = safeOptionGroups[1];

    if (!firstGroup && legacyOptions.length > 0) {
      firstGroup = {
        name: '옵션',
        values: legacyOptions.map((value) => ({ value, isSoldOut: false }))
      };
    }

    if (!secondGroup && legacyColors.length > 0) {
      secondGroup = {
        name: '컬러',
        values: legacyColors.map((value) => ({ value, isSoldOut: false }))
      };
    }

    const galleryItems = [];
    if (product.image) galleryItems.push({ type: 'image', src: product.image });
    if (product.video) galleryItems.push({ type: 'video', src: product.video });

    safeSubImages.forEach((img) => {
      if (!galleryItems.find((item) => item.src === img)) {
        galleryItems.push({ type: 'image', src: img });
      }
    });

    const discountRate =
      Number(product.oldPrice || 0) > Number(product.price || 0)
        ? Math.round((1 - Number(product.price || 0) / Number(product.oldPrice || 0)) * 100)
        : 0;

    const rewardPoint = Math.floor(Number(product.price || 0) * 0.01);

    const reviewSamples = [
      {
        author: 'damore***',
        date: '2026-04-18',
        rating: 5,
        body: '핏이 예쁘고 원단 퀄리티가 좋아서 만족했어요. 실제로 받아보니 더 괜찮았습니다.'
      },
      {
        author: 'style***',
        date: '2026-04-16',
        rating: 4,
        body: '색감이 화면이랑 비슷하고 데일리로 입기 좋아요. 정사이즈 느낌입니다.'
      }
    ];

    const inquirySamples = [
      {
        author: 'guest***',
        date: '2026-04-20',
        title: '배송 문의',
        body: '오늘 주문하면 언제쯤 출고될까요?'
      },
      {
        author: 'look***',
        date: '2026-04-19',
        title: '사이즈 문의',
        body: '평소 100 입는데 이 상품은 어떤 사이즈 추천인가요?'
      }
    ];

    const recommendProducts = safeAddOnProducts.slice(0, 4);
  %>

  <div
    id="productData"
    data-price="<%= Number(product.price || 0) %>"
    data-stock="<%= Number(product.stock || 0) %>"
    data-has-first-group="<%= firstGroup && Array.isArray(firstGroup.values) && firstGroup.values.length > 0 ? 'true' : 'false' %>"
    data-has-second-group="<%= secondGroup && Array.isArray(secondGroup.values) && secondGroup.values.length > 0 ? 'true' : 'false' %>"
  ></div>

  <div class="page">
    <div class="breadcrumb">
      <a href="/">홈</a>
      <% if (product.category) { %>
        <span>/</span>
        <a href="/category/<%= product.category %>"><%= product.category %></a>
      <% } %>
      <span>/</span>
      <span><%= product.name %></span>
    </div>

    <div class="layout">
      <div class="gallery-column">
        <div class="gallery-main" id="galleryStage">
          <% if (galleryItems.length > 0) { %>
            <% if (galleryItems[0].type === 'video') { %>
              <video src="<%= galleryItems[0].src %>" controls playsinline preload="metadata"></video>
            <% } else { %>
              <img src="<%= galleryItems[0].src %>" alt="<%= product.name %>">
            <% } %>
          <% } %>
        </div>

        <% if (galleryItems.length > 1) { %>
          <div class="thumbs" id="thumbs">
            <% galleryItems.forEach((item, index) => { %>
              <button
                type="button"
                class="thumb-btn <%= index === 0 ? 'active' : '' %>"
                data-type="<%= item.type %>"
                data-src="<%= item.src %>"
              >
                <% if (item.type === 'video') { %>
                  <video src="<%= item.src %>" muted playsinline preload="metadata"></video>
                <% } else { %>
                  <img src="<%= item.src %>" alt="썸네일">
                <% } %>
              </button>
            <% }) %>
          </div>
        <% } %>
      </div>

      <div class="purchase-column">
        <div class="purchase-card">
          <% if (product.category) { %>
            <div class="category"><%= product.category %></div>
          <% } %>

          <div class="title"><%= product.name %></div>

          <% if (safeSummary) { %>
            <div class="summary"><%= safeSummary %></div>
          <% } %>

          <div class="tag-row">
            <% if (product.tag) { %>
              <div class="chip dark"><%= product.tag %></div>
            <% } %>

            <% if (product.couponDisplay && product.couponDisplay.enabled && product.couponDisplay.label) { %>
              <div class="chip soft"><%= product.couponDisplay.label %></div>
            <% } %>
          </div>

          <div class="price-wrap">
            <% if (discountRate > 0) { %>
              <div class="discount-rate"><%= discountRate %>%</div>
            <% } %>
            <div class="main-price"><%= Number(product.price || 0).toLocaleString() %>원</div>
            <% if (Number(product.oldPrice || 0) > 0) { %>
              <div class="old-price"><%= Number(product.oldPrice || 0).toLocaleString() %>원</div>
            <% } %>
          </div>

          <div class="benefit-box">
            <div class="benefit-row">
              <span>적립혜택</span>
              <strong>최대 <%= rewardPoint.toLocaleString() %>원 적립</strong>
            </div>
            <div class="benefit-row">
              <span>배송안내</span>
              <strong><%= product.shippingFeeText || '무료배송' %></strong>
            </div>
            <div class="benefit-row">
              <span>혜택안내</span>
              <strong>
                <% if (product.couponDisplay && product.couponDisplay.enabled && product.couponDisplay.label) { %>
                  <%= product.couponDisplay.label %>
                <% } else { %>
                  회원 혜택 적용 가능
                <% } %>
              </strong>
            </div>
          </div>

          <div class="stock-text <%= isSoldOut ? 'soldout' : '' %>">
            <% if (isSoldOut) { %>
              품절된 상품입니다
            <% } else { %>
              현재 구매 가능 · 재고 <%= Number(product.stock || 0) %>개
            <% } %>
          </div>

          <% if (safeDesc) { %>
            <div class="desc"><%= safeDesc %></div>
          <% } %>

          <div class="divider"></div>

          <form id="productForm" method="POST">
            <input type="hidden" name="productId" value="<%= product._id %>">
            <input type="hidden" name="selectedOption" id="selectedOptionInput" value="">
            <input type="hidden" name="option" id="legacyOptionInput" value="">
            <input type="hidden" name="selectedColor" id="selectedColorInput" value="">
            <input type="hidden" name="quantity" id="quantityHidden" value="1">
            <input type="hidden" name="selectedAddOnIds" id="selectedAddOnIdsInput" value="">
            <input type="hidden" name="selectedAddOnNames" id="selectedAddOnNamesInput" value="">
            <input type="hidden" name="selectedAddOnTotal" id="selectedAddOnTotalInput" value="0">

            <% if (firstGroup && Array.isArray(firstGroup.values) && firstGroup.values.length > 0) { %>
              <div class="form-group">
                <label class="label"><%= firstGroup.name || '옵션 선택' %></label>
                <div class="option-wrap" id="optionWrap">
                  <% firstGroup.values.forEach((item) => { %>
                    <button
                      type="button"
                      class="option-btn <%= item.isSoldOut ? 'soldout' : '' %>"
                      data-option="<%= item.value %>"
                      data-soldout="<%= item.isSoldOut ? 'true' : 'false' %>"
                    >
                      <%= item.value %>
                    </button>
                  <% }) %>
                </div>
                <div class="error-text" id="optionError"></div>
              </div>
            <% } %>

            <% if (secondGroup && Array.isArray(secondGroup.values) && secondGroup.values.length > 0) { %>
              <div class="form-group">
                <label class="label"><%= secondGroup.name || '컬러 선택' %></label>
                <div class="option-wrap" id="colorWrap">
                  <% secondGroup.values.forEach((item) => { %>
                    <button
                      type="button"
                      class="color-btn <%= item.isSoldOut ? 'soldout' : '' %>"
                      data-color="<%= item.value %>"
                      data-soldout="<%= item.isSoldOut ? 'true' : 'false' %>"
                    >
                      <%= item.value %>
                    </button>
                  <% }) %>
                </div>
                <div class="error-text" id="colorError"></div>
              </div>
            <% } %>

            <div class="form-group">
              <label class="label">수량</label>
              <div class="qty-box">
                <button type="button" class="qty-btn" id="minusBtn">-</button>
                <input
                  type="number"
                  class="qty-input"
                  id="qtyInput"
                  value="1"
                  min="1"
                  max="<%= Math.max(Number(product.stock || 1), 1) %>"
                />
                <button type="button" class="qty-btn" id="plusBtn">+</button>
              </div>
            </div>

            <% if (safeAddOnProducts.length > 0) { %>
              <div class="form-group">
                <label class="label">추가상품</label>
                <div class="add-on-list" id="addOnList">
                  <% safeAddOnProducts.forEach((item) => { %>
                    <label class="add-on-item">
                      <div class="add-on-left">
                        <input
                          type="checkbox"
                          class="add-on-check"
                          data-id="<%= item._id %>"
                          data-name="<%= item.name %>"
                          data-price="<%= Number(item.price || 0) %>"
                        />

                        <% if (item.image) { %>
                          <img src="<%= item.image %>" alt="<%= item.name %>" class="add-on-thumb">
                        <% } else { %>
                          <div class="add-on-thumb"></div>
                        <% } %>

                        <div class="add-on-info">
                          <div class="add-on-name"><%= item.name %></div>
                          <div class="add-on-price"><%= Number(item.price || 0).toLocaleString() %>원</div>
                        </div>
                      </div>
                    </label>
                  <% }) %>
                </div>
              </div>
            <% } %>

            <div class="total-box">
              <div class="total-label">총 상품금액</div>
              <div class="total-price" id="totalPrice"><%= Number(product.price || 0).toLocaleString() %>원</div>
            </div>

            <div class="button-row">
              <button
                type="button"
                class="action-btn light"
                id="cartBtn"
                <%= isSoldOut ? 'disabled' : '' %>
              >
                장바구니 담기
              </button>

              <button
                type="button"
                class="action-btn dark"
                id="buyBtn"
                <%= isSoldOut ? 'disabled' : '' %>
              >
                바로구매
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <div class="section">
      <div class="tab-nav">
        <button type="button" class="tab-btn active" data-tab="detail">상세정보</button>
        <button type="button" class="tab-btn" data-tab="review">리뷰</button>
        <button type="button" class="tab-btn" data-tab="inquiry">문의</button>
      </div>

      <div class="tab-panel active" data-panel="detail">
        <div class="section-title">상품 상세정보</div>

        <% if (safeDetailImages.length > 0) { %>
          <div class="detail-images">
            <% safeDetailImages.forEach((img, index) => { %>
              <img src="<%= img %>" alt="상세 이미지 <%= index + 1 %>">
            <% }) %>
          </div>
        <% } else if (safeDesc) { %>
          <div class="guide-text"><%= safeDesc %></div>
        <% } else { %>
          <div class="empty">등록된 상세 정보가 없습니다.</div>
        <% } %>

        <% if (
          (product.guide && product.guide.sizeGuideImage) ||
          (product.guide && product.guide.washImage) ||
          (product.guide && product.guide.shippingExchangeReturn) ||
          (product.guide && product.guide.copyrightNotice)
        ) { %>
          <div style="margin-top:32px;">
            <% if (product.guide && product.guide.sizeGuideImage) { %>
              <div class="guide-block">
                <div class="guide-label">사이즈 가이드</div>
                <img src="<%= product.guide.sizeGuideImage %>" alt="사이즈 가이드" style="border-radius:20px;">
              </div>
            <% } %>

            <% if (product.guide && product.guide.washImage) { %>
              <div class="guide-block">
                <div class="guide-label">세탁 안내</div>
                <img src="<%= product.guide.washImage %>" alt="세탁 안내" style="border-radius:20px;">
              </div>
            <% } %>

            <% if (product.guide && product.guide.shippingExchangeReturn) { %>
              <div class="guide-block">
                <div class="guide-label">배송 / 교환 / 반품 안내</div>
                <div class="guide-text"><%= product.guide.shippingExchangeReturn %></div>
              </div>
            <% } %>

            <% if (product.guide && product.guide.copyrightNotice) { %>
              <div class="guide-block">
                <div class="guide-label">저작권 안내</div>
                <div class="guide-text"><%= product.guide.copyrightNotice %></div>
              </div>
            <% } %>
          </div>
        <% } %>
      </div>

      <div class="tab-panel" data-panel="review">
        <div class="section-title">상품 리뷰</div>

        <div class="review-summary">
          <div class="review-score-box">
            <div class="review-score">4.8</div>
            <div class="star-row">★★★★★</div>
            <div class="review-count">총 <%= Number(product.reviewCount || reviewSamples.length) %>개 리뷰</div>
          </div>

          <div class="guide-text">
            실제 구매 고객 기준으로 핏, 원단, 착용감 만족도가 높은 상품입니다.
            여성의류 쇼핑몰 느낌으로 리뷰 요약 영역까지 들어간 구성입니다.
          </div>
        </div>

        <div class="review-list">
          <% reviewSamples.forEach((review) => { %>
            <div class="review-item">
              <div class="review-head">
                <div class="review-author"><%= review.author %></div>
                <div class="review-date"><%= review.date %></div>
              </div>
              <div class="star-row" style="justify-content:flex-start; margin-bottom:10px;">
                <% for (let i = 0; i < review.rating; i++) { %>★<% } %>
              </div>
              <div class="review-body"><%= review.body %></div>
            </div>
          <% }) %>
        </div>
      </div>

      <div class="tab-panel" data-panel="inquiry">
        <div class="section-title">상품 문의</div>

        <div class="inquiry-list">
          <% inquirySamples.forEach((item) => { %>
            <div class="inquiry-item">
              <div class="inquiry-head">
                <div class="inquiry-author"><%= item.author %> · <%= item.title %></div>
                <div class="inquiry-date"><%= item.date %></div>
              </div>
              <div class="inquiry-body"><%= item.body %></div>
            </div>
          <% }) %>
        </div>

        <form class="inquiry-form" onsubmit="event.preventDefault(); alert('문의 저장 기능은 다음 단계에서 연결하면 됨');">
          <input class="text-input" type="text" placeholder="문의 제목">
          <textarea class="text-area" placeholder="문의 내용을 입력하세요"></textarea>
          <button class="submit-btn" type="submit">문의 등록</button>
        </form>
      </div>
    </div>

    <% if (recommendProducts.length > 0) { %>
      <div class="section">
        <div class="section-title">추천 상품</div>
        <div class="recommend-grid">
          <% recommendProducts.forEach((item) => { %>
            <a class="recommend-card" href="/products/<%= item._id %>">
              <% if (item.image) { %>
                <img class="recommend-thumb" src="<%= item.image %>" alt="<%= item.name %>">
              <% } else { %>
                <div class="recommend-thumb"></div>
              <% } %>
              <div class="recommend-info">
                <div class="recommend-name"><%= item.name %></div>
                <div class="recommend-price"><%= Number(item.price || 0).toLocaleString() %>원</div>
              </div>
            </a>
          <% }) %>
        </div>
      </div>
    <% } %>
  </div>

  <script>
    const productDataEl = document.getElementById('productData');

    const price = Number(productDataEl?.dataset.price || 0);
    const stock = Number(productDataEl?.dataset.stock || 0);
    const hasFirstGroup = productDataEl?.dataset.hasFirstGroup === 'true';
    const hasSecondGroup = productDataEl?.dataset.hasSecondGroup === 'true';

    const optionWrap = document.getElementById('optionWrap');
    const optionButtons = optionWrap ? optionWrap.querySelectorAll('.option-btn') : [];
    const selectedOptionInput = document.getElementById('selectedOptionInput');
    const legacyOptionInput = document.getElementById('legacyOptionInput');
    const optionError = document.getElementById('optionError');

    const colorWrap = document.getElementById('colorWrap');
    const colorButtons = colorWrap ? colorWrap.querySelectorAll('.color-btn') : [];
    const selectedColorInput = document.getElementById('selectedColorInput');
    const colorError = document.getElementById('colorError');

    const addOnList = document.getElementById('addOnList');
    const addOnChecks = addOnList ? addOnList.querySelectorAll('.add-on-check') : [];
    const selectedAddOnIdsInput = document.getElementById('selectedAddOnIdsInput');
    const selectedAddOnNamesInput = document.getElementById('selectedAddOnNamesInput');
    const selectedAddOnTotalInput = document.getElementById('selectedAddOnTotalInput');

    const qtyInput = document.getElementById('qtyInput');
    const quantityHidden = document.getElementById('quantityHidden');
    const minusBtn = document.getElementById('minusBtn');
    const plusBtn = document.getElementById('plusBtn');
    const totalPrice = document.getElementById('totalPrice');

    const productForm = document.getElementById('productForm');
    const cartBtn = document.getElementById('cartBtn');
    const buyBtn = document.getElementById('buyBtn');

    const galleryStage = document.getElementById('galleryStage');
    const thumbs = document.getElementById('thumbs');

    function getSelectedAddOnTotal() {
      let sum = 0;
      addOnChecks.forEach((check) => {
        if (check.checked) {
          sum += Number(check.dataset.price || 0);
        }
      });
      return sum;
    }

    function syncAddOnInputs() {
      const ids = [];
      const names = [];
      let total = 0;

      addOnChecks.forEach((check) => {
        if (check.checked) {
          ids.push(check.dataset.id || '');
          names.push(check.dataset.name || '');
          total += Number(check.dataset.price || 0);
        }
      });

      if (selectedAddOnIdsInput) selectedAddOnIdsInput.value = ids.join(',');
      if (selectedAddOnNamesInput) selectedAddOnNamesInput.value = names.join(',');
      if (selectedAddOnTotalInput) selectedAddOnTotalInput.value = String(total);
    }

    function updateTotal() {
      let qty = Number(qtyInput?.value || 1);

      if (qty < 1) qty = 1;
      if (stock > 0 && qty > stock) qty = stock;

      if (qtyInput) qtyInput.value = qty;
      if (quantityHidden) quantityHidden.value = qty;

      const addOnTotal = getSelectedAddOnTotal();
      const finalTotal = (price * qty) + addOnTotal;

      if (totalPrice) {
        totalPrice.textContent = finalTotal.toLocaleString() + '원';
      }

      syncAddOnInputs();
    }

    if (minusBtn) {
      minusBtn.addEventListener('click', function () {
        qtyInput.value = Math.max(Number(qtyInput.value || 1) - 1, 1);
        updateTotal();
      });
    }

    if (plusBtn) {
      plusBtn.addEventListener('click', function () {
        const next = Number(qtyInput.value || 1) + 1;
        qtyInput.value = stock > 0 ? Math.min(next, stock) : next;
        updateTotal();
      });
    }

    if (qtyInput) {
      qtyInput.addEventListener('input', updateTotal);
    }

    optionButtons.forEach((button) => {
      button.addEventListener('click', function () {
        if (button.dataset.soldout === 'true') return;

        optionButtons.forEach((btn) => btn.classList.remove('active'));
        button.classList.add('active');

        const value = button.dataset.option || '';
        if (selectedOptionInput) selectedOptionInput.value = value;
        if (legacyOptionInput) legacyOptionInput.value = value;
        if (optionError) optionError.textContent = '';
      });
    });

    colorButtons.forEach((button) => {
      button.addEventListener('click', function () {
        if (button.dataset.soldout === 'true') return;

        colorButtons.forEach((btn) => btn.classList.remove('active'));
        button.classList.add('active');

        const value = button.dataset.color || '';
        if (selectedColorInput) selectedColorInput.value = value;
        if (colorError) colorError.textContent = '';
      });
    });

    addOnChecks.forEach((check) => {
      check.addEventListener('change', function () {
        updateTotal();
      });
    });

    function validateForm() {
      if (hasFirstGroup && selectedOptionInput && !selectedOptionInput.value) {
        if (optionError) optionError.textContent = '옵션을 선택해주세요.';
        return false;
      }

      if (hasSecondGroup && selectedColorInput && !selectedColorInput.value) {
        if (colorError) colorError.textContent = '컬러를 선택해주세요.';
        return false;
      }

      return true;
    }

    if (cartBtn) {
      cartBtn.addEventListener('click', function () {
        if (!validateForm()) return;
        productForm.action = '/cart/add';
        productForm.submit();
      });
    }

    if (buyBtn) {
      buyBtn.addEventListener('click', function () {
        if (!validateForm()) return;
        productForm.action = '/buy-now';
        productForm.submit();
      });
    }

    if (thumbs && galleryStage) {
      thumbs.addEventListener('click', function (e) {
        const thumb = e.target.closest('.thumb-btn');
        if (!thumb) return;

        const type = thumb.dataset.type;
        const src = thumb.dataset.src;

        if (type === 'video') {
          galleryStage.innerHTML = `<video src="${src}" controls playsinline preload="metadata"></video>`;
        } else {
          galleryStage.innerHTML = `<img src="${src}" alt="상품 이미지">`;
        }

        thumbs.querySelectorAll('.thumb-btn').forEach((item) => {
          item.classList.remove('active');
        });
        thumb.classList.add('active');
      });
    }

    const tabButtons = document.querySelectorAll('.tab-btn');
    const tabPanels = document.querySelectorAll('.tab-panel');

    tabButtons.forEach((button) => {
      button.addEventListener('click', function () {
        const target = button.dataset.tab;

        tabButtons.forEach((btn) => btn.classList.remove('active'));
        tabPanels.forEach((panel) => panel.classList.remove('active'));

        button.classList.add('active');
        const panel = document.querySelector(`[data-panel="${target}"]`);
        if (panel) panel.classList.add('active');
      });
    });

    updateTotal();
  </script>
</body>
</html>
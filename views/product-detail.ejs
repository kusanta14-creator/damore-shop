  .content-section {
    padding: 26px 0;
    border-top: 1px solid var(--line);
    background: transparent;
    scroll-margin-top: 110px;
  }

  .content-section:first-of-type {
    border-top: 0;
    padding-top: 0;
  }

  .content-section-title {
    font-size: 16px;
    font-weight: 800;
    margin-bottom: 12px;
    letter-spacing: -0.01em;
    text-align: center;
  }

  .content-section-sub {
    font-size: 11px;
    color: #7a746c;
    margin-bottom: 18px;
    text-align: center;
  }

  .detail-images {
    display: grid;
    gap: 14px;
  }

  .detail-images img {
    width: 100%;
    background: transparent;
    border: 0;
    box-shadow: none;
  }

  .guide-text {
    font-size: 12px;
    color: #555;
    white-space: pre-line;
    word-break: keep-all;
    line-height: 1.9;
  }

  .guide-block {
    margin-top: 22px;
  }

  .guide-block:first-child {
    margin-top: 0;
  }

  .guide-heading {
    font-size: 13px;
    font-weight: 800;
    margin-bottom: 10px;
    color: #222;
  }

  .empty-text {
    font-size: 12px;
    color: #6f675d;
    line-height: 1.8;
    text-align: center;
  }

  .mobile-buybar {
    display: none;
  }

  @media (max-width: 980px) {
    .layout {
      grid-template-columns: 1fr;
      gap: 22px;
    }

    .gallery-col,
    .gallery-main {
      max-width: 100%;
    }

    .purchase-box {
      position: static;
    }

    .content-wrap {
      margin-top: 56px;
    }
  }

  @media (max-width: 640px) {
    .page {
      padding: 14px 12px 92px;
    }

    .title {
      font-size: 20px;
    }

    .price-main {
      font-size: 16px;
    }

    .detail-row {
      grid-template-columns: 82px minmax(0, 1fr);
      gap: 10px;
    }

    .content-wrap {
      margin-top: 40px;
    }

    .content-nav {
      row-gap: 8px;
    }

    .mobile-buybar {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 50;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      padding: 10px 12px calc(10px + env(safe-area-inset-bottom));
      background: rgba(255, 255, 255, 0.96);
      border-top: 1px solid #ddd6cb;
      backdrop-filter: blur(6px);
    }

    .mobile-buybar button {
      height: 44px;
      border: 0;
      font-size: 13px;
      font-weight: 800;
    }

    .mobile-cart {
      background: var(--icon);
      color: #333;
      border: 1px solid #d8d0c4 !important;
    }

    .mobile-buy {
      background: var(--brown-dark);
      color: #fff;
    }
  }
</style>

<div id="productData"
  data-price="<%= safePrice %>"
  data-stock="<%= safeStock %>"
  data-has-color="<%= hasColorGroup ? 'true' : 'false' %>"
  data-has-size="<%= hasSizeGroup ? 'true' : 'false' %>">
</div>

<div class="page">
  <div class="layout">
    <div class="gallery-col">
      <div class="gallery-main" id="galleryStage">
        <% if (galleryItems.length > 0) { %>
          <% if (galleryItems[0].type === 'video') { %>
            <video src="<%= galleryItems[0].src %>" controls playsinline preload="metadata"></video>
          <% } else { %>
            <img src="<%= galleryItems[0].src %>" alt="<%= safeName %>">
          <% } %>
        <% } else { %>
          <div class="empty-text" style="height:100%; display:flex; align-items:center; justify-content:center;">등록된 상품 이미지가 없습니다.</div>
        <% } %>
      </div>

      <% if (galleryItems.length > 1) { %>
        <div class="thumbs-wrap">
          <div class="thumbs" id="thumbs">
            <% galleryItems.forEach((item, index) => { %>
              <button type="button" class="thumb-btn <%= index === 0 ? 'active' : '' %>" data-type="<%= item.type %>" data-src="<%= item.src %>">
                <% if (item.type === 'video') { %>
                  <video src="<%= item.src %>" muted playsinline preload="metadata"></video>
                <% } else { %>
                  <img src="<%= item.src %>" alt="썸네일">
                <% } %>
              </button>
            <% }) %>
          </div>
        </div>
      <% } %>
    </div>

    <div class="purchase-col">
      <div class="purchase-box">
        <div class="interest-bubble">🔔 <%= interestCount.toLocaleString() %>명이 이 상품을 관심상품에 담아두었어요.</div>

        <div class="title-row">
          <div class="title"><%= safeName %></div>
          <div class="new-badge">NEW</div>
        </div>

        <% if (safeSummary) { %>
          <div class="summary-top"><%= safeSummary %></div>
        <% } %>

        <div class="price-lines">
          <div class="price-line">
            <div class="price-label">소비자가</div>
            <div><span class="price-old"><%= safeOldPrice.toLocaleString() %>원</span></div>
          </div>

          <div class="price-line">
            <div class="price-label">회원판매가</div>
            <div>
              <span class="price-main">KRW <%= safePrice.toLocaleString() %></span>
              <% if (discountRate > 0) { %>
                <span class="price-discount">(<%= discountRate %>% off)</span>
              <% } %>
            </div>
          </div>
        </div>

        <div class="detail-info">
          <div class="detail-row">
            <div class="detail-row-label">상품간략설명</div>
            <div class="detail-row-value"><%= safeSummary || '-' %></div>
          </div>

          <div class="detail-row">
            <div class="detail-row-label">SIZE(cm)</div>
            <div class="detail-row-value">
              <%= hasSizeGroup ? sizeGroup.values.map(v => v.value).join(' / ') : '-' %>
            </div>
          </div>

          <div class="detail-row">
            <div class="detail-row-label">MODEL</div>
            <div class="detail-row-value"><%= modelInfo %></div>
          </div>

          <div class="detail-row">
            <div class="detail-row-label">배송비(비회원)</div>
            <div class="detail-row-value"><%= shippingText %></div>
          </div>
        </div>

        <div class="coupon-row">
          <button type="button" class="coupon-btn" onclick="alert('쿠폰 다운로드 기능은 다음 단계에서 연결')">쿠폰 확인</button>
        </div>

        <div class="benefit-box">
          <div class="benefit-line">
            <div class="benefit-label">예상 최저가ⓘ</div>
            <div class="benefit-value"><%= safePrice.toLocaleString() %>원</div>
          </div>
          <div class="benefit-line">
            <div class="benefit-label">최대 적립 혜택</div>
            <div class="benefit-value"><%= rewardPoint.toLocaleString() %>P</div>
          </div>
        </div>

        <form id="productForm" method="POST">
          <input type="hidden" name="productId" value="<%= safeProduct._id || '' %>">
          <input type="hidden" name="selectedOption" id="selectedOptionInput" value="">
          <input type="hidden" name="option" id="legacyOptionInput" value="">
          <input type="hidden" name="selectedColor" id="selectedColorInput" value="">
          <input type="hidden" name="quantity" id="quantityHidden" value="1">

          <div class="option-wrap">
            <% if (hasColorGroup) { %>
              <div class="option-group">
                <div class="option-title">색상</div>
                <div class="option-values" id="colorWrap">
                  <% colorGroup.values.forEach((item) => { %>
                    <button
                      type="button"
                      class="option-chip <%= item && item.isSoldOut ? 'soldout' : '' %>"
                      data-color="<%= item && item.value ? item.value : '' %>"
                      data-soldout="<%= item && item.isSoldOut ? 'true' : 'false' %>">
                      <%= item && item.value ? item.value : '-' %>
                    </button>
                  <% }) %>
                </div>
                <div class="error-text" id="colorError"></div>
              </div>
            <% } %>

            <% if (hasSizeGroup) { %>
              <div class="option-group">
                <div class="option-title">사이즈</div>
                <div class="option-values" id="sizeWrap">
                  <% sizeGroup.values.forEach((item) => { %>
                    <button
                      type="button"
                      class="option-chip <%= item && item.isSoldOut ? 'soldout' : '' %>"
                      data-size="<%= item && item.value ? item.value : '' %>"
                      data-soldout="<%= item && item.isSoldOut ? 'true' : 'false' %>">
                      <%= item && item.value ? item.value : '-' %>
                    </button>
                  <% }) %>
                </div>
                <div class="error-text" id="optionError"></div>
              </div>
            <% } %>
          </div>

          <% if (safeAddOnProducts.length > 0) { %>
            <div class="with-section">
              <div class="with-title">Weekly Best</div>
              <div class="with-sub">70,000원 이상 구매 시 배송비 무료</div>

              <div class="with-wrap">
                <div class="with-viewport">
                  <div class="with-track" id="withTrack">
                    <% safeAddOnProducts.forEach((item, index) => { 
                      const addOnName = item && item.name ? item.name : '추가상품';
                      const addOnPrice = Number(item && item.price ? item.price : 0);
                      const addOnOldPrice = Number(item && item.oldPrice ? item.oldPrice : 0);
                      const addOnImage = item && item.image ? item.image : '';
                      const addOnId = item && item._id ? item._id : '';
                      const addOnDiscount = addOnOldPrice > addOnPrice && addOnOldPrice > 0
                        ? Math.round((1 - addOnPrice / addOnOldPrice) * 100)
                        : 0;
                    %>
                      <div class="with-card">
                        <div class="with-thumb">
                          <div class="with-rank"><%= index + 1 %></div>
                          <% if (addOnImage) { %>
                            <img src="<%= addOnImage %>" alt="<%= addOnName %>">
                          <% } else { %>
                            <div class="empty-text" style="height:100%; display:flex; align-items:center; justify-content:center;">이미지 없음</div>
                          <% } %>
                        </div>

                        <div class="with-name"><%= addOnName %></div>

                        <div class="with-price-row">
                          <% if (addOnDiscount > 0) { %>
                            <span class="with-sale"><%= addOnDiscount %>%</span>
                            <span class="with-price"><%= addOnPrice.toLocaleString() %>원</span>
                            <span class="with-old"><%= addOnOldPrice.toLocaleString() %>원</span>
                          <% } else { %>
                            <span class="with-price"><%= addOnPrice.toLocaleString() %>원</span>
                          <% } %>
                        </div>

                        <button
                          type="button"
                          class="with-btn add-on-select-btn"
                          data-id="<%= addOnId %>"
                          data-name="<%= addOnName %>"
                          data-price="<%= addOnPrice %>">
                          선택
                        </button>
                      </div>
                    <% }) %>
                  </div>
                </div>

                <div class="with-nav">
                  <button type="button" class="with-arrow" id="withPrev">‹</button>
                  <span class="with-page" id="withPage">1/1</span>
                  <button type="button" class="with-arrow" id="withNext">›</button>
                </div>
              </div>
            </div>
          <% } %>

          <div class="selected-box">
            <div class="selected-name"><%= safeName %></div>
            <div class="selected-meta" id="selectedMetaText">옵션을 선택해주세요.</div>

            <div class="qty-total-row">
              <div class="qty-row">
                <button type="button" class="qty-btn" id="minusBtn">-</button>
                <input type="number" id="qtyInput" class="qty-input" value="1" min="1" max="<%= Math.max(safeStock, 1) %>" />
                <button type="button" class="qty-btn" id="plusBtn">+</button>
              </div>

              <div class="total-box">
                TOTAL
                <span class="total-price" id="totalPrice"><%= safePrice.toLocaleString() %></span>
              </div>
            </div>
          </div>

          <div class="btn-grid-main">
            <button type="button" class="action-btn btn-buy" id="buyBtn" <%= isSoldOut ? 'disabled' : '' %>>
              <%= isSoldOut ? '품절' : '바로구매' %>
            </button>

            <button type="button" class="action-btn btn-cart-icon" id="cartBtn" aria-label="장바구니" <%= isSoldOut ? 'disabled' : '' %>>
              🛒
            </button>

            <button type="button" class="action-btn btn-wish-icon" aria-label="찜" onclick="alert('찜 기능은 다음 단계에서 연결')">
              ♡
            </button>
          </div>

          <div class="btn-grid-sub">
            <button type="button" class="action-btn btn-npay" onclick="alert('네이버페이 구매는 다음 단계에서 연결')" <%= isSoldOut ? 'disabled' : '' %>>
              Npay 구매
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div class="content-wrap">
    <div class="content-nav" id="contentNav">
      <a href="#product-detail" class="section-link active">상세보기</a>
      <a href="#product-info" class="section-link">구매안내</a>
      <a href="#product-review" class="section-link">상품후기</a>
      <a href="#product-qna" class="section-link">상품문의</a>
    </div>

    <section class="content-section" id="product-detail">
      <div class="content-section-title">제품상세</div>
      <div class="content-section-sub">상품의 상세 정보를 확인해보세요.</div>

      <% if (safeDetailImages.length > 0) { %>
        <div class="detail-images">
          <% safeDetailImages.forEach((img, index) => { %>
            <img src="<%= img %>" alt="상세 이미지 <%= index + 1 %>">
          <% }) %>
        </div>
      <% } else if (safeDesc) { %>
        <div class="guide-text"><%= safeDesc %></div>
      <% } else { %>
        <div class="empty-text">등록된 상세 정보가 없습니다.</div>
      <% } %>
    </section>

    <section class="content-section" id="product-info">
      <div class="content-section-title">구매안내</div>
      <div class="content-section-sub">사이즈 / 세탁 / 배송 정보를 확인해보세요.</div>

      <% if (safeGuide && safeGuide.sizeGuideImage) { %>
        <div class="guide-block">
          <div class="guide-heading">사이즈 가이드</div>
          <img src="<%= safeGuide.sizeGuideImage %>" alt="사이즈 가이드" style="width:100%;">
        </div>
      <% } %>

      <% if (safeGuide && safeGuide.washImage) { %>
        <div class="guide-block">
          <div class="guide-heading">세탁 안내</div>
          <img src="<%= safeGuide.washImage %>" alt="세탁 안내" style="width:100%;">
        </div>
      <% } %>

      <% if (safeGuide && safeGuide.shippingExchangeReturn) { %>
        <div class="guide-block">
          <div class="guide-heading">배송 / 교환 / 반품 안내</div>
          <div class="guide-text"><%= safeGuide.shippingExchangeReturn %></div>
        </div>
      <% } %>

      <% if (
        !(safeGuide && safeGuide.sizeGuideImage) &&
        !(safeGuide && safeGuide.washImage) &&
        !(safeGuide && safeGuide.shippingExchangeReturn)
      ) { %>
        <div class="empty-text">등록된 안내 정보가 없습니다.</div>
      <% } %>
    </section>

    <section class="content-section" id="product-review">
      <div class="content-section-title">상품후기</div>
      <div class="content-section-sub">고객 리뷰 영역입니다.</div>
      <div class="empty-text">리뷰 영역은 다음 단계에서 연결</div>
    </section>

    <section class="content-section" id="product-qna">
      <div class="content-section-title">상품문의</div>
      <div class="content-section-sub">상품 문의 영역입니다.</div>
      <div class="empty-text">Q&amp;A 영역은 다음 단계에서 연결</div>
    </section>
  </div>
</div>

<%- include('partials/footer') %>

<div class="mobile-buybar">
  <button type="button" class="mobile-cart" id="mobileCartBtn" <%= isSoldOut ? 'disabled' : '' %>>장바구니</button>
  <button type="button" class="mobile-buy" id="mobileBuyBtn" <%= isSoldOut ? 'disabled' : '' %>><%= isSoldOut ? '품절' : '바로구매' %></button>
</div>

<script>
  const productDataEl = document.getElementById('productData');

  const price = Number(productDataEl?.dataset.price || 0);
  const stock = Number(productDataEl?.dataset.stock || 0);
  const hasColor = productDataEl?.dataset.hasColor === 'true';
  const hasSize = productDataEl?.dataset.hasSize === 'true';

  const colorWrap = document.getElementById('colorWrap');
  const sizeWrap = document.getElementById('sizeWrap');
  const colorButtons = colorWrap ? colorWrap.querySelectorAll('.option-chip') : [];
  const sizeButtons = sizeWrap ? sizeWrap.querySelectorAll('.option-chip') : [];

  const selectedOptionInput = document.getElementById('selectedOptionInput');
  const legacyOptionInput = document.getElementById('legacyOptionInput');
  const selectedColorInput = document.getElementById('selectedColorInput');

  const optionError = document.getElementById('optionError');
  const colorError = document.getElementById('colorError');

  const addOnSelectButtons = document.querySelectorAll('.add-on-select-btn');
  const qtyInput = document.getElementById('qtyInput');
  const quantityHidden = document.getElementById('quantityHidden');
  const minusBtn = document.getElementById('minusBtn');
  const plusBtn = document.getElementById('plusBtn');
  const totalPrice = document.getElementById('totalPrice');
  const selectedMetaText = document.getElementById('selectedMetaText');

  const productForm = document.getElementById('productForm');
  const cartBtn = document.getElementById('cartBtn');
  const buyBtn = document.getElementById('buyBtn');
  const mobileCartBtn = document.getElementById('mobileCartBtn');
  const mobileBuyBtn = document.getElementById('mobileBuyBtn');

  const galleryStage = document.getElementById('galleryStage');
  const thumbs = document.getElementById('thumbs');

  const withTrack = document.getElementById('withTrack');
  const withPrev = document.getElementById('withPrev');
  const withNext = document.getElementById('withNext');
  const withPage = document.getElementById('withPage');

  let selectedAddOns = [];
  let withIndex = 0;

  function syncSelections() {
    const colorValue = selectedColorInput ? selectedColorInput.value : '';
    const sizeValue = selectedOptionInput ? selectedOptionInput.value : '';

    const metaParts = [];
    if (colorValue) metaParts.push(`색상: ${colorValue}`);
    if (sizeValue) metaParts.push(`사이즈: ${sizeValue}`);
    if (selectedAddOns.length) {
      metaParts.push(`추가상품: ${selectedAddOns.map(item => item.name).join(', ')}`);
    }

    if (selectedMetaText) {
      selectedMetaText.textContent = metaParts.length ? metaParts.join(' / ') : '옵션을 선택해주세요.';
    }
  }

  function updateTotal() {
    if (!qtyInput) return;

    let qty = Number(qtyInput.value || 1);

    if (qty < 1) qty = 1;
    if (stock > 0 && qty > stock) qty = stock;

    qtyInput.value = qty;
    if (quantityHidden) quantityHidden.value = qty;

    const addOnTotal = selectedAddOns.reduce((sum, item) => sum + item.price, 0);
    if (totalPrice) totalPrice.textContent = ((price * qty) + addOnTotal).toLocaleString();

    syncSelections();
  }

  colorButtons.forEach((button) => {
    button.addEventListener('click', function () {
      if (button.dataset.soldout === 'true') return;

      colorButtons.forEach((btn) => btn.classList.remove('active'));
      button.classList.add('active');

      if (selectedColorInput) selectedColorInput.value = button.dataset.color || '';
      if (colorError) colorError.textContent = '';

      syncSelections();
    });
  });

  sizeButtons.forEach((button) => {
    button.addEventListener('click', function () {
      if (button.dataset.soldout === 'true') return;

      sizeButtons.forEach((btn) => btn.classList.remove('active'));
      button.classList.add('active');

      if (selectedOptionInput) selectedOptionInput.value = button.dataset.size || '';
      if (legacyOptionInput) legacyOptionInput.value = button.dataset.size || '';
      if (optionError) optionError.textContent = '';

      syncSelections();
    });
  });

  addOnSelectButtons.forEach((button) => {
    button.addEventListener('click', function () {
      const id = button.dataset.id || '';
      const name = button.dataset.name || '';
      const priceValue = Number(button.dataset.price || 0);

      const exists = selectedAddOns.find(item => item.id === id);

      if (exists) {
        selectedAddOns = selectedAddOns.filter(item => item.id !== id);
        button.textContent = '선택';
        button.classList.remove('selected');
      } else {
        selectedAddOns.push({ id, name, price: priceValue });
        button.textContent = '선택됨';
        button.classList.add('selected');
      }

      updateTotal();
    });
  });

  if (minusBtn) {
    minusBtn.addEventListener('click', function () {
      if (!qtyInput) return;
      qtyInput.value = Math.max(Number(qtyInput.value || 1) - 1, 1);
      updateTotal();
    });
  }

  if (plusBtn) {
    plusBtn.addEventListener('click', function () {
      if (!qtyInput) return;
      const next = Number(qtyInput.value || 1) + 1;
      qtyInput.value = stock > 0 ? Math.min(next, stock) : next;
      updateTotal();
    });
  }

  if (qtyInput) qtyInput.addEventListener('input', updateTotal);

  function validateForm() {
    syncSelections();

    if (hasColor && selectedColorInput && !selectedColorInput.value) {
      if (colorError) colorError.textContent = '색상을 선택해주세요.';
      return false;
    }

    if (hasSize && selectedOptionInput && !selectedOptionInput.value) {
      if (optionError) optionError.textContent = '사이즈를 선택해주세요.';
      return false;
    }

    return true;
  }

  function submitCart() {
    if (!validateForm()) return;
    if (!productForm) return;
    productForm.action = '/cart/add';
    productForm.submit();
  }

  function submitBuy() {
    if (!validateForm()) return;
    if (!productForm) return;
    productForm.action = '/buy-now';
    productForm.submit();
  }

  if (cartBtn) cartBtn.addEventListener('click', submitCart);
  if (buyBtn) buyBtn.addEventListener('click', submitBuy);
  if (mobileCartBtn) mobileCartBtn.addEventListener('click', submitCart);
  if (mobileBuyBtn) mobileBuyBtn.addEventListener('click', submitBuy);

  if (thumbs && galleryStage) {
    thumbs.addEventListener('click', function (e) {
      const thumb = e.target.closest('.thumb-btn');
      if (!thumb) return;

      const type = thumb.dataset.type;
      const src = thumb.dataset.src;

      const stageMedia = type === 'video'
        ? `<video src="${src}" controls playsinline preload="metadata"></video>`
        : `<img src="${src}" alt="상품 이미지">`;

      galleryStage.innerHTML = stageMedia;

      thumbs.querySelectorAll('.thumb-btn').forEach((item) => {
        item.classList.remove('active');
      });
      thumb.classList.add('active');
    });
  }

  function moveWith(direction) {
    if (!withTrack) return;

    const cards = withTrack.querySelectorAll('.with-card');
    if (!cards.length) return;

    const cardWidth = cards[0].offsetWidth + 8;
    const viewport = withTrack.parentElement;
    const visibleCount = Math.max(Math.floor(viewport.offsetWidth / cardWidth), 1);
    const totalPages = Math.max(Math.ceil(cards.length / visibleCount), 1);
    const maxIndex = Math.max(cards.length - visibleCount, 0);

    withIndex += direction;
    if (withIndex < 0) withIndex = 0;
    if (withIndex > maxIndex) withIndex = maxIndex;

    withTrack.style.transform = `translateX(-${withIndex * cardWidth}px)`;

    const currentPage = Math.min(Math.floor(withIndex / visibleCount) + 1, totalPages);
    if (withPage) withPage.textContent = `${currentPage}/${totalPages}`;
  }

  if (withPrev) withPrev.addEventListener('click', () => moveWith(-1));
  if (withNext) withNext.addEventListener('click', () => moveWith(1));
  window.addEventListener('resize', () => moveWith(0));

  const sectionLinks = document.querySelectorAll('.section-link');
  const contentSections = document.querySelectorAll('.content-section');

  function setActiveSection() {
    let currentId = '';

    contentSections.forEach((section) => {
      const top = section.getBoundingClientRect().top;
      if (top <= 140) {
        currentId = section.id;
      }
    });

    if (!currentId && contentSections.length) {
      currentId = contentSections[0].id;
    }

    sectionLinks.forEach((link) => {
      link.classList.remove('active');
      const href = link.getAttribute('href') || '';
      if (href === `#${currentId}`) {
        link.classList.add('active');
      }
    });
  }

  sectionLinks.forEach((link) => {
    link.addEventListener('click', function () {
      sectionLinks.forEach((item) => item.classList.remove('active'));
      link.classList.add('active');
    });
  });

  window.addEventListener('scroll', setActiveSection);

  updateTotal();
  moveWith(0);
  setActiveSection();
</script>
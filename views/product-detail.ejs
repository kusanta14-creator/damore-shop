<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= product.name %></title>

<style>
*{margin:0;padding:0;box-sizing:border-box;}

body{
  font-family:Pretendard;
  background:#f5f3ef;
}

.container{
  max-width:1200px;
  margin:0 auto;
  padding:20px;
  display:grid;
  grid-template-columns:1fr 420px;
  gap:40px;
}

/* 좌측 이미지 */
.main-img{
  width:100%;
}

.thumbs{
  display:flex;
  gap:6px;
  margin-top:6px;
}
.thumbs img{
  width:60px;
  cursor:pointer;
}

/* 우측 */
.right{
  font-size:13px;
}

.bubble{
  font-size:11px;
  background:#eee;
  padding:6px 10px;
  border-radius:20px;
  display:inline-block;
  margin-bottom:10px;
}

.title{
  font-size:20px;
  font-weight:700;
  margin-bottom:6px;
}

.price{
  font-size:22px;
  font-weight:800;
  margin-bottom:10px;
}

.line{
  border-bottom:1px solid #ddd;
  padding:8px 0;
  display:flex;
}

.line span:first-child{
  width:100px;
  color:#777;
}

.summary{
  margin-bottom:10px;
  color:#666;
}

/* 옵션 */
select{
  width:100%;
  height:36px;
  margin-bottom:6px;
}

/* 코디 */
.coord{
  margin-top:10px;
}

.coord-head{
  display:flex;
  justify-content:space-between;
  margin-bottom:6px;
}

.coord-track{
  display:flex;
  gap:10px;
  overflow-x:auto;
}

.coord-item{
  width:90px;
  flex-shrink:0;
}

.coord-item img{
  width:100%;
}

.coord-btn{
  width:100%;
  background:#ff5a5a;
  color:#fff;
  border:none;
  font-size:11px;
  height:24px;
  cursor:pointer;
}

/* 수량 */
.qty{
  display:flex;
  margin-top:10px;
}

.qty button{
  width:30px;
}

.qty input{
  width:40px;
  text-align:center;
}

/* TOTAL */
.total{
  margin-top:10px;
  text-align:right;
  font-weight:700;
}

/* 버튼 */
.buttons{
  margin-top:10px;
}

.buy{
  width:100%;
  height:40px;
  background:#00c73c;
  color:#fff;
  border:none;
}

.cart{
  width:100%;
  height:40px;
  margin-top:6px;
}
</style>
</head>

<body>

<div class="container">

<!-- 이미지 -->
<div>
  <img src="<%= product.image %>" class="main-img">

  <div class="thumbs">
    <% product.subImages.forEach(img=>{ %>
      <img src="<%= img %>">
    <% }) %>
  </div>
</div>

<!-- 오른쪽 -->
<div class="right">

<div class="bubble">🔥 <%= product.likeCount || 238 %>명 관심</div>

<div class="title"><%= product.name %></div>
<div class="price"><%= product.price.toLocaleString() %>원</div>

<div class="summary"><%= product.summary %></div>

<div class="line"><span>상품설명</span><span><%= product.summary %></span></div>
<div class="line"><span>배송비</span><span><%= product.shippingFeeText %></span></div>
<div class="line"><span>적립금</span><span><%= Math.floor(product.price*0.01) %>P</span></div>

<!-- 옵션 -->
<select id="color">
<option>색상</option>
<% product.optionGroups[0]?.values.forEach(v=>{ %>
<option><%= v.value %></option>
<% }) %>
</select>

<select id="size">
<option>사이즈</option>
<% product.optionGroups[1]?.values.forEach(v=>{ %>
<option><%= v.value %></option>
<% }) %>
</select>

<!-- 코디 -->
<div class="coord">
<div class="coord-head">
<div>모델 착용 아이템</div>
</div>

<div class="coord-track">
<% addOnProducts.forEach(p=>{ %>
<div class="coord-item">
<img src="<%= p.image %>">
<div><%= p.price.toLocaleString() %></div>
<button class="coord-btn">선택</button>
</div>
<% }) %>
</div>
</div>

<!-- 수량 -->
<div class="qty">
<button>-</button>
<input value="1">
<button>+</button>
</div>

<div class="total">TOTAL <span id="total"><%= product.price.toLocaleString() %></span></div>

<div class="buttons">
<button class="buy">Npay 구매</button>
<button class="cart">장바구니</button>
</div>

</div>
</div>

</body>
</html>
<%
  const safeProduct = typeof product !== 'undefined' && product ? product : {};
  const safeName = safeProduct.name || '상품명';
  const safePrice = Number(safeProduct.price || 0);
  const safeOldPrice = Number(safeProduct.oldPrice || 0);
  const safeSummary = safeProduct.summary || '상품 설명이 없습니다.';
  const safeDesc = safeProduct.desc || '등록된 상세 정보가 없습니다.';
  const safeImage = safeProduct.image || '';
  const safeSubImages = Array.isArray(safeProduct.subImages) ? safeProduct.subImages.filter(Boolean) : [];
  const safeDetailImages = Array.isArray(safeProduct.detailImages) ? safeProduct.detailImages.filter(Boolean) : [];
  const safeGuide = safeProduct.guide || {};
  const safeAddOnProducts = Array.isArray(addOnProducts) ? addOnProducts.filter(Boolean) : [];
  const safeOptionGroups = Array.isArray(safeProduct.optionGroups) ? safeProduct.optionGroups.filter(Boolean) : [];

  let colorGroup = null;
  let sizeGroup = null;

  if (safeOptionGroups.length >= 1) colorGroup = safeOptionGroups[0];
  if (safeOptionGroups.length >= 2) sizeGroup = safeOptionGroups[1];

  const galleryItems = [];
  if (safeImage) galleryItems.push(safeImage);
  safeSubImages.forEach((img) => {
    if (!galleryItems.includes(img)) galleryItems.push(img);
  });

  const hasDiscount = safeOldPrice > safePrice && safeOldPrice > 0;
  const discountPercent = hasDiscount
    ? Math.round((1 - safePrice / safeOldPrice) * 100)
    : 0;
%>

<%- include('partials/header') %>

<style>
  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  :root {
    --bg: #f5f3ef;
    --white: #ffffff;
    --black: #111111;
    --text: #1f1f1f;
    --muted: #7a7268;
    --line: rgba(17, 17, 17, 0.08);
    --gold: #bfa68a;
    --max: 1280px;
    --shadow: 0 16px 40px rgba(0,0,0,0.06);
  }

  body {
    margin: 0;
    font-family: "Pretendard", "Noto Sans KR", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    word-break: keep-all;
  }

  a {
    text-decoration: none;
    color: inherit;
  }

  img {
    display: block;
    width: 100%;
  }

  .container {
    width: 100%;
    max-width: var(--max);
    margin: 0 auto;
    padding: 0 24px;
  }

  header {
    position: sticky;
    top: 0;
    z-index: 1000;
    background: rgba(245, 243, 239, 0.88);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--line);
  }

  .header-inner {
    min-height: 82px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 16px 0;
  }

  .brand {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .brand-logo {
    font-size: 30px;
    font-weight: 800;
    letter-spacing: 0.24em;
    color: var(--black);
  }

  .brand-sub {
    font-size: 10px;
    letter-spacing: 0.32em;
    color: var(--muted);
    text-transform: uppercase;
  }

  .nav {
    display: flex;
    gap: 20px;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
  }

  .nav-item {
    position: relative;
    display: flex;
    align-items: center;
    height: 48px;
    padding-bottom: 14px;
    margin-bottom: -14px;
  }

  .nav a,
  .nav-link {
    font-size: 14px;
    color: #312d29;
    position: relative;
    text-transform: uppercase;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    height: 48px;
  }

  .nav a::after,
  .nav-link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -6px;
    width: 0;
    height: 1px;
    background: var(--black);
    transition: 0.25s ease;
  }

  .nav a:hover::after,
  .nav a.active::after,
  .nav-link:hover::after,
  .nav-link.active::after {
    width: 100%;
  }

  .dropdown-menu {
    position: absolute;
    top: calc(100% - 2px);
    left: 50%;
    transform: translateX(-50%);
    min-width: 140px;
    padding: 14px 0;
    background: #e8e1d8;
    display: flex;
    flex-direction: column;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.18s ease, visibility 0.18s ease;
    z-index: 999;
    box-shadow: 0 10px 24px rgba(0,0,0,0.08);
  }

  .dropdown-menu a {
    display: block;
    padding: 8px 16px;
    text-align: center;
    font-size: 13px;
    color: #111;
    text-transform: none;
    white-space: nowrap;
  }

  .dropdown-menu a::after { display: none; }

  .dropdown-menu a:hover {
    background: rgba(255,255,255,0.28);
  }

  .nav-item:hover .dropdown-menu,
  .nav-item:focus-within .dropdown-menu {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 14px;
    font-size: 14px;
    color: var(--muted);
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .user-name {
    font-weight: 700;
    color: var(--black);
  }

  .page {
    max-width: 1180px;
    margin: 0 auto;
    padding: 34px 24px 90px;
  }

  .layout {
    display: grid;
    grid-template-columns: 620px 1fr;
    gap: 48px;
    align-items: start;
  }

  .gallery-main {
    width: 100%;
    aspect-ratio: 4 / 5;
    background: #e7e0d5;
    overflow: hidden;
    box-shadow: var(--shadow);
  }

  .gallery-main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .gallery-empty {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #888;
    font-size: 14px;
    background: #e7e0d5;
  }

  .thumbs {
    display: flex;
    gap: 8px;
    margin-top: 10px;
    overflow-x: auto;
    padding-bottom: 4px;
  }

  .thumb-btn {
    width: 72px;
    height: 90px;
    min-width: 72px;
    border: 1px solid #ddd6cb;
    background: #fff;
    padding: 0;
    cursor: pointer;
    overflow: hidden;
    opacity: .75;
  }

  .thumb-btn.active {
    border-color: #111;
    opacity: 1;
  }

  .thumb-btn img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .purchase-box {
    position: sticky;
    top: 110px;
  }

  .product-label {
    display: inline-block;
    margin-bottom: 10px;
    color: var(--gold);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .product-title {
    font-size: 30px;
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.03em;
    margin-bottom: 14px;
    color: #111;
  }

  .price-row {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }

  .product-price {
    font-size: 28px;
    font-weight: 800;
    color: #111;
  }

  .old-price {
    font-size: 15px;
    color: #9f978d;
    text-decoration: line-through;
  }

  .discount {
    color: #d64c4c;
    font-size: 15px;
    font-weight: 800;
  }

  .product-summary {
    font-size: 15px;
    color: #6f675d;
    line-height: 1.9;
    margin-bottom: 24px;
    white-space: pre-line;
  }

  .info-box {
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding: 14px 0;
    margin-bottom: 18px;
  }

  .info-row {
    display: grid;
    grid-template-columns: 92px 1fr;
    gap: 12px;
    padding: 6px 0;
    font-size: 13px;
  }

  .info-label {
    color: #7a7268;
    font-weight: 700;
  }

  .info-value {
    color: #222;
  }

  .option-group {
    margin-bottom: 14px;
  }

  .option-title {
    font-size: 13px;
    font-weight: 700;
    color: #444;
    margin-bottom: 8px;
  }

  .option-values {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .option-chip {
    min-width: 44px;
    height: 34px;
    padding: 0 12px;
    border: 1px solid #ddd6cb;
    background: #fff;
    cursor: pointer;
    font-size: 12px;
    font-weight: 700;
    color: #333;
  }

  .option-chip.active {
    background: #111;
    color: #fff;
    border-color: #111;
  }

  .option-chip.soldout {
    opacity: .45;
    cursor: not-allowed;
    text-decoration: line-through;
  }

  .selected-box {
    margin-top: 20px;
    padding: 16px;
    background: #fff;
    border: 1px solid var(--line);
  }

  .selected-meta {
    font-size: 13px;
    color: #666;
    margin-bottom: 12px;
  }

  .qty-total-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 14px;
    flex-wrap: wrap;
  }

  .qty-row {
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .qty-btn {
    width: 28px;
    height: 28px;
    border: 1px solid #ddd6cb;
    background: #fff;
    cursor: pointer;
  }

  .qty-input {
    width: 40px;
    height: 28px;
    border: 1px solid #ddd6cb;
    text-align: center;
  }

  .total-box {
    text-align: right;
    font-size: 11px;
    color: #777;
  }

  .total-price {
    display: block;
    font-size: 22px;
    color: #111;
    font-weight: 800;
    margin-top: 2px;
  }

  .btn-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-top: 18px;
  }

  .buy-btn,
  .cart-btn {
    height: 54px;
    border: 0;
    font-size: 15px;
    font-weight: 800;
    cursor: pointer;
  }

  .buy-btn {
    background: #111;
    color: #fff;
  }

  .cart-btn {
    background: #d9c2a4;
    color: #111;
  }

  .content-wrap {
    max-width: 940px;
    margin: 72px auto 0;
    padding-top: 20px;
    border-top: 1px solid var(--line);
  }

  .content-nav {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0;
    flex-wrap: wrap;
    margin-bottom: 28px;
    text-align: center;
  }

  .content-nav a {
    position: relative;
    padding: 0 14px;
    font-size: 12px;
    color: #7d766e;
    font-weight: 600;
  }

  .content-nav a.active {
    color: #111;
    font-weight: 800;
  }

  .content-nav a:not(:last-child)::after {
    content: "";
    position: absolute;
    right: 0;
    top: 50%;
    width: 1px;
    height: 10px;
    background: #cfc6ba;
    transform: translateY(-50%);
  }

  .content-section {
    padding: 28px 0;
    border-top: 1px solid var(--line);
    scroll-margin-top: 120px;
  }

  .content-section:first-of-type {
    border-top: 0;
    padding-top: 0;
  }

  .content-title {
    font-size: 18px;
    font-weight: 800;
    text-align: center;
    margin-bottom: 12px;
    color: #111;
  }

  .content-text {
    font-size: 14px;
    color: #555;
    line-height: 1.9;
    white-space: pre-line;
    text-align: center;
  }

  .detail-images {
    display: grid;
    gap: 14px;
  }

  .detail-images img {
    width: 100%;
  }

  .add-on-wrap {
    margin-top: 18px;
    padding-top: 18px;
    border-top: 1px solid var(--line);
  }

  .add-on-title {
    font-size: 14px;
    font-weight: 800;
    margin-bottom: 10px;
  }

  .add-on-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
  }

  .add-on-card {
    display: block;
    background: #fff;
    border: 1px solid var(--line);
    overflow: hidden;
  }

  .add-on-card img {
    aspect-ratio: 1 / 1.15;
    object-fit: cover;
  }

  .add-on-body {
    padding: 10px;
  }

  .add-on-name {
    font-size: 12px;
    font-weight: 700;
    line-height: 1.5;
    min-height: 36px;
    margin-bottom: 6px;
  }

  .add-on-price {
    font-size: 12px;
    font-weight: 800;
  }

  @media (max-width: 1100px) {
    .layout {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .purchase-box {
      position: static;
    }

    .add-on-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 760px) {
    .container {
      padding: 0 16px;
    }

    .nav {
      display: none;
    }

    .header-actions {
      display: none;
    }

    .page {
      padding: 20px 16px 72px;
    }

    .product-title {
      font-size: 24px;
    }

    .product-price {
      font-size: 24px;
    }

    .add-on-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>

<div class="page">
  <div class="layout">
    <div>
      <div class="gallery-main" id="galleryStage">
        <% if (safeImage) { %>
          <img src="<%= safeImage %>" alt="<%= safeName %>">
        <% } else { %>
          <div class="gallery-empty">이미지 없음</div>
        <% } %>
      </div>

      <% if (galleryItems.length > 1) { %>
        <div class="thumbs" id="thumbs">
          <% galleryItems.forEach((img, index) => { %>
            <button type="button" class="thumb-btn <%= index === 0 ? 'active' : '' %>" data-src="<%= img %>">
              <img src="<%= img %>" alt="썸네일">
            </button>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="purchase-box">
      <div class="product-label">DAMORE ITEM</div>
      <h1 class="product-title"><%= safeName %></h1>

      <div class="price-row">
        <div class="product-price"><%= safePrice.toLocaleString() %>원</div>
        <% if (hasDiscount) { %>
          <div class="old-price"><%= safeOldPrice.toLocaleString() %>원</div>
          <div class="discount"><%= discountPercent %>%</div>
        <% } %>
      </div>

      <div class="product-summary"><%= safeSummary %></div>

      <div class="info-box">
        <div class="info-row">
          <div class="info-label">상품명</div>
          <div class="info-value"><%= safeName %></div>
        </div>
        <div class="info-row">
          <div class="info-label">배송</div>
          <div class="info-value"><%= safeProduct.shippingFeeText || '무료배송' %></div>
        </div>
        <div class="info-row">
          <div class="info-label">상태</div>
          <div class="info-value"><%= (safeProduct.status === 'soldout' || Number(safeProduct.stock || 0) <= 0) ? '품절' : '판매중' %></div>
        </div>
      </div>

      <% if (colorGroup && Array.isArray(colorGroup.values) && colorGroup.values.length > 0) { %>
        <div class="option-group">
          <div class="option-title"><%= colorGroup.name || '색상' %></div>
          <div class="option-values" id="colorWrap">
            <% colorGroup.values.forEach((item) => { %>
              <button
                type="button"
                class="option-chip <%= item && item.isSoldOut ? 'soldout' : '' %>"
                data-color="<%= item && item.value ? item.value : '' %>"
                data-soldout="<%= item && item.isSoldOut ? 'true' : 'false' %>">
                <%= item && item.value ? item.value : '-' %>
              </button>
            <% }) %>
          </div>
        </div>
      <% } %>

      <% if (sizeGroup && Array.isArray(sizeGroup.values) && sizeGroup.values.length > 0) { %>
        <div class="option-group">
          <div class="option-title"><%= sizeGroup.name || '사이즈' %></div>
          <div class="option-values" id="sizeWrap">
            <% sizeGroup.values.forEach((item) => { %>
              <button
                type="button"
                class="option-chip <%= item && item.isSoldOut ? 'soldout' : '' %>"
                data-size="<%= item && item.value ? item.value : '' %>"
                data-soldout="<%= item && item.isSoldOut ? 'true' : 'false' %>">
                <%= item && item.value ? item.value : '-' %>
              </button>
            <% }) %>
          </div>
        </div>
      <% } %>

      <div class="selected-box">
        <div class="selected-meta" id="selectedMetaText">옵션을 선택해주세요.</div>

        <div class="qty-total-row">
          <div class="qty-row">
            <button type="button" class="qty-btn" id="minusBtn">-</button>
            <input type="number" id="qtyInput" class="qty-input" value="1" min="1">
            <button type="button" class="qty-btn" id="plusBtn">+</button>
          </div>

          <div class="total-box">
            TOTAL
            <span class="total-price" id="totalPrice"><%= safePrice.toLocaleString() %>원</span>
          </div>
        </div>

        <div class="btn-grid">
          <button type="button" class="cart-btn">장바구니</button>
          <button type="button" class="buy-btn">바로구매</button>
        </div>
      </div>

      <% if (safeAddOnProducts.length > 0) { %>
        <div class="add-on-wrap">
          <div class="add-on-title">추천 상품</div>
          <div class="add-on-grid">
            <% safeAddOnProducts.slice(0, 4).forEach((item) => { %>
              <a href="/products/<%= item._id %>" class="add-on-card">
                <% if (item.image) { %>
                  <img src="<%= item.image %>" alt="<%= item.name %>">
                <% } %>
                <div class="add-on-body">
                  <div class="add-on-name"><%= item.name || '상품명' %></div>
                  <div class="add-on-price"><%= Number(item.price || 0).toLocaleString() %>원</div>
                </div>
              </a>
            <% }) %>
          </div>
        </div>
      <% } %>
    </div>
  </div>

  <div class="content-wrap">
    <div class="content-nav" id="contentNav">
      <a href="#detail" class="section-link active">상세보기</a>
      <a href="#guide" class="section-link">구매안내</a>
      <a href="#review" class="section-link">상품후기</a>
      <a href="#qna" class="section-link">상품문의</a>
    </div>

    <section class="content-section" id="detail">
      <div class="content-title">제품상세</div>

      <% if (safeDetailImages.length > 0) { %>
        <div class="detail-images">
          <% safeDetailImages.forEach((img) => { %>
            <img src="<%= img %>" alt="상세 이미지">
          <% }) %>
        </div>
      <% } else { %>
        <div class="content-text"><%= safeDesc %></div>
      <% } %>
    </section>

    <section class="content-section" id="guide">
      <div class="content-title">구매안내</div>
      <div class="content-text"><%= safeGuide.shippingExchangeReturn || '배송 / 교환 / 반품 안내가 준비중입니다.' %></div>
    </section>

    <section class="content-section" id="review">
      <div class="content-title">상품후기</div>
      <div class="content-text">리뷰 영역은 다음 단계에서 연결됩니다.</div>
    </section>

    <section class="content-section" id="qna">
      <div class="content-title">상품문의</div>
      <div class="content-text">Q&amp;A 영역은 다음 단계에서 연결됩니다.</div>
    </section>
  </div>
</div>

<%- include('partials/footer') %>

<script>
  const galleryStage = document.getElementById('galleryStage');
  const thumbs = document.getElementById('thumbs');
  const qtyInput = document.getElementById('qtyInput');
  const minusBtn = document.getElementById('minusBtn');
  const plusBtn = document.getElementById('plusBtn');
  const totalPrice = document.getElementById('totalPrice');
  const selectedMetaText = document.getElementById('selectedMetaText');

  const colorWrap = document.getElementById('colorWrap');
  const sizeWrap = document.getElementById('sizeWrap');
  const colorButtons = colorWrap ? colorWrap.querySelectorAll('.option-chip') : [];
  const sizeButtons = sizeWrap ? sizeWrap.querySelectorAll('.option-chip') : [];

  const sectionLinks = document.querySelectorAll('.section-link');
  const contentSections = document.querySelectorAll('.content-section');

  const basePrice = Number("<%= safePrice %>");
  let selectedColor = '';
  let selectedSize = '';

  function updateMeta() {
    const metaParts = [];
    if (selectedColor) metaParts.push(`색상: ${selectedColor}`);
    if (selectedSize) metaParts.push(`사이즈: ${selectedSize}`);

    if (selectedMetaText) {
      selectedMetaText.textContent = metaParts.length ? metaParts.join(' / ') : '옵션을 선택해주세요.';
    }
  }

  function updateTotal() {
    if (!qtyInput || !totalPrice) return;
    let qty = Number(qtyInput.value || 1);
    if (qty < 1) qty = 1;
    qtyInput.value = qty;
    totalPrice.textContent = (basePrice * qty).toLocaleString() + '원';
  }

  if (thumbs && galleryStage) {
    thumbs.addEventListener('click', function (e) {
      const btn = e.target.closest('.thumb-btn');
      if (!btn) return;

      const src = btn.dataset.src || '';
      if (!src) return;

      galleryStage.innerHTML = `<img src="${src}" alt="상품 이미지">`;

      thumbs.querySelectorAll('.thumb-btn').forEach((item) => item.classList.remove('active'));
      btn.classList.add('active');
    });
  }

  colorButtons.forEach((button) => {
    button.addEventListener('click', function () {
      if (button.dataset.soldout === 'true') return;
      colorButtons.forEach((btn) => btn.classList.remove('active'));
      button.classList.add('active');
      selectedColor = button.dataset.color || '';
      updateMeta();
    });
  });

  sizeButtons.forEach((button) => {
    button.addEventListener('click', function () {
      if (button.dataset.soldout === 'true') return;
      sizeButtons.forEach((btn) => btn.classList.remove('active'));
      button.classList.add('active');
      selectedSize = button.dataset.size || '';
      updateMeta();
    });
  });

  if (minusBtn) {
    minusBtn.addEventListener('click', function () {
      qtyInput.value = Math.max(Number(qtyInput.value || 1) - 1, 1);
      updateTotal();
    });
  }

  if (plusBtn) {
    plusBtn.addEventListener('click', function () {
      qtyInput.value = Number(qtyInput.value || 1) + 1;
      updateTotal();
    });
  }

  if (qtyInput) {
    qtyInput.addEventListener('input', updateTotal);
  }

  function setActiveSection() {
    let currentId = '';

    contentSections.forEach((section) => {
      const top = section.getBoundingClientRect().top;
      if (top <= 140) {
        currentId = section.id;
      }
    });

    if (!currentId && contentSections.length) {
      currentId = contentSections[0].id;
    }

    sectionLinks.forEach((link) => {
      link.classList.remove('active');
      const href = link.getAttribute('href') || '';
      if (href === `#${currentId}`) {
        link.classList.add('active');
      }
    });
  }

  window.addEventListener('scroll', setActiveSection);

  updateMeta();
  updateTotal();
  setActiveSection();
</script>
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= product.name %> | DAMORE</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg: #f4f1eb;
      --white: #ffffff;
      --text: #222222;
      --muted: #7f7a73;
      --line: #ddd6cb;
      --soft: #f8f5f0;
      --brown: #a28a73;
      --brown-dark: #8f775e;
      --black: #111111;
      --green: #03c75a;
      --danger: #d75b4e;
      --wish: #ece8e0;
      --max: 1180px;
    }

    body {
      font-family: "Pretendard", "Noto Sans KR", Arial, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
    }

    a { color: inherit; text-decoration: none; }
    button, input, select, textarea { font: inherit; }
    img, video { display: block; max-width: 100%; }

    .site-header {
      background: var(--white);
      border-bottom: 1px solid var(--line);
      position: sticky;
      top: 0;
      z-index: 40;
    }

    .site-header-inner {
      max-width: var(--max);
      margin: 0 auto;
      padding: 14px 18px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
    }

    .logo {
      font-size: 23px;
      font-weight: 800;
      letter-spacing: 0.08em;
    }

    .gnb {
      display: flex;
      gap: 18px;
      flex-wrap: wrap;
      font-size: 13px;
      color: #444;
    }

    .page {
      max-width: var(--max);
      margin: 0 auto;
      padding: 18px 18px 70px;
    }

    .breadcrumb {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      font-size: 11px;
      color: var(--muted);
      margin-bottom: 16px;
    }

    .layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 430px;
      gap: 34px;
      align-items: start;
    }

    .gallery-main {
      width: 100%;
      aspect-ratio: 1 / 1.25;
      background: #e8e1d6;
      overflow: hidden;
      position: relative;
    }

    .gallery-main img,
    .gallery-main video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      background: #e8e1d6;
    }

    .thumbs {
      display: flex;
      gap: 6px;
      margin-top: 6px;
      flex-wrap: wrap;
    }

    .thumb-btn {
      width: 58px;
      height: 58px;
      border: 1px solid #d9d1c5;
      background: #fff;
      overflow: hidden;
      cursor: pointer;
      padding: 0;
    }

    .thumb-btn.active {
      border-color: #111;
    }

    .thumb-btn img,
    .thumb-btn video {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .purchase-box {
      position: sticky;
      top: 82px;
      background: transparent;
    }

    .interest-bubble {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 6px 12px;
      border: 1px solid #d9d1c5;
      border-radius: 999px;
      background: #f8f5ef;
      color: #5f574c;
      font-size: 11px;
      font-weight: 600;
      margin-bottom: 10px;
    }

    .title-row {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 8px;
    }

    .title {
      font-size: 22px;
      line-height: 1.4;
      font-weight: 700;
      word-break: keep-all;
    }

    .new-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 24px;
      height: 18px;
      padding: 0 5px;
      background: #f6b21a;
      color: #fff;
      font-size: 10px;
      font-weight: 700;
    }

    .summary-top {
      font-size: 12px;
      color: #655d53;
      margin-bottom: 10px;
      white-space: pre-line;
      word-break: keep-all;
    }

    .price-lines {
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
      margin-bottom: 10px;
    }

    .price-line {
      min-height: 40px;
      display: grid;
      grid-template-columns: 92px 1fr;
      align-items: center;
      border-bottom: 1px solid var(--line);
      font-size: 12px;
    }

    .price-line:last-child {
      border-bottom: 0;
    }

    .price-label {
      color: #6f675d;
      font-weight: 600;
    }

    .price-value {
      color: #222;
      font-weight: 700;
    }

    .price-old {
      color: #8a847c;
      text-decoration: line-through;
      margin-right: 10px;
      font-weight: 500;
    }

    .price-main {
      font-size: 15px;
      font-weight: 800;
    }

    .price-discount {
      color: var(--danger);
      margin-left: 6px;
      font-weight: 700;
    }

    .toggle-bar {
      height: 34px;
      border: 1px solid var(--line);
      background: #f8f5f0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      color: #333;
      cursor: pointer;
      margin-bottom: 12px;
      user-select: none;
    }

    .detail-info {
      margin-bottom: 12px;
    }

    .detail-row {
      display: grid;
      grid-template-columns: 96px 1fr;
      gap: 12px;
      padding: 6px 0;
      font-size: 12px;
    }

    .detail-row-label {
      color: #6f675d;
      font-weight: 600;
    }

    .detail-row-value {
      color: #2a2a2a;
      font-weight: 500;
      word-break: keep-all;
      white-space: pre-line;
    }

    .coupon-row {
      display: flex;
      justify-content: flex-end;
      margin-top: 4px;
      margin-bottom: 10px;
    }

    .coupon-btn {
      height: 30px;
      padding: 0 14px;
      border: 0;
      background: var(--brown);
      color: #fff;
      font-size: 11px;
      font-weight: 700;
      cursor: pointer;
    }

    .benefit-box {
      border: 1px solid var(--line);
      background: #f8f5f0;
      margin-bottom: 12px;
    }

    .benefit-line {
      min-height: 40px;
      padding: 0 12px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      border-bottom: 1px solid var(--line);
      font-size: 12px;
    }

    .benefit-line:last-child {
      border-bottom: 0;
    }

    .benefit-label {
      color: #333;
      font-weight: 700;
    }

    .benefit-value {
      color: #333;
      font-weight: 700;
    }

    .benefit-toggle {
      height: 26px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      color: #5f574c;
      cursor: pointer;
      user-select: none;
    }

    .option-wrap {
      border-bottom: 1px solid var(--line);
      padding-bottom: 10px;
      margin-bottom: 10px;
    }

    .option-row {
      display: grid;
      grid-template-columns: 70px 1fr;
      gap: 10px;
      align-items: start;
      margin-bottom: 10px;
    }

    .option-row:last-child {
      margin-bottom: 0;
    }

    .option-label {
      font-size: 12px;
      color: #5f574c;
      font-weight: 600;
      padding-top: 6px;
    }

    .option-values {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
    }

    .option-chip {
      min-width: 30px;
      min-height: 26px;
      padding: 0 8px;
      border: 1px solid #d8d1c5;
      background: #f3eee6;
      color: #7b7368;
      font-size: 11px;
      font-weight: 600;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
    }

    .option-chip.active {
      background: #111;
      color: #fff;
      border-color: #111;
    }

    .option-chip.soldout {
      opacity: 0.45;
      cursor: not-allowed;
      text-decoration: line-through;
    }

    .error-text {
      min-height: 14px;
      margin-top: 3px;
      color: var(--danger);
      font-size: 10px;
      font-weight: 700;
    }

    .selected-box {
      background: #f8f5f0;
      border: 1px solid var(--line);
      padding: 10px;
      margin-bottom: 12px;
    }

    .selected-name {
      font-size: 12px;
      font-weight: 700;
      margin-bottom: 6px;
    }

    .selected-meta {
      font-size: 11px;
      color: #6f675d;
      margin-bottom: 8px;
    }

    .qty-total-row {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 12px;
      flex-wrap: wrap;
    }

    .qty-row {
      display: inline-flex;
      align-items: center;
      border: 1px solid #d7cfc2;
      background: #fff;
      height: 30px;
    }

    .qty-btn {
      width: 30px;
      height: 30px;
      border: 0;
      background: #fff;
      font-size: 14px;
      cursor: pointer;
    }

    .qty-input {
      width: 42px;
      height: 30px;
      border: 0;
      background: #fff;
      text-align: center;
      outline: none;
      font-size: 12px;
    }

    .total-box {
      text-align: right;
      font-size: 10px;
      color: #666;
    }

    .total-price {
      display: block;
      font-size: 18px;
      color: #111;
      font-weight: 800;
      margin-top: 2px;
    }

    .btn-grid-main {
      display: grid;
      grid-template-columns: 1fr 1fr 68px;
      gap: 6px;
      margin-top: 10px;
    }

    .btn-grid-sub {
      display: grid;
      grid-template-columns: 1fr;
      gap: 6px;
      margin-top: 6px;
    }

    .action-btn {
      height: 36px;
      border: 0;
      font-size: 11px;
      font-weight: 800;
      cursor: pointer;
    }

    .btn-buy {
      background: var(--brown-dark);
      color: #fff;
    }

    .btn-cart {
      background: #cfc5b8;
      color: #111;
    }

    .btn-wish {
      background: #ece8e0;
      color: #666;
      border: 1px solid #d8d0c4;
    }

    .btn-npay {
      background: var(--green);
      color: #fff;
    }

    .section {
      margin-top: 36px;
      background: #fff;
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
    }

    .tab-nav {
      display: flex;
      justify-content: center;
      border-bottom: 1px solid var(--line);
      overflow-x: auto;
    }

    .tab-btn {
      min-width: 100px;
      height: 42px;
      border: 0;
      border-right: 1px solid var(--line);
      background: #fff;
      cursor: pointer;
      font-size: 11px;
      font-weight: 700;
      color: #666;
      flex-shrink: 0;
    }

    .tab-btn:last-child {
      border-right: 0;
    }

    .tab-btn.active {
      background: #111;
      color: #fff;
    }

    .tab-panel {
      display: none;
      padding: 24px;
    }

    .tab-panel.active {
      display: block;
    }

    .detail-images {
      display: grid;
      gap: 18px;
    }

    .detail-images img {
      width: 100%;
    }

    .review-summary {
      display: grid;
      grid-template-columns: 180px 1fr;
      gap: 20px;
      align-items: center;
      margin-bottom: 22px;
    }

    .review-score-box {
      padding: 18px;
      background: #f8f5f0;
      border: 1px solid var(--line);
      text-align: center;
    }

    .review-score {
      font-size: 32px;
      font-weight: 800;
      line-height: 1;
      margin-bottom: 8px;
    }

    .star-row {
      color: #c7a867;
      font-size: 15px;
      margin-bottom: 8px;
      letter-spacing: 1px;
    }

    .review-count {
      font-size: 11px;
      color: var(--muted);
      font-weight: 700;
    }

    .review-list,
    .inquiry-list {
      display: grid;
      gap: 12px;
    }

    .review-item,
    .inquiry-item {
      border: 1px solid var(--line);
      background: #f8f5f0;
      padding: 14px;
    }

    .review-head,
    .inquiry-head {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 8px;
      font-size: 11px;
    }

    .review-author,
    .inquiry-author {
      font-weight: 800;
    }

    .review-date,
    .inquiry-date {
      color: #888;
    }

    .review-body,
    .inquiry-body,
    .guide-text {
      font-size: 12px;
      color: #555;
      white-space: pre-line;
      word-break: keep-all;
    }

    .inquiry-form {
      display: grid;
      gap: 8px;
      margin-top: 16px;
      padding-top: 16px;
      border-top: 1px solid var(--line);
    }

    .text-input,
    .text-area {
      width: 100%;
      border: 1px solid #d2cabd;
      background: #fff;
      padding: 10px 12px;
      font-size: 12px;
      outline: none;
    }

    .text-area {
      min-height: 120px;
      resize: vertical;
    }

    .submit-btn {
      height: 34px;
      border: 0;
      background: #111;
      color: #fff;
      cursor: pointer;
      font-size: 11px;
      font-weight: 800;
    }

    .guide-block + .guide-block {
      margin-top: 24px;
    }

    .guide-label {
      font-size: 12px;
      font-weight: 800;
      margin-bottom: 8px;
    }

    @media (max-width: 1100px) {
      .layout {
        grid-template-columns: 1fr;
      }

      .purchase-box {
        position: static;
      }
    }

    @media (max-width: 640px) {
      .site-header-inner {
        flex-direction: column;
        align-items: flex-start;
      }

      .page {
        padding: 14px 12px 60px;
      }

      .title {
        font-size: 20px;
      }

      .main-price {
        font-size: 22px;
      }

      .btn-grid-main {
        grid-template-columns: 1fr;
      }

      .tab-panel {
        padding: 18px 14px;
      }

      .review-summary {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <%
    const safeSubImages = Array.isArray(product.subImages) ? product.subImages.filter(Boolean) : [];
    const safeDetailImages = Array.isArray(product.detailImages) ? product.detailImages.filter(Boolean) : [];
    const safeDesc = product.desc || product.description || '';
    const safeSummary = product.summary || '';
    const isSoldOut = product.status === 'soldout' || Number(product.stock || 0) <= 0;
    const safeOptionGroups = Array.isArray(product.optionGroups) ? product.optionGroups.filter(Boolean) : [];

    let colorGroup = null;
    let sizeGroup = null;

    if (safeOptionGroups.length >= 1) colorGroup = safeOptionGroups[0];
    if (safeOptionGroups.length >= 2) sizeGroup = safeOptionGroups[1];

    const galleryItems = [];
    if (product.image) galleryItems.push({ type: 'image', src: product.image });
    if (product.video) galleryItems.push({ type: 'video', src: product.video });
    safeSubImages.forEach((img) => {
      if (!galleryItems.find((item) => item.src === img)) {
        galleryItems.push({ type: 'image', src: img });
      }
    });

    const discountRate =
      Number(product.oldPrice || 0) > Number(product.price || 0)
        ? Math.round((1 - Number(product.price || 0) / Number(product.oldPrice || 0)) * 100)
        : 0;

    const rewardPoint = Math.floor(Number(product.price || 0) * 0.01);
    const interestCount = Math.max(Number(product.likeCount || 0), 238);

    const reviewSamples = [
      {
        author: 'damore***',
        date: '2026-04-18',
        rating: 5,
        body: '핏이 정말 예쁘고 실제로 받아보니 더 만족스러웠어요.'
      },
      {
        author: 'style***',
        date: '2026-04-16',
        rating: 4,
        body: '컬러감이 화면이랑 거의 비슷하고 코디하기 좋습니다.'
      }
    ];

    const inquirySamples = [
      {
        author: 'guest***',
        date: '2026-04-20',
        title: '배송 문의',
        body: '오늘 주문하면 언제쯤 출고될까요?'
      },
      {
        author: 'look***',
        date: '2026-04-19',
        title: '사이즈 문의',
        body: '정사이즈로 가면 될까요?'
      }
    ];
  %>

  <header class="site-header">
    <div class="site-header-inner">
      <a href="/" class="logo">DAMORE</a>
      <nav class="gnb">
        <a href="/">HOME</a>
        <a href="/category/outer">OUTER</a>
        <a href="/category/top">TOP</a>
        <a href="/category/bottom">BOTTOM</a>
        <a href="/category/dress">DRESS</a>
        <a href="/category/acc">ACC</a>
      </nav>
    </div>
  </header>

  <div
    id="productData"
    data-price="<%= Number(product.price || 0) %>"
    data-stock="<%= Number(product.stock || 0) %>"
    data-has-color="<%= colorGroup && Array.isArray(colorGroup.values) && colorGroup.values.length > 0 ? 'true' : 'false' %>"
    data-has-size="<%= sizeGroup && Array.isArray(sizeGroup.values) && sizeGroup.values.length > 0 ? 'true' : 'false' %>"
  ></div>

  <div class="page">
    <div class="breadcrumb">
      <a href="/">HOME</a>
      <% if (product.category) { %>
        <span>/</span>
        <a href="/category/<%= product.category %>"><%= product.category %></a>
      <% } %>
      <span>/</span>
      <span><%= product.name %></span>
    </div>

    <div class="layout">
      <div class="gallery-col">
        <div class="gallery-main" id="galleryStage">
          <% if (galleryItems.length > 0) { %>
            <% if (galleryItems[0].type === 'video') { %>
              <video src="<%= galleryItems[0].src %>" controls playsinline preload="metadata"></video>
            <% } else { %>
              <img src="<%= galleryItems[0].src %>" alt="<%= product.name %>">
            <% } %>
          <% } %>
        </div>

        <% if (galleryItems.length > 1) { %>
          <div class="thumbs" id="thumbs">
            <% galleryItems.forEach((item, index) => { %>
              <button
                type="button"
                class="thumb-btn <%= index === 0 ? 'active' : '' %>"
                data-type="<%= item.type %>"
                data-src="<%= item.src %>"
              >
                <% if (item.type === 'video') { %>
                  <video src="<%= item.src %>" muted playsinline preload="metadata"></video>
                <% } else { %>
                  <img src="<%= item.src %>" alt="썸네일">
                <% } %>
              </button>
            <% }) %>
          </div>
        <% } %>
      </div>

      <div class="purchase-col">
        <div class="purchase-box">
          <div class="interest-bubble">🔔 <%= interestCount.toLocaleString() %>명이 이 옷을 관심상품에 담아두었어요.</div>

          <div class="title-row" style="display:flex; gap:8px; align-items:center; flex-wrap:wrap; margin-bottom:6px;">
            <div class="title"><%= product.name %></div>
            <div style="display:inline-flex; align-items:center; justify-content:center; min-width:24px; height:18px; padding:0 5px; background:#f6b21a; color:#fff; font-size:10px; font-weight:700;">NEW</div>
          </div>

          <% if (safeSummary) { %>
            <div class="summary-top" style="font-size:12px;color:#5e564d;margin-bottom:10px;white-space:pre-line;word-break:keep-all;"><%= safeSummary %></div>
          <% } %>

          <div class="price-lines">
            <div class="price-line">
              <div class="price-label">소비자가</div>
              <div class="price-value">
                <span class="price-old"><%= Number(product.oldPrice || product.price || 0).toLocaleString() %>원</span>
              </div>
            </div>

            <div class="price-line">
              <div class="price-label" style="font-weight:700;">회원판매가</div>
              <div class="price-value">
                <span class="price-main">KRW <%= Number(product.price || 0).toLocaleString() %></span>
                <% if (discountRate > 0) { %>
                  <span class="price-discount">(<%= discountRate %>% off)</span>
                <% } %>
              </div>
            </div>
          </div>

          <div class="toggle-bar">자세히 보기 ∧</div>

          <div class="detail-info">
            <div class="detail-row">
              <div class="detail-row-label">상품간략설명</div>
              <div class="detail-row-value"><%= safeSummary || product.name %></div>
            </div>

            <div class="detail-row">
              <div class="detail-row-label">SIZE(cm)</div>
              <div class="detail-row-value">
                <% if (sizeGroup && Array.isArray(sizeGroup.values) && sizeGroup.values.length > 0) { %>
                  <%= sizeGroup.values.map(v => v.value).join(' / ') %>
                <% } else { %>
                  FREE
                <% } %>
              </div>
            </div>

            <div class="detail-row">
              <div class="detail-row-label">MODEL</div>
              <div class="detail-row-value">신혜성 178cm / 70kg (상의 100~105 / 하의 30~31)</div>
            </div>

            <div class="detail-row">
              <div class="detail-row-label">배송비(비회원)</div>
              <div class="detail-row-value"><%= product.shippingFeeText || 'KRW 2,500 (KRW 70,000 이상 구매 시 무료)' %></div>
            </div>
          </div>

          <div class="coupon-row">
            <button type="button" class="coupon-btn" onclick="alert('쿠폰 다운로드 기능은 다음 단계에서 연결')">쿠폰 확인</button>
          </div>

          <div class="benefit-box">
            <div class="benefit-line">
              <div class="benefit-label">예상 최저가ⓘ</div>
              <div class="benefit-value"><%= Number(product.price || 0).toLocaleString() %>원</div>
            </div>
            <div class="benefit-line">
              <div class="benefit-label">최대 적립 혜택</div>
              <div class="benefit-value"><%= rewardPoint.toLocaleString() %>P</div>
            </div>
            <div class="benefit-toggle">자세히 보기 ˅</div>
          </div>

          <form id="productForm" method="POST">
            <input type="hidden" name="productId" value="<%= product._id %>">
            <input type="hidden" name="selectedOption" id="selectedOptionInput" value="">
            <input type="hidden" name="option" id="legacyOptionInput" value="">
            <input type="hidden" name="selectedColor" id="selectedColorInput" value="">
            <input type="hidden" name="quantity" id="quantityHidden" value="1">
            <input type="hidden" name="selectedAddOnIds" id="selectedAddOnIdsInput" value="">
            <input type="hidden" name="selectedAddOnNames" id="selectedAddOnNamesInput" value="">
            <input type="hidden" name="selectedAddOnTotal" id="selectedAddOnTotalInput" value="0">

            <div class="option-wrap">
              <% if (colorGroup && Array.isArray(colorGroup.values) && colorGroup.values.length > 0) { %>
                <div class="option-row">
                  <div class="option-label">색상</div>
                  <div>
                    <div class="option-values" id="colorWrap">
                      <% colorGroup.values.forEach((item) => { %>
                        <button
                          type="button"
                          class="option-chip <%= item.isSoldOut ? 'soldout' : '' %>"
                          data-color="<%= item.value %>"
                          data-soldout="<%= item.isSoldOut ? 'true' : 'false' %>"
                        >
                          <%= item.value %>
                        </button>
                      <% }) %>
                    </div>
                    <div class="error-text" id="colorError"></div>
                  </div>
                </div>
              <% } %>

              <% if (sizeGroup && Array.isArray(sizeGroup.values) && sizeGroup.values.length > 0) { %>
                <div class="option-row">
                  <div class="option-label">사이즈</div>
                  <div>
                    <div class="option-values" id="sizeWrap">
                      <% sizeGroup.values.forEach((item) => { %>
                        <button
                          type="button"
                          class="option-chip <%= item.isSoldOut ? 'soldout' : '' %>"
                          data-size="<%= item.value %>"
                          data-soldout="<%= item.isSoldOut ? 'true' : 'false' %>"
                        >
                          <%= item.value %>
                        </button>
                      <% }) %>
                    </div>
                    <div class="error-text" id="optionError"></div>
                  </div>
                </div>
              <% } %>
            </div>

            <div class="selected-box">
              <div class="selected-name"><%= product.name %></div>
              <div class="selected-meta" id="selectedMetaText">옵션을 선택해주세요.</div>

              <div class="qty-total-row">
                <div class="qty-row">
                  <button type="button" class="qty-btn" id="minusBtn">-</button>
                  <input
                    type="number"
                    id="qtyInput"
                    class="qty-input"
                    value="1"
                    min="1"
                    max="<%= Math.max(Number(product.stock || 1), 1) %>"
                  />
                  <button type="button" class="qty-btn" id="plusBtn">+</button>
                </div>

                <div class="total-box">
                  TOTAL
                  <span class="total-price" id="totalPrice"><%= Number(product.price || 0).toLocaleString() %></span>
                </div>
              </div>
            </div>

            <div class="btn-grid-main">
              <button
                type="button"
                class="action-btn btn-buy"
                id="buyBtn"
                <%= isSoldOut ? 'disabled' : '' %>
              >
                BUY NOW
              </button>

              <button
                type="button"
                class="action-btn btn-cart"
                id="cartBtn"
                <%= isSoldOut ? 'disabled' : '' %>
              >
                CART
              </button>

              <button
                type="button"
                class="action-btn btn-wish"
                onclick="alert('찜 기능은 다음 단계에서 연결')"
              >
                WISH
              </button>
            </div>

            <div class="btn-grid-sub">
              <button
                type="button"
                class="action-btn btn-npay"
                onclick="alert('네이버페이 구매는 다음 단계에서 연결')"
                <%= isSoldOut ? 'disabled' : '' %>
              >
                N pay 구매
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <div class="section">
      <div class="tab-nav">
        <button type="button" class="tab-btn active" data-tab="detail">DETAIL</button>
        <button type="button" class="tab-btn" data-tab="review">REVIEW</button>
        <button type="button" class="tab-btn" data-tab="qna">Q&A</button>
        <button type="button" class="tab-btn" data-tab="guide">GUIDE</button>
      </div>

      <div class="tab-panel active" data-panel="detail">
        <% if (safeDetailImages.length > 0) { %>
          <div class="detail-images">
            <% safeDetailImages.forEach((img, index) => { %>
              <img src="<%= img %>" alt="상세 이미지 <%= index + 1 %>">
            <% }) %>
          </div>
        <% } else if (safeDesc) { %>
          <div class="guide-text"><%= safeDesc %></div>
        <% } else { %>
          <div class="guide-text">등록된 상세 정보가 없습니다.</div>
        <% } %>
      </div>

      <div class="tab-panel" data-panel="review">
        <div class="review-summary">
          <div class="review-score-box">
            <div class="review-score">4.8</div>
            <div class="star-row">★★★★★</div>
            <div class="review-count">총 <%= Number(product.reviewCount || reviewSamples.length) %>개 리뷰</div>
          </div>

          <div class="guide-text">
            실제 구매 고객 기준으로 핏, 원단, 컬러 만족도가 높은 상품입니다.
          </div>
        </div>

        <div class="review-list">
          <% reviewSamples.forEach((review) => { %>
            <div class="review-item">
              <div class="review-head">
                <div class="review-author"><%= review.author %></div>
                <div class="review-date"><%= review.date %></div>
              </div>
              <div class="star-row" style="text-align:left; margin-bottom:8px;"><%= '★'.repeat(review.rating) %></div>
              <div class="review-body"><%= review.body %></div>
            </div>
          <% }) %>
        </div>
      </div>

      <div class="tab-panel" data-panel="qna">
        <div class="inquiry-list">
          <% inquirySamples.forEach((item) => { %>
            <div class="inquiry-item">
              <div class="inquiry-head">
                <div class="inquiry-author"><%= item.author %> · <%= item.title %></div>
                <div class="inquiry-date"><%= item.date %></div>
              </div>
              <div class="inquiry-body"><%= item.body %></div>
            </div>
          <% }) %>
        </div>

        <form class="inquiry-form" onsubmit="event.preventDefault(); alert('문의 등록 기능은 다음 단계에서 연결')">
          <input type="text" class="text-input" placeholder="문의 제목">
          <textarea class="text-area" placeholder="문의 내용을 입력하세요"></textarea>
          <button type="submit" class="submit-btn">문의 등록</button>
        </form>
      </div>

      <div class="tab-panel" data-panel="guide">
        <% if (product.guide && product.guide.sizeGuideImage) { %>
          <div class="guide-block">
            <div class="guide-label">사이즈 가이드</div>
            <img src="<%= product.guide.sizeGuideImage %>" alt="사이즈 가이드">
          </div>
        <% } %>

        <% if (product.guide && product.guide.washImage) { %>
          <div class="guide-block">
            <div class="guide-label">세탁 안내</div>
            <img src="<%= product.guide.washImage %>" alt="세탁 안내">
          </div>
        <% } %>

        <% if (product.guide && product.guide.shippingExchangeReturn) { %>
          <div class="guide-block">
            <div class="guide-label">배송 / 교환 / 반품 안내</div>
            <div class="guide-text"><%= product.guide.shippingExchangeReturn %></div>
          </div>
        <% } %>

        <% if (product.guide && product.guide.copyrightNotice) { %>
          <div class="guide-block">
            <div class="guide-label">저작권 안내</div>
            <div class="guide-text"><%= product.guide.copyrightNotice %></div>
          </div>
        <% } %>

        <% if (
          !product.guide ||
          (!product.guide.sizeGuideImage &&
            !product.guide.washImage &&
            !product.guide.shippingExchangeReturn &&
            !product.guide.copyrightNotice)
        ) { %>
          <div class="guide-text">등록된 안내 정보가 없습니다.</div>
        <% } %>
      </div>
    </div>
  </div>

  <script>
    const productDataEl = document.getElementById('productData');

    const price = Number(productDataEl?.dataset.price || 0);
    const stock = Number(productDataEl?.dataset.stock || 0);
    const hasColor = productDataEl?.dataset.hasColor === 'true';
    const hasSize = productDataEl?.dataset.hasSize === 'true';

    const colorWrap = document.getElementById('colorWrap');
    const sizeWrap = document.getElementById('sizeWrap');

    const colorButtons = colorWrap ? colorWrap.querySelectorAll('.option-chip') : [];
    const sizeButtons = sizeWrap ? sizeWrap.querySelectorAll('.option-chip') : [];

    const selectedOptionInput = document.getElementById('selectedOptionInput');
    const legacyOptionInput = document.getElementById('legacyOptionInput');
    const selectedColorInput = document.getElementById('selectedColorInput');

    const optionError = document.getElementById('optionError');
    const colorError = document.getElementById('colorError');

    const qtyInput = document.getElementById('qtyInput');
    const quantityHidden = document.getElementById('quantityHidden');
    const minusBtn = document.getElementById('minusBtn');
    const plusBtn = document.getElementById('plusBtn');
    const totalPrice = document.getElementById('totalPrice');
    const selectedMetaText = document.getElementById('selectedMetaText');

    const productForm = document.getElementById('productForm');
    const cartBtn = document.getElementById('cartBtn');
    const buyBtn = document.getElementById('buyBtn');

    const galleryStage = document.getElementById('galleryStage');
    const thumbs = document.getElementById('thumbs');

    function syncSelections() {
      const colorValue = selectedColorInput ? selectedColorInput.value : '';
      const sizeValue = selectedOptionInput ? selectedOptionInput.value : '';

      const metaParts = [];
      if (colorValue) metaParts.push(`색상: ${colorValue}`);
      if (sizeValue) metaParts.push(`사이즈: ${sizeValue}`);

      if (selectedMetaText) {
        selectedMetaText.textContent = metaParts.length ? metaParts.join(' / ') : '옵션을 선택해주세요.';
      }
    }

    function updateTotal() {
      let qty = Number(qtyInput?.value || 1);

      if (qty < 1) qty = 1;
      if (stock > 0 && qty > stock) qty = stock;

      if (qtyInput) qtyInput.value = qty;
      if (quantityHidden) quantityHidden.value = qty;
      if (totalPrice) totalPrice.textContent = (price * qty).toLocaleString();

      syncSelections();
    }

    colorButtons.forEach((button) => {
      button.addEventListener('click', function () {
        if (button.dataset.soldout === 'true') return;

        colorButtons.forEach((btn) => btn.classList.remove('active'));
        button.classList.add('active');

        if (selectedColorInput) selectedColorInput.value = button.dataset.color || '';
        if (colorError) colorError.textContent = '';

        syncSelections();
      });
    });

    sizeButtons.forEach((button) => {
      button.addEventListener('click', function () {
        if (button.dataset.soldout === 'true') return;

        sizeButtons.forEach((btn) => btn.classList.remove('active'));
        button.classList.add('active');

        if (selectedOptionInput) selectedOptionInput.value = button.dataset.size || '';
        if (legacyOptionInput) legacyOptionInput.value = button.dataset.size || '';
        if (optionError) optionError.textContent = '';

        syncSelections();
      });
    });

    if (minusBtn) {
      minusBtn.addEventListener('click', function () {
        qtyInput.value = Math.max(Number(qtyInput.value || 1) - 1, 1);
        updateTotal();
      });
    }

    if (plusBtn) {
      plusBtn.addEventListener('click', function () {
        const next = Number(qtyInput.value || 1) + 1;
        qtyInput.value = stock > 0 ? Math.min(next, stock) : next;
        updateTotal();
      });
    }

    if (qtyInput) {
      qtyInput.addEventListener('input', updateTotal);
    }

    function validateForm() {
      if (hasColor && selectedColorInput && !selectedColorInput.value) {
        if (colorError) colorError.textContent = '색상을 선택해주세요.';
        return false;
      }

      if (hasSize && selectedOptionInput && !selectedOptionInput.value) {
        if (optionError) optionError.textContent = '사이즈를 선택해주세요.';
        return false;
      }

      return true;
    }

    if (cartBtn) {
      cartBtn.addEventListener('click', function () {
        if (!validateForm()) return;
        productForm.action = '/cart/add';
        productForm.submit();
      });
    }

    if (buyBtn) {
      buyBtn.addEventListener('click', function () {
        if (!validateForm()) return;
        productForm.action = '/buy-now';
        productForm.submit();
      });
    }

    if (thumbs && galleryStage) {
      thumbs.addEventListener('click', function (e) {
        const thumb = e.target.closest('.thumb-btn');
        if (!thumb) return;

        const type = thumb.dataset.type;
        const src = thumb.dataset.src;

        if (type === 'video') {
          galleryStage.innerHTML = `<video src="${src}" controls playsinline preload="metadata"></video>`;
        } else {
          galleryStage.innerHTML = `<img src="${src}" alt="상품 이미지">`;
        }

        thumbs.querySelectorAll('.thumb-btn').forEach((item) => {
          item.classList.remove('active');
        });
        thumb.classList.add('active');
      });
    }

    const tabButtons = document.querySelectorAll('.tab-btn');
    const tabPanels = document.querySelectorAll('.tab-panel');

    tabButtons.forEach((button) => {
      button.addEventListener('click', function () {
        const target = button.dataset.tab;

        tabButtons.forEach((btn) => btn.classList.remove('active'));
        tabPanels.forEach((panel) => panel.classList.remove('active'));

        button.classList.add('active');
        const panel = document.querySelector(`[data-panel="${target}"]`);
        if (panel) panel.classList.add('active');
      });
    });

    updateTotal();
  </script>
</body>
</html>